function engineQueryOSPerformancesByDate_(dateText) {
  const rows = engineQueryOSReadObjects_("SnapshotOS v2 - Show State");
  if (!rows.length) return [];

  const targetDate = engineQueryOSNormalize_(dateText);
  if (!targetDate) return [];

  const byPerformance = {};

  rows.forEach(row => {
    const rowDate = engineQueryOSNormalize_(row["Date"]);
    if (rowDate !== targetDate) return;

    const key = engineQueryOSNormalize_(
      row["Performance Label"] ||
      row["Performance Number"] ||
      JSON.stringify(row)
    );

    if (!key) return;

    // Last row wins, so newer snapshots replace older ones.
    byPerformance[key] = row;
  });

  return Object.keys(byPerformance)
    .map(key => engineQueryOSBuildPerformanceObject_(byPerformance[key]))
    .sort((a, b) => {
      const aNum = Number(a.performanceNumber || 0);
      const bNum = Number(b.performanceNumber || 0);
      return aNum - bNum;
    });
}
