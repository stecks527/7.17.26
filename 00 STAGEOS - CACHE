function testStageCacheOSPlatformAPI() {
  const os =
    StageCacheOS();

  const requiredMethods = [
    "registry",
    "status",
    "statusFor",
    "clear",
    "clearAll",
    "refresh",
    "refreshCore",
    "platformStatus",
    "test"
  ];

  const missingMethods =
    requiredMethods.filter(
      function (methodName) {
        return (
          typeof os[methodName] !==
          "function"
        );
      }
    );

  const status =
    os.platformStatus();

  const requiredCacheIds = [
    "settings",
    "weekly",
    "castList",
    "assignments",
    "guestSpeller",
    "showState",
    "prepState",
    "prepIntelligence",
    "timelineRules",
    "timelineEvents"
  ];

  const missingCaches =
    requiredCacheIds.filter(
      function (cacheId) {
        return (
          status.cacheIds.indexOf(
            cacheId
          ) === -1
        );
      }
    );

  const result = {
    healthy:
      status.healthy &&
      missingMethods.length === 0 &&
      missingCaches.length === 0,

    methodsChecked:
      requiredMethods.length,

    missingMethods:
      missingMethods,

    registeredCaches:
      status.registeredCaches,

    propertyEntries:
      status.propertyEntries,

    existingEntries:
      status.existingEntries,

    missingCaches:
      missingCaches
  };

  Logger.log(
    "STAGECACHEOS PLATFORM API TEST"
  );

  Logger.log(
    JSON.stringify(
      result,
      null,
      2
    )
  );

  SpreadsheetApp
    .getUi()
    .alert(
      "StageCacheOS platform API test " +
      (
        result.healthy
          ? "passed."
          : "found issues."
      ) +
      "\n\n" +
      "Methods checked: " +
      result.methodsChecked +
      "\n" +
      "Missing methods: " +
      result.missingMethods.length +
      "\n" +
      "Registered caches: " +
      result.registeredCaches +
      "\n" +
      "Property entries: " +
      result.propertyEntries +
      "\n" +
      "Existing entries: " +
      result.existingEntries +
      "\n" +
      "Missing caches: " +
      result.missingCaches.length
    );

  return result;
}

/*************************************************
 * STAGEOS PLATFORM CACHE REFRESH
 * Version: 1.0.0
 *
 * Rebuilds the active StageOS dependency chain
 * in a controlled order and reports timing.
 *************************************************/

function forceRebuildStageOSPlatformCaches() {
  const startedAt =
    Date.now();

  const results = [];

  /*
   * Order matters.
   *
   * 1. Source caches
   * 2. Assignment model
   * 3. Show State
   * 4. Timeline
   * 5. Decision
   * 6. Home context
   */

  stageOSRunPlatformRefreshStep_(
    results,
    "Settings",
    function () {
      if (
        typeof SettingsCacheOS !==
        "function"
      ) {
        throw new Error(
          "SettingsCacheOS is unavailable."
        );
      }

      return SettingsCacheOS()
        .refresh();
    }
  );

  stageOSRunPlatformRefreshStep_(
    results,
    "Cast List",
    function () {
      if (
        typeof CastListCacheOS !==
        "function"
      ) {
        throw new Error(
          "CastListCacheOS is unavailable."
        );
      }

      return CastListCacheOS()
        .refresh();
    }
  );

  stageOSRunPlatformRefreshStep_(
    results,
    "Assignments",
    function () {
      if (
        typeof AssignmentOS ===
        "function"
      ) {
        return AssignmentOS()
          .refresh();
      }

      if (
        typeof AssignmentCacheOS ===
        "function"
      ) {
        return AssignmentCacheOS()
          .refresh();
      }

      throw new Error(
        "AssignmentOS is unavailable."
      );
    }
  );

  /*
   * Clear dependent caches before rebuilding
   * the shared state.
   */
  if (
    typeof clearPrepIntelligenceCache_ ===
    "function"
  ) {
    clearPrepIntelligenceCache_();
  }

  if (
    typeof clearExpandedCalendarConductorCache_ ===
    "function"
  ) {
    clearExpandedCalendarConductorCache_();
  }

  if (
    typeof TimelineOS ===
    "function"
  ) {
    TimelineOS().clearAllCaches();
  }

  if (
    typeof PrepOS ===
    "function"
  ) {
    PrepOS().clearCache();
  }

  if (
    typeof HomeOS ===
    "function"
  ) {
    HomeOS().clearCache();
  }

  stageOSRunPlatformRefreshStep_(
    results,
    "Show State",
    function () {
      if (
        typeof ShowStateOS !==
        "function"
      ) {
        throw new Error(
          "ShowStateOS is unavailable."
        );
      }

      return ShowStateOS()
        .refresh();
    }
  );

  stageOSRunPlatformRefreshStep_(
    results,
    "Timeline",
    function () {
      if (
        typeof TimelineOS !==
        "function"
      ) {
        throw new Error(
          "TimelineOS is unavailable."
        );
      }

      const showState =
        ShowStateOS()
          .current();

      return TimelineOS()
        .refresh(
          showState
        );
    }
  );

  stageOSRunPlatformRefreshStep_(
    results,
    "Decision",
    function () {
      if (
        typeof DecisionOS !==
        "function"
      ) {
        throw new Error(
          "DecisionOS is unavailable."
        );
      }

      return DecisionOS()
        .refresh();
    }
  );

  stageOSRunPlatformRefreshStep_(
    results,
    "Home Context",
    function () {
      if (
        typeof HomeOS !==
        "function"
      ) {
        throw new Error(
          "HomeOS is unavailable."
        );
      }

      return HomeOS()
        .current();
    }
  );

  const totalMs =
    Date.now() -
    startedAt;

  const failed =
    results.filter(
      function (item) {
        return !item.success;
      }
    );

  const successful =
    results.filter(
      function (item) {
        return item.success;
      }
    );

  const result = {
    success:
      failed.length === 0,

    totalMs:
      totalMs,

    successful:
      successful.length,

    failed:
      failed.length,

    steps:
      results
  };

  Logger.log(
    "STAGEOS PLATFORM CACHE REFRESH"
  );

  Logger.log(
    JSON.stringify(
      result,
      null,
      2
    )
  );

  SpreadsheetApp
    .getUi()
    .alert(
      "StageOS Platform Refresh " +
      (
        result.success
          ? "Complete"
          : "Completed With Issues"
      ) +
      "\n\n" +
      results
        .map(
          function (item) {
            return (
              (
                item.success
                  ? "✅ "
                  : "❌ "
              ) +
              item.label +
              " — " +
              item.durationMs +
              " ms" +
              (
                item.error
                  ? "\n   " +
                    item.error
                  : ""
              )
            );
          }
        )
        .join("\n") +
      "\n\n" +
      "Successful: " +
      result.successful +
      "\n" +
      "Failed: " +
      result.failed +
      "\n" +
      "Total: " +
      result.totalMs +
      " ms"
    );

  return result;
}

/*************************************************
 * FAST PLATFORM REFRESH
 * Version: 1.0.1
 *
 * Normal-use refresh.
 *
 * Preserves expensive source caches:
 * - Settings
 * - Cast List
 * - Assignments
 * - Weekly
 * - Conductors
 * - Prep Intelligence
 * - Timeline Rules
 *
 * Rebuilds only derived state:
 * - Show State
 * - Timeline Events
 * - Prep State
 * - Home Context
 *************************************************/

function refreshStageOSPlatformCaches() {
  const startedAt =
    Date.now();

  const results = [];

  /*
   * Clear only derived caches.
   */
  stageOSRunPlatformRefreshStep_(
    results,
    "Clear Derived State",
    function () {
      if (
        typeof clearShowStateOSCache ===
        "function"
      ) {
        clearShowStateOSCache();
      }

      if (
        typeof timelineOSClearEventCache_ ===
        "function"
      ) {
        timelineOSClearEventCache_();
      } else if (
        typeof TimelineOS ===
        "function"
      ) {
        TimelineOS().clearCache();
      }

      if (
        typeof prepOSClearStateCache_ ===
        "function"
      ) {
        prepOSClearStateCache_();
      }

      if (
        typeof HomeOS ===
        "function"
      ) {
        HomeOS().clearCache();
      }

      return {
        cleared:
          true
      };
    }
  );

  let showState = null;

  /*
   * Show State
   */
  stageOSRunPlatformRefreshStep_(
    results,
    "Show State",
    function () {
      if (
        typeof ShowStateOS !==
        "function"
      ) {
        throw new Error(
          "ShowStateOS is unavailable."
        );
      }

      showState =
        ShowStateOS().current();

      return {
        date:
          showState.date || "",

        performances:
          Array.isArray(
            showState.performances
          )
            ? showState.performances.length
            : 0,

        plannedOuts:
          showState.intelligence &&
          Array.isArray(
            showState.intelligence
              .plannedOuts
          )
            ? showState.intelligence
                .plannedOuts.length
            : 0
      };
    }
  );

  /*
   * Timeline
   */
  stageOSRunPlatformRefreshStep_(
    results,
    "Timeline",
    function () {
      if (
        typeof TimelineOS !==
        "function"
      ) {
        throw new Error(
          "TimelineOS is unavailable."
        );
      }

      const timeline =
        TimelineOS().current(
          showState
        );

      return {
        events:
          Array.isArray(
            timeline.events
          )
            ? timeline.events.length
            : 0,

        displayEvents:
          Array.isArray(
            timeline.displayEvents
          )
            ? timeline.displayEvents.length
            : 0
      };
    }
  );

  /*
   * Prep State
   */
  stageOSRunPlatformRefreshStep_(
    results,
    "Prep State",
    function () {
      if (
        typeof PrepOS !==
        "function"
      ) {
        throw new Error(
          "PrepOS is unavailable."
        );
      }

      const prep =
        PrepOS().current();

      return {
        performances:
          prep &&
          Array.isArray(
            prep.performances
          )
            ? prep.performances.length
            : 0,

        plannedOuts:
          prep &&
          prep.intelligence &&
          Array.isArray(
            prep.intelligence
              .plannedOuts
          )
            ? prep.intelligence
                .plannedOuts.length
            : 0
      };
    }
  );

  /*
   * Home Context
   */
  stageOSRunPlatformRefreshStep_(
    results,
    "Home Context",
    function () {
      if (
        typeof HomeOS !==
        "function"
      ) {
        throw new Error(
          "HomeOS is unavailable."
        );
      }

      const home =
        HomeOS().current();

      return {
        date:
          home.date ||
          home.prettyDate ||
          "",

        timelineEvents:
          home.timeline &&
          Array.isArray(
            home.timeline
              .displayEvents
          )
            ? home.timeline
                .displayEvents.length
            : 0
      };
    }
  );

  const totalMs =
    Date.now() -
    startedAt;

  const failed =
    results.filter(
      function (item) {
        return !item.success;
      }
    );

  const result = {
    success:
      failed.length === 0,

    totalMs:
      totalMs,

    successful:
      results.length -
      failed.length,

    failed:
      failed.length,

    steps:
      results
  };

  Logger.log(
    "STAGEOS FAST PLATFORM REFRESH"
  );

  Logger.log(
    JSON.stringify(
      result,
      null,
      2
    )
  );

  SpreadsheetApp
    .getUi()
    .alert(
      "StageOS Platform Refresh " +
      (
        result.success
          ? "Complete"
          : "Completed With Issues"
      ) +
      "\n\n" +
      results
        .map(
          function (item) {
            return (
              (
                item.success
                  ? "✅ "
                  : "❌ "
              ) +
              item.label +
              " — " +
              item.durationMs +
              " ms" +
              (
                item.error
                  ? "\n   " +
                    item.error
                  : ""
              )
            );
          }
        )
        .join("\n") +
      "\n\n" +
      "Successful: " +
      result.successful +
      "\n" +
      "Failed: " +
      result.failed +
      "\n" +
      "Total: " +
      result.totalMs +
      " ms"
    );

  return result;
}


/*************************************************
 * PLATFORM REFRESH STEP
 *************************************************/

function stageOSRunPlatformRefreshStep_(
  results,
  label,
  callback
) {
  const startedAt =
    Date.now();

  try {
    callback();

    results.push({
      label:
        label,

      success:
        true,

      durationMs:
        Date.now() -
        startedAt
    });

  } catch (err) {
    results.push({
      label:
        label,

      success:
        false,

      durationMs:
        Date.now() -
        startedAt,

      error:
        String(
          err &&
          err.message
            ? err.message
            : err
        )
    });
  }
}
