function decisionOSAssignmentByTrackFromPerformance_(
  perf,
  trackId
) {
  const assignments =
    perf
      ? perf.assignments || []
      : [];

  const target =
    decisionOSNormalize_(
      trackId
    );

  return (
    assignments.find(
      function (row) {
        return (
          decisionOSNormalize_(
            row["Track ID"] ||
            row["Track"] ||
            row["Track Label"]
          ) === target
        );
      }
    ) ||
    null
  );
}


function decisionOSRoleRowFromPerformance_(
  perf,
  roleName
) {
  const cast =
    perf
      ? perf.resolvedCast || []
      : [];

  const target =
    decisionOSNormalizeRole_(
      roleName
    );

  return (
    cast.find(
      function (row) {
        return (
          decisionOSNormalizeRole_(
            row["Role"]
          ) === target
        );
      }
    ) ||
    null
  );
}


function decisionOSActorForRoleFromPerformance_(
  perf,
  roleName
) {
  const row =
    decisionOSRoleRowFromPerformance_(
      perf,
      roleName
    );

  return row
    ? row["Resolved Actor"] ||
      row["Actor"] ||
      row["Default Actor"] ||
      ""
    : "";
}


function decisionOSPrincipalOutsFromPerformance_(
  perf
) {
  const cast =
    perf
      ? perf.resolvedCast || []
      : [];

  return cast.filter(
    function (row) {
      const status =
        decisionOSNormalize_(
          row["Status"]
        );

      const role =
        decisionOSNormalize_(
          row["Role"]
        );

      const outActor =
        String(
          row["Default Actor"] ||
          row["Out Actor"] ||
          row["Out"] ||
          ""
        ).trim();

      if (!outActor) return false;

      if (
        role.includes("swing") ||
        role.includes("understudy") ||
        role.includes("u/s") ||
        role.includes("standby")
      ) {
        return false;
      }

      return (
        status.includes("covered") ||
        status.includes("out")
      );
    }
  );
}


function decisionOSInsertLinesFromPerformance_(
  perf
) {
  return decisionOSPrincipalOutsFromPerformance_(
    perf
  ).map(
    function (row) {
      const role =
        row["Role"] ||
        "Role";

      const actor =
        row["Resolved Actor"] ||
        row["Cover Actor"] ||
        row["In Actor"] ||
        "Cover TBD";

      return (
        role +
        " = " +
        actor
      );
    }
  );
}


function decisionOSPerformancesTodayFromPerformance_(
  current
) {
  if (
    !current ||
    typeof EngineQueryOS !==
      "function"
  ) {
    return [];
  }

  const query =
    EngineQueryOS();

  const performances =
    query &&
    typeof query.performancesByDate ===
      "function"
      ? query.performancesByDate(
          current.date
        )
      : [];

  return (
    performances &&
    performances.length
      ? performances
      : [current]
  );
}


function decisionOSStatus_(perf) {
  const summary =
    decisionOSSummaryFromPerformance_(
      perf
    );

  return {
    system: "DecisionOS",
    version: "4.0.0",
    available:
      Boolean(
        summary.available
      ),
    healthy:
      Boolean(
        summary.available &&
        summary.performanceLabel
      ),
    engineAvailable:
      typeof EngineQueryOS ===
      "function",
    snapshotId:
      summary.snapshotId || "",
    date:
      summary.date || "",
    performance:
      summary.performanceLabel || "",
    performanceNumber:
      summary.performanceNumber || "",
    conductor:
      summary.conductor || "",
    assignments:
      summary.assignmentCount || 0,
    resolvedCast:
      summary.resolvedCastCount || 0,
    principalOuts:
      summary.principalOutCount || 0,
    insertLines:
      summary.insertLineCount || 0
  };
}


