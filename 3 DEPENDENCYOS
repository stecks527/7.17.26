}

function dependencyOSResumeAudit_() {
  const state = dependencyOSLoadAuditState_();
  if (!state) {
    throw new Error("No saved DependencyOS audit was found. Start the audit first.");
  }
  return dependencyOSRunResumableAudit_(false);
}

function dependencyOSInitializeAudit_(sourceSS) {
  const config =
    dependencyOSConfig_();

  const engineSS =
    dependencyOSGetEngineWorkbook_();

  dependencyOSDeleteResumeTriggers_();
  dependencyOSClearSavedAudit_();
  dependencyOSResetStageSheets_(
    engineSS,
    config
  );

  const includedSheets =
    dependencyOSGetIncludedSheets_(
      sourceSS,
      config
    );

  const state = {
    version: config.version,
    status: "RUNNING",
    phase: "SCAN",
    sourceSpreadsheetId:
      sourceSS.getId(),
    sourceSpreadsheetName:
      sourceSS.getName(),
    engineSpreadsheetId:
      engineSS.getId(),
    sheetNames:
      includedSheets.map(function (sheet) {
        return sheet.getName();
      }),
    sheetIndex: 0,
    nextRow: 1,
    startedAt:
      new Date().toISOString(),
    updatedAt:
      new Date().toISOString(),
    completedSheets: 0,
    completedRows: 0,
    lastMessage:
      "Audit initialized."
  };

  dependencyOSSaveAuditState_(
    state
  );

  sourceSS.toast(
    "DependencyOS audit started. It will pause and resume automatically as needed.",
    "DependencyOS",
    8
  );
}

function dependencyOSRunResumableAudit_(fromTrigger) {
  const runStartedAt =
    Date.now();

  const config =
    dependencyOSConfig_();

  let state =
    dependencyOSLoadAuditState_();

  if (!state) {
    if (fromTrigger) {
      return null;
    }

    throw new Error(
      "No saved DependencyOS audit was found."
    );
  }

  const sourceSS =
    SpreadsheetApp.openById(
      state.sourceSpreadsheetId
    );

  const engineSS =
    dependencyOSGetEngineWorkbook_();

  console.log(
    "DependencyOS: Resuming " +
      state.phase +
      " at sheet " +
      (state.sheetIndex + 1) +
      ", row " +
      state.nextRow
  );

  while (
    Date.now() - runStartedAt <
    config.resumable.maxRunMs
  ) {
    if (state.phase === "SCAN") {
      state =
        dependencyOSProcessNextScanChunk_(
          sourceSS,
          engineSS,
          config,
          state
        );

      dependencyOSSaveAuditState_(
        state
      );

      continue;
    }

    if (state.phase === "FINALIZE") {
      const scan =
        dependencyOSBuildScanFromStage_(
          sourceSS,
          engineSS,
          config,
          state
        );

      dependencyOSScanNamedRanges_(
        sourceSS,
        scan
      );

      dependencyOSFinalizeSheetRelationships_(
        scan
      );

      scan.sourceSpreadsheetId =
        sourceSS.getId();

      scan.sourceSpreadsheetName =
        sourceSS.getName();

      scan.outputSpreadsheetId =
        engineSS.getId();

      scan.outputSpreadsheetName =
        engineSS.getName();

      dependencyOSWriteArchitectureAudit_(
        engineSS,
        config,
        scan
      );

      dependencyOSWriteRiskReport_(
        engineSS,
        config,
        scan
      );

      dependencyOSWriteSummary_(
        engineSS,
        config,
        scan,
        new Date(
          state.startedAt
        ).getTime()
      );

      state.phase =
        "COMPLETE";

      state.status =
        "COMPLETE";

      state.completedAt =
        new Date().toISOString();

      state.lastMessage =
        "DependencyOS audit complete.";

      dependencyOSSaveAuditState_(
        state
      );

      dependencyOSDeleteResumeTriggers_();

      sourceSS.toast(
        "DependencyOS audit complete. Reports were written to the Engine workbook.",
        "DependencyOS",
        10
      );

      return {
        status: "COMPLETE",
        phase: "COMPLETE",
        elapsedSeconds:
          (
            (
              Date.now() -
              new Date(
                state.startedAt
              ).getTime()
            ) /
            1000
          ).toFixed(1),
        state: state
      };
    }

    if (state.phase === "COMPLETE") {
      return {
        status: "COMPLETE",
        phase: "COMPLETE",
        state: state
      };
    }

    throw new Error(
      "Unknown DependencyOS audit phase: " +
      state.phase
    );
  }

  state.status =
    "PAUSED";

  state.updatedAt =
    new Date().toISOString();

  state.lastMessage =
    dependencyOSBuildProgressMessage_(
      state
    );

  dependencyOSSaveAuditState_(
    state
  );

  dependencyOSScheduleResume_();

  sourceSS.toast(
    state.lastMessage +
      " It will resume automatically.",
    "DependencyOS",
    8
  );

  console.log(
    "DependencyOS: Paused safely. " +
      state.lastMessage
  );

  return {
    status: "PAUSED",
    phase: state.phase,
    state: state
  };
}

function dependencyOSProcessNextScanChunk_(
  sourceSS,
  engineSS,
  config,
  state
) {
  if (
    state.sheetIndex >=
    state.sheetNames.length
  ) {
    state.phase =
      "FINALIZE";

    state.lastMessage =
      "All workbook sheets scanned.";

    return state;
  }

  const sheetName =
    state.sheetNames[
      state.sheetIndex
    ];

  const sheet =
    sourceSS.getSheetByName(
      sheetName
    );

  if (!sheet) {
    state.sheetIndex++;
    state.nextRow = 1;
    state.lastMessage =
      "Skipped missing sheet: " +
      sheetName;

    return state;
  }

  const lastRow =
    sheet.getLastRow();

  dependencyOSEnsureStageSheetStats_(
    engineSS,
    config,
    sheet
  );

  if (
    lastRow < 1 ||
    state.nextRow > lastRow
  ) {
    state.sheetIndex++;
    state.nextRow = 1;
    state.completedSheets++;
    state.lastMessage =
      "Completed sheet: " +
      sheetName;

    return state;
  }

  const rowCount =
    Math.min(
      config.resumable.rowChunkSize,
      lastRow - state.nextRow + 1
    );

  dependencyOSScanSheetChunkToStage_(
    sheet,
    engineSS,
    config,
    state.nextRow,
    rowCount
  );

  state.nextRow +=
    rowCount;

  state.completedRows +=
    rowCount;

  state.lastMessage =
    "Scanned " +
    sheetName +
    " through row " +
    (state.nextRow - 1) +
    " of " +
    lastRow +
    ".";

  if (state.nextRow > lastRow) {
    state.sheetIndex++;
    state.nextRow = 1;
    state.completedSheets++;
    state.lastMessage =
      "Completed sheet: " +
      sheetName;
  }

  return state;
}

function dependencyOSScanSheetChunk_(sheet, scan, startRow, rowCount) {
  const sheetName = sheet.getName();
  const lastColumn = sheet.getLastColumn();
  dependencyOSEnsureSheetStats_(sheet, scan);
  if (rowCount < 1 || lastColumn < 1) return;

  const range = sheet.getRange(startRow, 1, rowCount, lastColumn);
  const formulas = range.getFormulas();
  const displayValues = range.getDisplayValues();

  for (let rowOffset = 0; rowOffset < rowCount; rowOffset++) {
    for (let columnIndex = 0; columnIndex < lastColumn; columnIndex++) {
      const formula = formulas[rowOffset][columnIndex];
      const displayValue = displayValues[rowOffset][columnIndex];
      const stats = scan.sheetStats[sheetName];

      if (formula || displayValue !== "") stats.populatedCells++;

      if (!formula) {
        if (displayValue !== "") stats.staticCells++;
        continue;
      }

      stats.formulaCells++;
      const actualRow = startRow + rowOffset;
      const sourceA1 = dependencyOSColumnToLetter_(columnIndex + 1) + String(actualRow);
      const sourceQualified = dependencyOSQualifiedAddress_(sheetName, sourceA1);

      const formulaRecord = {
        sourceSheet: sheetName,
        sourceCell: sourceA1,
        sourceQualified: sourceQualified,
        formula: formula,
        displayValue: displayValue,
        isExternal: dependencyOSIsExternalFormula_(formula),
        isBroken: dependencyOSIsBrokenFormula_(formula, displayValue),
        references: []
      };

      if (formulaRecord.isExternal) {
        stats.externalFormulaCount++;
        scan.externalLinks.push({
          sourceSheet: sheetName,
          sourceCell: sourceA1,
          formula: formula,
          externalId: dependencyOSExtractImportRangeId_(formula),
          externalRange: dependencyOSExtractImportRangeRange_(formula)
        });
      }

      if (formulaRecord.isBroken) {
        stats.brokenFormulaCount++;
        scan.brokenFormulas.push({
          sheet: sheetName,
          cell: sourceA1,
          formula: formula,
          displayValue: displayValue
        });
      }

      dependencyOSExtractFormulaReferences_(formula, sheetName)
        .forEach(function (reference) {
          const relationship = {
            sourceSheet: sheetName,
            sourceCell: sourceA1,
            sourceQualified: sourceQualified,
            targetSheet: reference.sheet,
            targetRange: reference.range,
            targetQualified: dependencyOSQualifiedAddress_(reference.sheet, reference.range),
            relationshipType: reference.relationshipType,
            formula: formula
          };

          formulaRecord.references.push(relationship);
          scan.references.push(relationship);
          dependencyOSRegisterReferenceUsage_(scan, relationship);
        });

      scan.formulas.push(formulaRecord);
    }
  }
}

function dependencyOSEnsureSheetStats_(sheet, scan) {
  const sheetName = sheet.getName();
  if (scan.sheetStats[sheetName]) return;

  scan.sheetStats[sheetName] = {
    sheetName: sheetName,
    sheetId: sheet.getSheetId(),
    lastRow: sheet.getLastRow(),
    lastColumn: sheet.getLastColumn(),
    populatedCells: 0,
    formulaCells: 0,
    staticCells: 0,
    incomingReferenceCount: 0,
    outgoingReferenceCount: 0,
    incomingSourceCells: {},
    outgoingTargetCells: {},
    externalFormulaCount: 0,
    brokenFormulaCount: 0,
    namedRangeCount: 0,
    validationCount: 0,
    formattingRuleCount: 0
  };
}

function dependencyOSCreateEmptyScan_(ss) {
  return {
    scannedAt: new Date(),
    spreadsheetId: ss.getId(),
    spreadsheetName: ss.getName(),
    sheetStats: {},
    formulas: [],
    references: [],
    namedRanges: [],
    validations: [],
    formattingRules: [],
    externalLinks: [],
    brokenFormulas: [],
    usageByTarget: {},
    incomingBySheet: {},
    outgoingBySheet: {}
  };
}

function dependencyOSGetIncludedSheets_(ss, config) {
  return ss.getSheets().filter(function (sheet) {
    return config.excludedSheets.indexOf(sheet.getName()) === -1;
  });
}

function dependencyOSBuildProgressMessage_(state) {
  const totalSheets = state.sheetNames ? state.sheetNames.length : 0;
  const currentSheet = state.sheetNames && state.sheetNames[state.sheetIndex]
    ? state.sheetNames[state.sheetIndex]
    : "Final reports";

  return (
    "Paused after " + state.completedSheets + " of " + totalSheets +
    " sheets. Next: " + currentSheet +
    (state.phase === "SCAN" ? " row " + state.nextRow + "." : ".")
  );
}

/* =========================================================
 * SAVED STATE / SCAN SNAPSHOT
 * ========================================================= */

function dependencyOSGetProperties_() {
  return PropertiesService.getDocumentProperties();
}

function dependencyOSStateKey_() {
  return dependencyOSConfig_()
    .resumable
    .statePropertyKey;
}



function dependencyOSSaveAuditState_(state) {
  state.updatedAt = new Date().toISOString();
  dependencyOSGetProperties_().setProperty(
    dependencyOSStateKey_(),
    JSON.stringify(state)
  );
}

function dependencyOSLoadAuditState_() {
  const raw = dependencyOSGetProperties_().getProperty(dependencyOSStateKey_());
  return raw ? JSON.parse(raw) : null;
}














function dependencyOSClearSavedAudit_() {
  dependencyOSGetProperties_()
    .deleteProperty(
      dependencyOSStateKey_()
    );
}

function dependencyOSResetAuditProgress_() {
  dependencyOSDeleteResumeTriggers_();
  dependencyOSClearSavedAudit_();

  const activeSS =
    SpreadsheetApp.getActiveSpreadsheet();

  const engineSS =
    dependencyOSGetEngineWorkbook_();

  const config =
    dependencyOSConfig_();

  dependencyOSResetStageSheets_(
    engineSS,
    config
  );

  if (activeSS) {
    activeSS.toast(
      "DependencyOS saved progress and Engine staging data were reset.",
      "DependencyOS",
      6
    );
  }

  return {
    reset: true
  };
}

function dependencyOSGetAuditStatus_() {
  const state = dependencyOSLoadAuditState_();
  if (!state) {
    return { status: "NONE", message: "No DependencyOS audit is currently saved." };
  }

  return {
    status: state.status,
    phase: state.phase,
    state: state,
    message: [
      "Status: " + state.status,
      "Phase: " + state.phase,
      "Completed sheets: " + state.completedSheets + " of " + state.sheetNames.length,
      "Next sheet: " + (state.sheetNames[state.sheetIndex] || "Final reports"),
      "Next row: " + state.nextRow,
      "Last update: " + state.updatedAt,
      "",
      state.lastMessage || ""
    ].join("\n")
  };
}

/* =========================================================
 * AUTOMATIC RESUME TRIGGER
 * ========================================================= */

function dependencyOSScheduleResume_() {
  dependencyOSDeleteResumeTriggers_();
  ScriptApp.newTrigger("dependencyOSResumeAuditTrigger_")
    .timeBased()
    .after(dependencyOSConfig_().resumable.resumeAfterMs)
    .create();
}

function dependencyOSDeleteResumeTriggers_() {
  ScriptApp.getProjectTriggers().forEach(function (trigger) {
    if (trigger.getHandlerFunction() === "dependencyOSResumeAuditTrigger_") {
      ScriptApp.deleteTrigger(trigger);
    }
  });
}




