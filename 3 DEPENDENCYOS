/* =========================================================
 * TABLE WRITERS
 * ========================================================= */

function dependencyOSWriteTable_(
  sheet,
  headers,
  rows,
  config
) {
  sheet.clear();

  const safeHeaders =
    dependencyOSMakeReportRowsSafe_([headers]);

  const safeRows =
    dependencyOSMakeReportRowsSafe_(rows);

  sheet.getRange(1, 1, 1, headers.length)
    .setValues(safeHeaders);

  dependencyOSStyleHeader_(
    sheet.getRange(1, 1, 1, headers.length),
    config
  );

  if (safeRows.length) {
    sheet.getRange(
      2,
      1,
      safeRows.length,
      headers.length
    )
      .setValues(safeRows)
      .setVerticalAlignment("top")
      .setWrap(true);
  } else {
    sheet.getRange(2, 1)
      .setValue("No matching dependencies were found.");
  }

  sheet.setFrozenRows(1);

  if (sheet.getFilter()) {
    sheet.getFilter().remove();
  }

  if (safeRows.length) {
    sheet.getRange(
      1,
      1,
      safeRows.length + 1,
      headers.length
    ).createFilter();
  }
}


function dependencyOSWriteInspectorSection_(
  sheet,
  startRow,
  title,
  headers,
  rows,
  config
) {
  sheet.getRange(
    startRow,
    1,
    1,
    headers.length
  ).merge();

  sheet.getRange(startRow, 1)
    .setValue(title);

  dependencyOSStyleSectionRow_(
    sheet.getRange(
      startRow,
      1,
      1,
      headers.length
    ),
    config
  );

  const safeHeaders =
    dependencyOSMakeReportRowsSafe_([headers]);

  const safeRows =
    dependencyOSMakeReportRowsSafe_(rows);

  sheet.getRange(
    startRow + 1,
    1,
    1,
    headers.length
  ).setValues(safeHeaders);

  dependencyOSStyleHeader_(
    sheet.getRange(
      startRow + 1,
      1,
      1,
      headers.length
    ),
    config
  );

  if (safeRows.length) {
    sheet.getRange(
      startRow + 2,
      1,
      safeRows.length,
      headers.length
    ).setValues(safeRows);
  } else {
    sheet.getRange(startRow + 2, 1)
      .setValue("None detected.");
  }

  return startRow + 2 + Math.max(safeRows.length, 1);
}


