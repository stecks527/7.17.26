/*************************************************
 * BUILD ACTOR OUT / COVERAGE NOTES
 *************************************************/

function productionEventsBuildActorOutCoverageV2_(
  people,
  events
) {
  (people || [])
    .forEach(function(person) {
      const role =
        String(person.role || "")
          .trim();

      const roleLower =
        role.toLowerCase();

      const roleKey =
        person.roleKey;

      const shortName =
        person.shortName;

      if (!role) return;

      /*
       * Stage-management substitutes are handled
       * by the existing SM workflow.
       */
      if (
        roleLower === "psm / asm sub" ||
        roleLower.includes(
          "stage manager sub"
        ) ||
        roleLower.includes("sm sub")
      ) {
        return;
      }

      if (
        !person.out ||
        person.out.totalShows === 0
      ) {
        return;
      }

      const isSwingOrUnderstudy =
        roleLower === "swing" ||
        roleLower.includes("swing") ||
        roleLower.includes(
          "understudy"
        ) ||
        roleLower.includes("u/s") ||
        roleLower === "us";

      const reasonText =
        productionEventsReasonSummaryV1_(
          person.out.reasonCounts,
          person.out.totalShows
        );

      const firstPart =
        "- " +
        shortName +
        " OUT (" +
        person.out.totalShows +
        " " +
        (
          person.out.totalShows === 1
            ? "show"
            : "shows"
        ) +
        ") (" +
        reasonText +
        ")";

      /*
       * Swings and understudies report their own OUT.
       * They do not need principal-role coverage matching.
       */
      if (isSwingOrUnderstudy) {
        events.push({
          type: "UNDERSTUDY_OUT",
          priority: 31,
          affectsPayroll: true,
          note:
            firstPart +
            ": " +
            productionEventsDateSummaryV1_(
              person.out.dates
            )
        });

        return;
      }

      const coverage = [];

      (people || [])
        .forEach(function(cover) {
          if (
            cover.key === person.key
          ) {
            return;
          }

          const data =
            cover.ins &&
            cover.ins[roleKey];

          if (!data) return;

          coverage.push({
            sort:
              productionEventsFirstDateSortV1_(
                data.dates
              ),

            text:
              cover.shortName +
              " IN as " +
              productionEventsDisplayRoleV1_(
                role
              ) +
              " (" +
              data.shows +
              " " +
              (
                data.shows === 1
                  ? "show"
                  : "shows"
              ) +
              "): " +
              productionEventsDateSummaryV1_(
                data.dates
              )
          });
        });

      if (coverage.length > 0) {
        coverage.sort(
          function(a, b) {
            return a.sort - b.sort;
          }
        );

        events.push({
          type:
            "ACTOR_OUT_COVERAGE",
          priority: 30,
          affectsPayroll: true,
          note:
            firstPart +
            ": " +
            coverage
              .map(function(item) {
                return item.text;
              })
              .join("; ")
        });

        return;
      }

      events.push({
        type: "ACTOR_OUT",
        priority: 30,
        affectsPayroll: true,
        note:
          firstPart +
          ": " +
          productionEventsDateSummaryV1_(
            person.out.dates
          )
      });
    });
}

