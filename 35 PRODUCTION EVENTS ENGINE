    return "";
  }

  const actorMap =
    productionEventsActorMapV1_(castList);

  const dateDisplays =
    payroll
      .getRange("B3:H3")
      .getDisplayValues()[0];

  const people =
    productionEventsReadPayrollPeopleV2_(
      payroll,
      dateDisplays,
      actorMap
    );

  const context = {
    ss: ss,
    payroll: payroll,
    castList: castList,
    actorMap: actorMap,
    dateDisplays: dateDisplays,
    payrollPeople: people,
    payrollPersonEvents:
      productionEventsFlattenPersonEventsV2_(
        people
      ),

    wizardLog:
      productionEventsFindSheetV1_(
        ss,
        [
          "Wizard Log",
          "New Hire Wizard Log",
          "Personnel Log"
        ]
      ),

    weekly:
      productionEventsFindCurrentWeeklyV1_(
        ss
      )
  };

  const events = [];

  productionEventsBuildSMOfficeCoverageV1_(
    people,
    events
  );

  stageOSBuildPayrollActorOutNotes_20260711_(
    people,
    events
  );

  productionEventsFromWizardLogV1_(
    context,
    events
  );

  productionEventsFromWeeklyV1_(
    context,
    events
  );

  productionEventsBuildRehearsalCalloutNotesV1_(
    context,
    events
  );

  const sortedEvents =
    productionEventsSortV1_(
      events
    );

  return productionEventsFormatPayrollNotesV1_(
    sortedEvents,
    context
  );
}
