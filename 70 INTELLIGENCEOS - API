/*************************************************
 * PUBLIC ENTRY POINTS
 *************************************************/

function buildStageOSIntelligence(showState, timeline) {
  showState = showState || buildShowState();
  timeline = timeline || buildTimelineOS(showState);

  const day = buildDayIntelligence_(showState);

  return {
    day: day,
    inserts: buildInsertIntelligence_(showState),
    focus: buildFocusIntelligence_(showState, timeline),
    alerts: buildAlertIntelligence_(showState),
    postShow: buildPostShowIntelligence_(showState, timeline)
  };
}

/*************************************************
 * DAY INTELLIGENCE
 *************************************************/

function buildDayIntelligence_(showState) {
  const targetDate = parseInOutDate_(showState.date) || new Date();

  const dayName = Utilities.formatDate(
    targetDate,
    Session.getScriptTimeZone(),
    "EEEE"
  );

  const performances = showState.performances || [];
  const notes = String(showState.notes || "");

  return {
    date: targetDate,
    dayName: dayName,
    isSunday: dayName.toLowerCase() === "sunday",
    isMonday: dayName.toLowerCase() === "monday",
    isFriday: dayName.toLowerCase() === "friday",

    performanceCount: performances.length,
    hasPerformance: performances.length > 0,
    hasTwoShowDay: performances.length >= 2,

    hasGuestSpeller: !!(
      showState.guestSpeller &&
      showState.guestSpeller.name
    ),

    hasDollarFriday: notes.toLowerCase().includes("dollar friday"),
    hasNotes: !!notes.trim()
  };
}

/*************************************************
 * INSERT INTELLIGENCE
 *************************************************/

function buildInsertIntelligence_(showState) {
  const principalOuts = getPrincipalCastOutsForIntelligence_(showState);
  const count = principalOuts.length;

  let insertType = "NONE";

  if (count >= 3) {
    insertType = "TODAY_AT_INSERT";
  } else if (count >= 1) {
    insertType = "FOH_INSERT_SLIPS";
  }

  return {
    count,
    insertType,
    principalOuts,
    needsInsert: count > 0,
    needsTodayAtInsert: count >= 3,
    needsFOHSlips: count >= 1 && count < 3
  };
}

/*************************************************
 * ALERT INTELLIGENCE
 *************************************************/

function buildAlertIntelligence_(showState) {
  const inserts = buildInsertIntelligence_(showState);
  const alerts = [];

  if (inserts.count >= 3) {
    alerts.push({
      type: "insert",
      text:
        "• " + inserts.count + " cast members are out today.\n\n" +
        "    - TODAY AT INSERT required."
    });
  } else if (inserts.count > 0) {
    const lines = [];

    lines.push(
      "• " +
      inserts.count +
      " cast member" +
      (inserts.count === 1 ? "" : "s") +
      " " +
      (inserts.count === 1 ? "is" : "are") +
      " out today. FOH insert" +
      (inserts.count === 1 ? "" : "s") +
      " required."
    );

    inserts.principalOuts.forEach(out => {
      lines.push("    - " + out.in + " is on as " + out.role + ".");
    });

    alerts.push({
      type: "insert",
      text: lines.join("\n")
    });
  }

  if (showState.guestSpeller && showState.guestSpeller.name) {
    alerts.push({
      type: "guest",
      text: "• Guest Speller: " + showState.guestSpeller.name
    });
  }

  return alerts;
}

/*************************************************
 * FOCUS INTELLIGENCE
 *************************************************/

function buildFocusIntelligence_(showState, timeline) {
  const inserts = buildInsertIntelligence_(showState);
  const postShow = buildPostShowIntelligence_(showState, timeline);
  const workflowTasks = buildWorkflowFocusIntelligence_(showState);
  const tasks = [];

  tasks.push({ title: "Prep IN/OUT" });

  if (inserts.needsTodayAtInsert) {
    tasks.push({ title: "Prepare TODAY AT INSERT" });
  } else if (inserts.needsFOHSlips) {
    tasks.push({ title: "Send IN/OUT changes to FOH" });
  }

  postShow.tasks.forEach(task => {
    tasks.push({ title: task });
  });

  workflowTasks.forEach(task => {
    tasks.push(task);
  });

  return dedupeIntelligenceTasks_(tasks);
}

/*************************************************
 * POST SHOW INTELLIGENCE
 * Placeholder for 07a.
 *************************************************/

function buildPostShowIntelligence_(showState, timeline) {
  const currentPerf = getCurrentPerformanceForIntelligence_(showState, timeline);
  const nextPerf = getNextPerformanceForIntelligence_(showState, currentPerf);

  if (!currentPerf || !nextPerf) {
    return {
      hasSecondPerformance: false,
      tasks: [],
      sliderChanges: []
    };
  }

  const sliderChanges =
    buildSliderChangeIntelligence_(currentPerf, nextPerf);

  const tasks = [];

  tasks.push("Flip FOH Board");

  if (
    currentPerf.conductor &&
    nextPerf.conductor &&
    currentPerf.conductor !== nextPerf.conductor
  ) {
    tasks.push(
      "Swap " +
      currentPerf.conductor +
      " → " +
      nextPerf.conductor +
      " conductor slider"
    );
  }

  sliderChanges.forEach(change => {
    tasks.push(change.text);
  });

  tasks.push("Reset Performance Report");

  return {
    hasSecondPerformance: true,
    currentPerformance: currentPerf,
    nextPerformance: nextPerf,
    sliderChanges,
    tasks
  };
}

