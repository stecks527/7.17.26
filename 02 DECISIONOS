/*************************************************
 * 02 DECISIONOS
 * Version: 4.0.0
 * Status: ACTIVE
 *
 * Canonical Engine-backed decision API.
 *
 * Standard lifecycle:
 * - current()
 * - get()
 * - refresh()
 * - status()
 * - test()
 *
 * Compatibility methods remain available.
 *************************************************/

function DecisionOS() {
  let currentLoaded = false;
  let currentPerformance = null;

  function current_() {
    if (!currentLoaded) {
      currentPerformance =
        decisionOSCurrentPerformance_();

      currentLoaded = true;
    }

    return currentPerformance;
  }

  return {
    /***************
     * Platform API
     ***************/
    current: function () {
      return current_();
    },

    get: function () {
      return current_();
    },

    refresh: function () {
      decisionOSClearCache_();

      currentLoaded = false;
      currentPerformance = null;

      return current_();
    },

    status: function () {
      return decisionOSStatus_(
        current_()
      );
    },

    test: function () {
      return testDecisionOSPlatformAPI();
    },

    /***************
     * Core
     ***************/
    currentPerformance: function () {
      return current_();
    },

    available: function () {
      return Boolean(
        current_()
      );
    },

    summary: function () {
      return decisionOSSummaryFromPerformance_(
        current_()
      );
    },

    performancesToday: function () {
      return decisionOSPerformancesTodayFromPerformance_(
        current_()
      );
    },

    today: function () {
      return decisionOSTodayFromPerformance_(
        current_()
      );
    },

    /***************
     * Performance
     ***************/
    showDate: function () {
      const perf = current_();
      return perf ? perf.date : "";
    },

    performanceLabel: function () {
      const perf = current_();
      return perf ? perf.performanceLabel : "";
    },

    performanceNumber: function () {
      const perf = current_();
      return perf ? perf.performanceNumber : "";
    },

    performanceTime: function () {
      const perf = current_();
      return perf ? perf.performanceTime : "";
    },

    showType: function () {
      const perf = current_();
      return perf ? perf.showType : "";
    },

    conductor: function () {
      const perf = current_();
      return perf ? perf.conductor : "";
    },

    guestSpeller: function () {
      const perf = current_();
      return perf ? perf.guestSpeller : "";
    },

    hasGuestSpeller: function () {
      return Boolean(
        String(
          this.guestSpeller() || ""
        ).trim()
      );
    },

    notes: function () {
      const perf = current_();
      return perf ? perf.notes || "" : "";
    },

    /***************
     * Engine rows
     ***************/
    showState: function () {
      const perf = current_();
      return perf ? perf.showState || {} : {};
    },

    showStateHistory: function () {
      const perf = current_();
      return perf ? perf.showStateHistory || [] : [];
    },

    assignments: function () {
      const perf = current_();
      return perf ? perf.assignments || [] : [];
    },

    resolvedCast: function () {
      const perf = current_();
      return perf ? perf.resolvedCast || [] : [];
    },

    coveredRoles: function () {
      const perf = current_();
      return perf ? perf.coveredRoles || [] : [];
    },

    outs: function () {
      const perf = current_();
      return perf ? perf.outs || [] : [];
    },

    principalOuts: function () {
      return decisionOSPrincipalOutsFromPerformance_(
        current_()
      );
    },

    insertLines: function () {
      return decisionOSInsertLinesFromPerformance_(
        current_()
      );
    },

    /***************
     * Assignments
     ***************/
    assignmentByTrack: function (trackId) {
      return decisionOSAssignmentByTrackFromPerformance_(
        current_(),
        trackId
      );
    },

    callingSM: function () {
      return decisionOSAssignmentByTrackFromPerformance_(
        current_(),
        "calling"
      );
    },

    deckSM: function () {
      return decisionOSAssignmentByTrackFromPerformance_(
        current_(),
        "deck"
      );
    },

    audio: function () {
      return decisionOSAssignmentByTrackFromPerformance_(
        current_(),
        "audio"
      );
    },

    assignmentNameByTrack: function (trackId) {
      const row =
        decisionOSAssignmentByTrackFromPerformance_(
          current_(),
          trackId
        );

      return row
        ? row["Assigned Person"] ||
          row["Person"] ||
          row["Actor"] ||
          row["Name"] ||
          ""
        : "";
    },

    /***************
     * Cast
     ***************/
    actorForRole: function (roleName) {
      return decisionOSActorForRoleFromPerformance_(
        current_(),
        roleName
      );
    },

    roleRow: function (roleName) {
      return decisionOSRoleRowFromPerformance_(
        current_(),
        roleName
      );
    },

    barfee: function () {
      return (
        decisionOSActorForRoleFromPerformance_(
          current_(),
          "Barfée"
        ) ||
        decisionOSActorForRoleFromPerformance_(
          current_(),
          "Barfee"
        )
      );
    },

    olive: function () {
      return decisionOSActorForRoleFromPerformance_(
        current_(),
        "Olive"
      );
    },

    rona: function () {
      return decisionOSActorForRoleFromPerformance_(
        current_(),
        "Rona"
      );
    },

    panch: function () {
      return decisionOSActorForRoleFromPerformance_(
        current_(),
        "Panch"
      );
    },

    chip: function () {
      return decisionOSActorForRoleFromPerformance_(
        current_(),
        "Chip"
      );
    },

    leaf: function () {
      return decisionOSActorForRoleFromPerformance_(
        current_(),
        "Leaf"
      );
    },

    marcy: function () {
      return decisionOSActorForRoleFromPerformance_(
        current_(),
        "Marcy"
      );
    },

    mitch: function () {
      return decisionOSActorForRoleFromPerformance_(
        current_(),
        "Mitch"
      );
    },

    schwartzy: function () {
      return decisionOSActorForRoleFromPerformance_(
        current_(),
        "Schwartzy"
      );
    },

    /***************
     * Flags
     ***************/
    hasPerformance: function () {
      return Boolean(
        this.performanceLabel()
      );
    },

    isMatinee: function () {
      return (
        decisionOSNormalize_(
          this.showType()
        ).includes("mat") ||
        decisionOSNormalize_(
          this.performanceLabel()
        ).includes("mat")
      );
    },

    isEvening: function () {
      return (
        decisionOSNormalize_(
          this.showType()
        ).includes("eve") ||
        decisionOSNormalize_(
          this.performanceLabel()
        ).includes("eve")
      );
    },

    officeShow: function () {
      return decisionOSContainsAny_(
        [this.notes()],
        ["office show"]
      );
    },

    trainingToday: function () {
      return decisionOSContainsAny_(
        [this.notes()],
        [
          "training",
          "rehearsing",
          "rehearsal"
        ]
      );
    },

    /***************
     * Snapshot review
     ***************/
    review: function () {
      return decisionOSReviewLatestPerformance_();
    },

    reviewLatestPerformance: function () {
      return decisionOSReviewLatestPerformance_();
    }
  };
}


/*************************************************
 * CURRENT PERFORMANCE
 *************************************************/

function decisionOSCurrentPerformance_() {
  if (typeof EngineQueryOS !== "function") return null;
  return EngineQueryOS().latestPerformance();
}

/*************************************************
 * TODAY PAYLOAD
 *************************************************/

function decisionOSToday_() {
  const perf = decisionOSCurrentPerformance_();

  if (!perf) {
    return {
      available: false,
      message: "No current Engine performance found."
    };
  }

  return {
    available: true,
    snapshotId: perf.snapshotId || "",
    date: perf.date || "",
    dateText: perf.date || "",
    performanceLabel: perf.performanceLabel || "",
    performanceText: perf.performanceLabel || "",
    performanceNumber: perf.performanceNumber || "",
    performanceTime: perf.performanceTime || "",
    showType: perf.showType || "",
    conductor: perf.conductor || "",
    guestSpeller: perf.guestSpeller || "",
    notes: perf.notes || "",
    assignments: perf.assignments || [],
    resolvedCast: perf.resolvedCast || [],
    coveredRoles: perf.coveredRoles || [],
    outs: perf.outs || [],
    principalOuts: decisionOSPrincipalOuts_(),
    insertLines: decisionOSInsertLines_(),
    counts: perf.counts || {}
  };
}

/*************************************************
 * ASSIGNMENTS
 *************************************************/

function decisionOSAssignmentByTrack_(trackId) {
  const perf = decisionOSCurrentPerformance_();
  const assignments = perf ? perf.assignments || [] : [];
  const target = decisionOSNormalize_(trackId);

  return assignments.find(row =>
    decisionOSNormalize_(
      row["Track ID"] ||
      row["Track"] ||
      row["Track Label"]
    ) === target
  ) || null;
}

/*************************************************
 * CAST
 *************************************************/

function decisionOSRoleRow_(roleName) {
  const perf = decisionOSCurrentPerformance_();
  const cast = perf ? perf.resolvedCast || [] : [];
  const target = decisionOSNormalizeRole_(roleName);

  return cast.find(row =>
    decisionOSNormalizeRole_(row["Role"]) === target
  ) || null;
}

function decisionOSActorForRole_(roleName) {
  const row = decisionOSRoleRow_(roleName);

  return row
    ? row["Resolved Actor"] ||
      row["Actor"] ||
      row["Default Actor"] ||
      ""
    : "";
}

function decisionOSPrincipalOuts_() {
  const perf = decisionOSCurrentPerformance_();
  const cast = perf ? perf.resolvedCast || [] : [];

  return cast.filter(row => {
    const status = decisionOSNormalize_(row["Status"]);
    const role = decisionOSNormalize_(row["Role"]);
    const outActor = String(
      row["Default Actor"] ||
      row["Out Actor"] ||
      row["Out"] ||
      ""
    ).trim();

    if (!outActor) return false;

    if (
      role.includes("swing") ||
      role.includes("understudy") ||
      role.includes("u/s") ||
      role.includes("standby")
    ) {
      return false;
    }

    return (
      status.includes("covered") ||
      status.includes("out")
    );
  });
}

function decisionOSInsertLines_() {
  return decisionOSPrincipalOuts_().map(row => {
    const role = row["Role"] || "Role";
    const actor =
      row["Resolved Actor"] ||
      row["Cover Actor"] ||
      row["In Actor"] ||
      "Cover TBD";

    return role + " = " + actor;
  });
}

/*************************************************
 * SNAPSHOT REVIEW
 *************************************************/

function decisionOSReviewLatestPerformance_() {
  const assignmentChanges =
    typeof SnapshotDiffOS === "function"
      ? SnapshotDiffOS().assignments()
      : [];

  const castChanges =
    typeof SnapshotDiffOS === "function"
      ? SnapshotDiffOS().cast()
      : [];

  return {
    system: "DecisionOS",
    version: "2.0.0",
    reviewedAt: new Date(),
    currentPerformance: decisionOSSummary_(),
    assignmentChanges,
    castChanges,
    recommendations: decisionOSBuildRecommendations_(assignmentChanges, castChanges)
  };
}

function decisionOSBuildRecommendations_(assignmentChanges, castChanges) {
  const recommendations = [];

  assignmentChanges.forEach(change => {
    recommendations.push({
      type: "ASSIGNMENT_CHANGE",
      severity: "INFO",
      message:
        change.key +
        " changed from " +
        (change.previous || "blank") +
        " to " +
        (change.current || "blank") +
        "."
    });
  });

  castChanges.forEach(change => {
    recommendations.push({
      type: "CAST_CHANGE",
      severity: "INFO",
      message:
        change.key +
        " changed from " +
        (change.previous || "blank") +
        " to " +
        (change.current || "blank") +
        "."
    });
  });

  if (!recommendations.length) {
    recommendations.push({
      type: "NO_CHANGES",
      severity: "OK",
      message: "No major changes detected from the previous snapshot."
    });
  }

  return recommendations;
}

/*************************************************
 * SUMMARY
 *************************************************/

function decisionOSSummary_() {
  const perf = decisionOSCurrentPerformance_();

  if (!perf) {
    return {
      available: false,
      message: "No current Engine performance found."
    };
  }

  return {
    available: true,
    snapshotId: perf.snapshotId || "",
    date: perf.date || "",
    performanceLabel: perf.performanceLabel || "",
    performanceNumber: perf.performanceNumber || "",
    performanceTime: perf.performanceTime || "",
    showType: perf.showType || "",
    conductor: perf.conductor || "",
    guestSpeller: perf.guestSpeller || "",
    hasGuestSpeller: !!String(perf.guestSpeller || "").trim(),
    assignmentCount: (perf.assignments || []).length,
    resolvedCastCount: (perf.resolvedCast || []).length,
    coveredRoleCount: (perf.coveredRoles || []).length,
    uncoveredOutCount: (perf.outs || []).length,
    principalOutCount: decisionOSPrincipalOuts_().length,
    insertLineCount: decisionOSInsertLines_().length
  };
}

/*************************************************
 * HELPERS
 *************************************************/

function decisionOSNormalize_(value) {
  return String(value || "")
    .toLowerCase()
    .replace(/\s+/g, " ")
    .trim();
}

function decisionOSNormalizeRole_(value) {
  return decisionOSNormalize_(value)
    .replace(/[ée]/g, "e")
    .replace(/[^a-z0-9 ]/g, "")
    .trim();
}

function decisionOSContainsAny_(values, needles) {
  const text = values
    .map(value => String(value || ""))
    .join(" ")
    .toLowerCase();

  return needles.some(needle =>
    text.includes(String(needle || "").toLowerCase())
  );
}

