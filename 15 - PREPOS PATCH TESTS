/* =========================================================
 * SHEET TARGETS
 * ========================================================= */

function prepOSCheckPreflightSheetTargets_() {
  const ss =
    SpreadsheetApp
      .getActiveSpreadsheet();

  const required = [
    "IN/OUT",
    "Performance Report",
    "Insert",
    "Cast List",
    "Expanded Calendar",
    "PD/Vacation Tracker"
  ];

  return required.map(function (name) {
    return {
      name:
        name,

      available:
        Boolean(
          ss.getSheetByName(
            name
          )
        )
    };
  });
}
