 * TEST
 * ========================================================= */

function testPerformanceAssignmentOS() {
  const startedAt =
    Date.now();

  const current =
    PerformanceAssignmentOS()
      .current();

  const status =
    performanceAssignmentOSStatus_(
      current
    );

  const leaf =
    current.onstageCast.people
      .find(function (row) {
        return row.role === "Leaf";
      });

  const barfee =
    current.onstageCast.people
      .find(function (row) {
        return row.role === "Barfée";
      });

  const ceciliaOutRecord =
  current.outs.find(
    function (out) {
      return (
        performanceAssignmentOSNameKey_(
          out.person
        ) ===
          performanceAssignmentOSNameKey_(
            "Cecilia Snow"
          ) &&
        performanceAssignmentOSNameKey_(
          out.role
        ) ===
          performanceAssignmentOSNameKey_(
            "Swing"
          )
      );
    }
  );

const ceciliaCompanyRecord =
  current.resolvedCompany.people.find(
    function (row) {
      return (
        performanceAssignmentOSNameKey_(
          row.person
        ) ===
          performanceAssignmentOSNameKey_(
            "Cecilia Snow"
          ) &&
        performanceAssignmentOSNameKey_(
          row.role
        ) ===
          performanceAssignmentOSNameKey_(
            "Swing"
          )
      );
    }
  );

const incorrectSwingOuts =
  current.resolvedCompany.people.filter(
    function (row) {
      if (
        performanceAssignmentOSNameKey_(
          row.role
        ) !==
          performanceAssignmentOSNameKey_(
            "Swing"
          )
      ) {
        return false;
      }

      if (
        String(
          row.status || ""
        ).toUpperCase() !==
          "OUT"
      ) {
        return false;
      }

      /*
       * Cecilia may be OUT only when she appears
       * in the current performance's OUT records.
       */
      return (
        !ceciliaOutRecord ||
        performanceAssignmentOSNameKey_(
          row.person
        ) !==
          performanceAssignmentOSNameKey_(
            "Cecilia Snow"
          )
      );
    }
  );

const swingOutValidation =
  ceciliaOutRecord
    ? Boolean(
        ceciliaCompanyRecord &&
        String(
          ceciliaCompanyRecord.status || ""
        ).toUpperCase() ===
          "OUT" &&
        incorrectSwingOuts.length === 0
      )
    : incorrectSwingOuts.length === 0;

  const selfCoverIssues =
    current.resolvedCompany.people
      .filter(function (row) {
        const personKey =
          performanceAssignmentOSNameKey_(
            row.person
          );

        return (
          personKey &&
          personKey ===
            performanceAssignmentOSNameKey_(
              row.outPerson
            ) &&
          personKey ===
            performanceAssignmentOSNameKey_(
              row.inPerson
            )
        );
      });

  const validation = {
    leaf:
      Boolean(
        leaf &&
        leaf.person ===
          "Fernell Hogan" &&
        leaf.status ===
          "COVERED"
      ),

    barfee:
      Boolean(
        barfee &&
        barfee.person ===
          "Brandon L. Armstrong" &&
        barfee.status ===
          "COVERED"
      ),

    swingOuts:
      swingOutValidation,

    selfCovers:
      selfCoverIssues.length === 0
  };

  validation.allPassed =
    Object.keys(validation)
      .filter(function (key) {
        return key !== "allPassed";
      })
      .every(function (key) {
        return validation[key] === true;
      });

  const totalDurationMs =
    Date.now() -
    startedAt;

  Logger.log(
    "PERFORMANCEASSIGNMENTOS V0.3 TEST"
  );

  Logger.log(
    JSON.stringify(
      {
        model: current,
        validation: validation
      },
      null,
      2
    )
  );

  SpreadsheetApp
    .getUi()
    .alert(
      [
        "PerformanceAssignmentOS v0.3 test " +
          (
            status.healthy &&
            validation.allPassed
              ? "passed."
              : "found issues."
          ),
        "",
        "Date: " +
          status.date,
        "Performance: " +
          status.performance,
        "Part: " +
          status.performancePart,
        "Staffing tracks: " +
          status.staffingTracks,
        "OUT records: " +
          status.outs,
        "Coverage records: " +
          status.coverage,
        "Unresolved coverage: " +
          status.unresolvedCoverage,
        "Resolved company records: " +
          status.resolvedCompany,
        "Onstage cast roles: " +
          status.onstageCast,
        "Resolved cast source: " +
          status.resolvedCastSource,
        "",
        "Leaf → Fernell: " +
          (
            validation.leaf
              ? "YES"
              : "NO"
          ),
        "Barfée → Brandon: " +
          (
            validation.barfee
              ? "YES"
              : "NO"
          ),
        "Swing OUT reconciliation: " +
          (
            validation.swingOuts
              ? "YES"
              : "NO"
          ),
        "Self-cover artifacts removed: " +
          (
            validation.selfCovers
              ? "YES"
              : "NO"
          ),
        "",
        "Model duration: " +
          status.durationMs +
          " ms",
        "Total test duration: " +
          totalDurationMs +
          " ms",
        "",
        "Open the execution log for the full model."
      ].join("\n")
    );

  return {
    model: current,
    validation: validation
  };
}
