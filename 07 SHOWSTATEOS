function getWeeklyCastOuts_(values, dayStart, dayEnd) {
  const cache = CastListCacheOS().get();

  const actors = cache.actors || [];
  const principalByRole = cache.principalByRole || {};
  const rolesByKey = cache.rolesByKey || {};

  const outs = [];

  for (let r = dayStart; r < dayEnd; r++) {
    const rowText = values[r].join("\n").replace(/\t/g, " ").trim();
    if (!rowText.toUpperCase().includes("OUT")) continue;

    rowText.split(/\n+/).forEach(line => {
      const match = line.trim().match(/(.+?)\s+OUT\s*,\s*(.+?)\s*=\s*(.+)/i);
      if (!match) return;

      const role = matchRoleFromCastList_(clean_(match[2]), rolesByKey);

      outs.push({
        out: principalByRole[cleanKey_(role)] || matchActorNameFromCastList_(match[1], actors),
        in: matchActorNameFromCastList_(match[3], actors),
        role: role,
        reason: ""
      });
    });
  }

  return dedupeCastOutRows_(outs);
}

