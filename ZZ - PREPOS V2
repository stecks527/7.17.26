 * Canonical public API for performance preparation.
 *************************************************/

function PrepOS() {
  return {
    /*************************************************
     * UI
     *************************************************/

    open: function () {
      return prepOSOpenDialog_();
    },

    /*************************************************
     * STATE
     *************************************************/

        current: function () {
      return prepOSGetState_();
    },

    get: function () {
      return prepOSGetState_();
    },

    /*
     * Legacy compatibility alias.
     * Older Prep dialog endpoints still call PrepOS().state().
     */
    state: function () {
      return prepOSGetState_();
    },

    refresh: function () {
      prepOSClearStateCache_();

      if (
        typeof clearShowStateOSCache ===
        "function"
      ) {
        clearShowStateOSCache();
      }

      return prepOSGetState_();
    },

    /*************************************************
     * APPLY
     *************************************************/

    apply: function (payload) {
      return prepOSApplyPayload_(
        payload || {}
      );
    },

    /*************************************************
     * CACHE
     *************************************************/

    clearCache: function () {
      return prepOSClearStateCache_();
    },

    clearAllCaches: function () {
      if (
        typeof clearPrepOSCaches ===
        "function"
      ) {
        return clearPrepOSCaches();
      }

      return prepOSClearStateCache_();
    },

    /*************************************************
     * HEALTH
     *************************************************/

    status: function () {
      return prepOSStatus_();
    },

    test: function () {
      return testPrepOSPlatformAPI();
    }
  };
}

