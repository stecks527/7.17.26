/*************************************************
 * FULL COMPANY
 *************************************************/

function getResolvedCompany() {
  return CastResolverOS().resolveCurrentPerformance().company;
}

function getResolvedPerformanceCastObject() {
  return CastResolverOS().resolveCurrentPerformance();
}

/*************************************************
 * ROLE LOOKUPS
 *************************************************/

function getResolvedActorForRole(roleName) {
  const company = getResolvedCompany();
  const target = castResolverOSNormalize_(roleName);

  const match = company.find(row =>
    castResolverOSNormalize_(row.role) === target
  );

  return match ? match.resolvedActor : "";
}

function getResolvedCompanyByRole() {
  const company = getResolvedCompany();
  const output = {};

  company.forEach(row => {
    output[row.role] = row.resolvedActor;
  });

  return output;
}

/*************************************************
 * ACTOR / COVERAGE LOOKUPS
 *************************************************/

function getResolvedRolesForActor(actorName) {
  const company = getResolvedCompany();
  const target = castResolverOSNormalize_(actorName);

  return company
    .filter(row =>
      castResolverOSNormalize_(row.resolvedActor) === target
    )
    .map(row => row.role);
}

function getResolvedCoveredRoles() {
  return getResolvedCompany().filter(row => row.status === "COVERED");
}

function getResolvedDefaultRoles() {
  return getResolvedCompany().filter(row => row.status === "DEFAULT");
}

function getResolvedUncoveredRoles() {
  return getResolvedCompany().filter(row => row.status === "OUT_UNCOVERED");
}

/*************************************************
 * SNAPSHOT-FRIENDLY OUTPUT
 *************************************************/

function getResolvedCastSnapshotPayload() {
  const resolved = CastResolverOS().resolveCurrentPerformance();

  return {
    system: "CastResolverOS",
    version: "0.1.0",
    capturedAt: new Date(),
    performanceDate: resolved.performanceDate,
    performanceLabel: resolved.performanceLabel,
    company: resolved.company.map(row => ({
      role: row.role,
      actor: row.resolvedActor,
      defaultActor: row.defaultActor,
      status: row.status,
      outActor: row.outActor,
      inActor: row.inActor,
      reason: row.reason
    }))
  };
}

/*************************************************
 * API TESTERS
 *************************************************/

function testCastResolverOS_API() {
  const payload = getResolvedCastSnapshotPayload();

  Logger.log(JSON.stringify(payload, null, 2));

  SpreadsheetApp.getUi().alert(
    "CastResolverOS API test complete.\n\nResolved roles: " +
    payload.company.length +
    "\nCheck Logs."
