/* =========================================================
 * SPEED TEST
 * ========================================================= */

function testPrepIntelligenceSpeed() {
  clearPrepIntelligenceAndShowStateCaches();

  const inOut =
    prepOSSheet_(
      "IN/OUT"
    );

  if (!inOut) {
    throw new Error(
      'Could not find "IN/OUT".'
    );
  }

  const dateText =
    inOut
      .getRange("A3")
      .getDisplayValue();

  const state = {
    date:
      dateText
  };

  const coldStartedAt =
    Date.now();

  const cold =
    addPrepIntelligenceToShowState_(
      Object.assign({}, state)
    );

  const coldMs =
    Date.now() -
    coldStartedAt;

  const warmStartedAt =
    Date.now();

  const warm =
    addPrepIntelligenceToShowState_(
      Object.assign({}, state)
    );

  const warmMs =
    Date.now() -
    warmStartedAt;

  const result = {
    coldMs:
      coldMs,

    warmMs:
      warmMs,

    plannedOuts:
      cold.intelligence
        .plannedOuts.length,

    actorOptions:
      cold.intelligence
        .actorOptions.length,

    warmAvailable:
      Boolean(
        warm.intelligence
      )
  };

  Logger.log(
    "PREP INTELLIGENCE SPEED TEST"
  );

  Logger.log(
    JSON.stringify(
      result,
      null,
      2
    )
  );

  SpreadsheetApp
    .getUi()
    .alert(
      "Prep intelligence speed test complete.\n\n" +
      "Cold build: " +
      result.coldMs +
      " ms\n" +
      "Warm build: " +
      result.warmMs +
      " ms\n\n" +
      "Planned outs: " +
      result.plannedOuts +
      "\n" +
      "Actor options: " +
      result.actorOptions
    );

  return result;
}

function diagnosePrepPlannedOutsToday() {
  const ss =
    SpreadsheetApp.getActiveSpreadsheet();

  const inOut =
    ss.getSheetByName("IN/OUT");

  if (!inOut) {
    throw new Error(
      'Could not find "IN/OUT".'
    );
  }

  const dateText =
    inOut
      .getRange("A3")
      .getDisplayValue();

  const targetDate =
    prepOSParseDate_(
      dateText
    );

  if (!targetDate) {
    throw new Error(
      "Could not parse IN/OUT!A3: " +
      dateText
    );
  }

  clearPrepIntelligenceAndShowStateCaches();

  let rawPlannedOuts = [];

  if (
    typeof InOutIntelligenceOS ===
    "function"
  ) {
    rawPlannedOuts =
      InOutIntelligenceOS()
        .plannedOutsForDate(
          targetDate
        ) || [];
  }

  const state =
    buildShowState();

  const normalizedPlannedOuts =
    state &&
    state.intelligence &&
    Array.isArray(
      state.intelligence.plannedOuts
    )
      ? state.intelligence.plannedOuts
      : [];

  const result = {
    dateText:
      dateText,

    targetDate:
      Utilities.formatDate(
        targetDate,
        Session.getScriptTimeZone(),
        "yyyy-MM-dd"
      ),

    rawCount:
      rawPlannedOuts.length,

    rawPlannedOuts:
      rawPlannedOuts,

    normalizedCount:
      normalizedPlannedOuts.length,

    normalizedPlannedOuts:
      normalizedPlannedOuts,

    showStateAvailable:
      Boolean(state),

    intelligenceAvailable:
      Boolean(
        state &&
        state.intelligence
      )
  };

  Logger.log(
    "PREP PLANNED OUTS DIAGNOSTIC"
  );

  Logger.log(
    JSON.stringify(
      result,
      null,
      2
    )
  );

  SpreadsheetApp
    .getUi()
    .alert(
      [
        "Prep planned-outs diagnostic complete.",
        "",
        "Date: " +
          result.dateText,
        "Raw planned outs: " +
          result.rawCount,
        "Normalized planned outs: " +
          result.normalizedCount,
        "",
        "Open the execution log for details."
      ].join("\n")
    );

  return result;
}
