/*************************************************
 * STATUS
 *************************************************/

function developerOSFunctionIndexStatus() {
  const sheet = developerOSGetOrCreateFunctionIndexSheet_();
  const count = Math.max(0, sheet.getLastRow() - 1);

  const result = {
    system: "DeveloperOS",
    version: "1.0.0",
    indexSheet: DEVELOPEROS_FUNCTION_INDEX_SHEET,
    indexedFunctions: count,
    automaticSourceScanning: false,
    healthy: true
  };

  Logger.log("DEVELOPEROS FUNCTION INDEX STATUS");
  Logger.log(JSON.stringify(result, null, 2));

  SpreadsheetApp.getUi().alert(
    "DeveloperOS Function Index\n\n" +
    "Indexed functions: " + count +
    "\nAutomatic source scanning: No" +
    "\nRegistry-backed search: Ready"
  );

  return result;
}

/*************************************************
 * HELPERS
 *************************************************/

function developerOSFunctionKey_(functionName, fileName) {
  return (
    developerOSNormalizeSearch_(functionName) +
    "::" +
    developerOSNormalizeSearch_(fileName)
  );
}

function developerOSNormalizeSearch_(value) {
  return String(value || "")
    .toLowerCase()
    .replace(/[^a-z0-9_]+/g, " ")
    .replace(/\s+/g, " ")
    .trim();
}
