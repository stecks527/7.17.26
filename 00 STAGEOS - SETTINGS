/* =========================================================
 * SETTINGS CACHE OS COMPATIBILITY
 * ========================================================= */

function SettingsCacheOS() {
  return {
    get: function (label) {
      return StageOSSettings().get(
        label,
        ""
      );
    },

    getAll: function () {
      const status =
        stageOSSettingsReadRawCache_();

      return {
        cachedAt:
          status.cachedAt || "",

        values:
          status.values || {},

        stageKeys:
          status.stageKeys || {}
      };
    },

    refresh: function () {
      StageOSSettings().refresh();

      return stageOSSettingsReadRawCache_();
    },

    clear: function () {
      return StageOSSettings().clear();
    }
  };
}

function stageOSSettingsReadRawCache_() {
  /*
   * Ensure a cache exists before reading it.
   */
  stageOSSettingsLoad_();

  const raw =
    PropertiesService
      .getDocumentProperties()
      .getProperty(
        STAGEOS_SETTINGS_CACHE_KEY
      );

  if (!raw) {
    return {
      cachedAt: "",
      values: {},
      stageKeys: {}
    };
  }

  try {
    return JSON.parse(raw);
  } catch (err) {
    return {
      cachedAt: "",
      values: {},
      stageKeys: {}
    };
  }
}

function refreshSettingsCacheOS() {
  const cache =
    SettingsCacheOS().refresh();

  SpreadsheetApp.getUi().alert(
    "StageOS settings refreshed.\n\n" +
    "Settings cached: " +
    Object.keys(
      cache.stageKeys || {}
    ).length
  );

  return cache;
}


