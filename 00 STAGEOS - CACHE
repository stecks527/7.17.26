/* =========================================================
 * REGISTRY ACCESS
 * ========================================================= */

function stageCacheOSGetRegistryItem_(
  cacheId
) {
  const target =
    String(cacheId || "")
      .trim()
      .toLowerCase();

  return (
    STAGEOS_CACHE_REGISTRY.find(
      function (item) {
        return (
          String(item.id || "")
            .toLowerCase() ===
          target
        );
      }
    ) || null
  );
}


/* =========================================================
 * STATUS
 * ========================================================= */

function stageCacheOSStatus_() {
  const output = [];

  STAGEOS_CACHE_REGISTRY.forEach(
    function (item) {
      const itemStatus =
        stageCacheOSBuildItemStatus_(
          item
        );

      itemStatus.entries.forEach(
        function (entry) {
          output.push(entry);
        }
      );
    }
  );

  return output;
}


function stageCacheOSStatusFor_(
  cacheId
) {
  const item =
    stageCacheOSGetRegistryItem_(
      cacheId
    );

  if (!item) {
    return null;
  }

  return stageCacheOSBuildItemStatus_(
    item
  );
}


function stageCacheOSBuildItemStatus_(
  item
) {
  const props =
    PropertiesService
      .getDocumentProperties();

  const allProperties =
    props.getProperties();

  const keys =
    stageCacheOSResolvePropertyKeys_(
      item,
      allProperties
    );

  const entries =
    keys.map(function (key) {
      const raw =
        allProperties[key] || "";

      const metadata =
        stageCacheOSReadMetadata_(
          raw
        );

      return {
        id:
          item.id,

        label:
          item.label,

        key:
          key,

        exists:
          Boolean(raw),

        cachedAt:
          metadata.cachedAt || "",

        entryCount:
          metadata.entryCount,

        size:
          raw.length
      };
    });

  return {
    id:
      item.id,

    label:
      item.label,

    available:
      stageCacheOSIsServiceAvailable_(
        item
      ),

    entries:
      entries
  };
}


function stageCacheOSResolvePropertyKeys_(
  item,
  allProperties
) {
  const output =
    (item.propertyKeys || [])
      .slice();

  (
    item.propertyPrefixes ||
    []
  ).forEach(
    function (prefix) {
      Object.keys(
        allProperties
      )
        .filter(
          function (key) {
            return (
              key.indexOf(
                prefix
              ) === 0
            );
          }
        )
        .forEach(
          function (key) {
            if (
              output.indexOf(
                key
              ) === -1
            ) {
              output.push(
                key
              );
            }
          }
        );
    }
  );

  return output;
}


function stageCacheOSReadMetadata_(
  raw
) {
  if (!raw) {
    return {
      cachedAt:
        "",

      entryCount:
        0
    };
  }

  const parsed =
    stageOSParseJson_(
      raw,
      {}
    ) || {};

  const directTimestamp =
    parsed.cachedAt ||
    parsed.savedAt ||
    parsed.createdAt ||
    "";

  if (directTimestamp) {
    return {
      cachedAt:
        directTimestamp,

      entryCount:
        stageCacheOSCountEntries_(
          parsed
        )
    };
  }

  /*
   * Date-keyed maps such as WeeklyCacheOS store
   * timestamps inside each date entry.
   */
  const keys =
    Object.keys(
      parsed
    );

  let latestCachedAt =
    "";

  keys.forEach(
    function (key) {
      const entry =
        parsed[key];

      const candidate =
        entry &&
        typeof entry ===
          "object"
          ? (
              entry.cachedAt ||
              entry.savedAt ||
              ""
            )
          : "";

      if (
        candidate &&
        (
          !latestCachedAt ||
          String(candidate) >
            String(latestCachedAt)
        )
      ) {
        latestCachedAt =
          candidate;
      }
    }
  );

  return {
    cachedAt:
      latestCachedAt,

    entryCount:
      keys.length
  };
}

function stageCacheOSCountEntries_(
  parsed
) {
  if (
    !parsed ||
    typeof parsed !== "object"
  ) {
    return 0;
  }

  if (
    Array.isArray(parsed)
  ) {
    return parsed.length;
  }

  const preferredCollections = [
    parsed.values,
    parsed.stageKeys,
    parsed.actors,
    parsed.roles,
    parsed.people,
    parsed.peopleByTrack
  ];

  for (
    let i = 0;
    i < preferredCollections.length;
    i++
  ) {
    const collection =
      preferredCollections[i];

    if (
      Array.isArray(collection)
    ) {
      return collection.length;
    }

    if (
      collection &&
      typeof collection === "object"
    ) {
      return Object.keys(
        collection
      ).length;
    }
  }

  return Object.keys(parsed).length;
}

function stageCacheOSIsServiceAvailable_(
  item
) {
  if (!item) return false;

  if (
    typeof item.refresh ===
      "function" ||
    typeof item.clear ===
      "function"
  ) {
    return true;
  }

  return false;
}


/* =========================================================
 * CLEAR
 * ========================================================= */

function stageCacheOSClear_(
  cacheId
) {
  const item =
    stageCacheOSGetRegistryItem_(
      cacheId
    );

  if (!item) {
    throw new Error(
      'Unknown StageOS cache "' +
      cacheId +
      '".'
    );
  }

  const result = {
    id: item.id,
    label: item.label,
    cleared: false,
    keys: []
  };

  if (
    typeof item.clear ===
    "function"
  ) {
    item.clear();
    result.cleared = true;
  } else {
    const props =
      PropertiesService
        .getDocumentProperties();

    (item.propertyKeys || [])
      .forEach(function (key) {
        props.deleteProperty(key);
      });

    result.cleared = true;
  }

  result.keys =
    (item.propertyKeys || [])
      .slice();

  stageCacheOSClearMemoryCaches_(
    item.id
  );

  return result;
}

function stageCacheOSClearAll_() {
  const results = [];

  STAGEOS_CACHE_REGISTRY.forEach(
    function (item) {
      try {
        results.push(
          stageCacheOSClear_(
            item.id
          )
        );
      } catch (err) {
        results.push({
          id: item.id,
          label: item.label,
          cleared: false,
          error:
            String(
              err &&
              err.message
                ? err.message
                : err
            )
        });
      }
    }
  );

  stageCacheOSClearAllMemoryCaches_();

  return {
    ok:
      results.every(
        function (item) {
          return item.cleared;
        }
      ),

    results: results
  };
}

function stageCacheOSClearMemoryCaches_(
  cacheId
) {
  switch (cacheId) {
    case "settings":
      if (
        typeof STAGEOS_SETTINGS_MEMORY_CACHE_ !==
        "undefined"
      ) {
        STAGEOS_SETTINGS_MEMORY_CACHE_ =
          null;
      }

      break;

    case "weekly":
      /*
       * Weekly cache currently uses DocumentProperties
       * only. No module memory cache to clear.
       */
      break;

    case "castList":
      break;

    case "assignments":
      break;

    case "guestSpeller":
      break;
  }
}

function stageCacheOSClearAllMemoryCaches_() {
  if (
    typeof STAGEOS_SETTINGS_MEMORY_CACHE_ !==
    "undefined"
  ) {
    STAGEOS_SETTINGS_MEMORY_CACHE_ =
      null;
  }

  if (
    typeof HOME_CURRENT_CONTEXT_ !==
    "undefined"
  ) {
    HOME_CURRENT_CONTEXT_ =
      null;
  }

  if (
    typeof HOME_TASK_CONTEXT_CACHE_ !==
    "undefined"
  ) {
    HOME_TASK_CONTEXT_CACHE_ =
      null;
  }

  if (
    typeof HOME_WORKFLOW_STATUS_CACHE_ !==
    "undefined"
  ) {
    HOME_WORKFLOW_STATUS_CACHE_ =
      null;
  }

  if (
    typeof clearHomeContext_ ===
    "function"
  ) {
    clearHomeContext_();
  }
}


/* =========================================================
 * REFRESH
 * ========================================================= */

function stageCacheOSRefresh_(
  cacheId
) {
  const item =
    stageCacheOSGetRegistryItem_(
      cacheId
    );

  if (!item) {
    throw new Error(
      'Unknown StageOS cache "' +
      cacheId +
      '".'
    );
  }

  if (
    typeof item.refresh !==
    "function"
  ) {
    return {
      id: item.id,
      label: item.label,
      refreshed: false,
      reason:
        "This cache rebuilds on demand."
    };
  }

  stageCacheOSClearMemoryCaches_(
    item.id
  );

  const data =
    item.refresh();

  return {
    id: item.id,
    label: item.label,
    refreshed: true,
    data: data
  };
}

function stageCacheOSRefreshCore_() {
  const coreIds = [
    "settings",
    "castList",
    "assignments"
  ];

  const results =
    coreIds.map(function (id) {
      try {
        return stageCacheOSRefresh_(id);
      } catch (err) {
        return {
          id: id,
          refreshed: false,
          error:
            String(
              err &&
              err.message
                ? err.message
                : err
            )
        };
      }
    });

  stageCacheOSClearAllMemoryCaches_();

  return results;
}


/* =========================================================
 * UI
 * ========================================================= */

function showStageCacheOSStatus() {
  const status =
    StageCacheOS().status();

  const lines =
    status.map(function (item) {
      return [
        item.exists
          ? "✅"
          : "⚪️",

        item.label +
          " — " +
          item.key,

        item.cachedAt
          ? "Cached: " +
            item.cachedAt
          : "No cache timestamp",

        "Entries: " +
          item.entryCount,

        "Size: " +
          item.size
      ].join("\n");
    });

  SpreadsheetApp
    .getUi()
    .alert(
      "StageCacheOS Status\n\n" +
      lines.join("\n\n")
    );

  return status;
}

function clearStageCacheOS() {
  const result =
    StageCacheOS().clearAll();

  const cleared =
    result.results.filter(
      function (item) {
        return item.cleared;
      }
    ).length;

  SpreadsheetApp
    .getUi()
    .alert(
      "StageCacheOS cleared.\n\n" +
      "Caches cleared: " +
      cleared +
      "\n\n" +
      "Caches will rebuild as needed."
    );

  return result;
}

function refreshStageCacheOSCore() {
  const results =
    StageCacheOS().refreshCore();

  const refreshed =
    results.filter(
      function (item) {
        return item.refreshed;
      }
    );

  const failed =
    results.filter(
      function (item) {
        return !item.refreshed;
      }
    );

  SpreadsheetApp
    .getUi()
    .alert(
      "StageCacheOS core refreshed.\n\n" +
      "Refreshed:\n" +
      (
        refreshed.length
          ? refreshed
              .map(function (item) {
                return "✅ " +
                  item.label;
              })
              .join("\n")
          : "None"
      ) +
      (
        failed.length
          ? "\n\nNot refreshed:\n" +
            failed
              .map(function (item) {
                return "⚪️ " +
                  (
                    item.label ||
                    item.id
                  ) +
                  (
                    item.error
                      ? " — " +
                        item.error
                      : ""
                  );
              })
              .join("\n")
          : ""
      )
    );

  return results;
}


