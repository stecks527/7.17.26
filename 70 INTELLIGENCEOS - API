/*************************************************
 * SHARED INTELLIGENCE HELPERS
 *************************************************/

function getPrincipalCastOutsForIntelligence_(showState) {
  const outs = showState.currentCastOuts || [];

  return outs.filter(out => {
    const role = String(out.role || "").toLowerCase();
    const outName = String(out.out || "").trim();

    if (!outName) return false;

    return !(
      role.includes("swing") ||
      role.includes("understudy") ||
      role.includes("u/s") ||
      role.includes("standby")
    );
  });
}

function getCurrentPerformanceForIntelligence_(showState, timeline) {
  const performances = showState.performances || [];
  if (!performances.length) return null;

  const currentEvent = timeline && timeline.currentEvent
    ? timeline.currentEvent
    : null;

  const currentNumber = currentEvent && currentEvent.performanceNumber
    ? currentEvent.performanceNumber
    : "";

  if (currentNumber) {
    const found = performances.find(perf =>
      String(perf.number || "") === String(currentNumber)
    );

    if (found) return found;
  }

  return performances[showState.selectedIndex || 0] || performances[0] || null;
}

function getNextPerformanceForIntelligence_(showState, currentPerf) {
  const performances = showState.performances || [];
  if (!currentPerf || performances.length < 2) return null;

  const index = performances.findIndex(perf =>
    String(perf.number || "") === String(currentPerf.number || "")
  );

  if (index === -1) return null;

  return performances[index + 1] || null;
}

function buildWorkflowFocusIntelligence_(showState) {
  if (typeof getRecurringWorkflowsForToday_ !== "function") return [];

  return getRecurringWorkflowsForToday_(showState).map(workflow => ({
    title: workflow.workflow
  }));
}

function dedupeIntelligenceTasks_(tasks) {
  const seen = {};
  const output = [];

  tasks.forEach(task => {
    const title = String(task.title || "").trim();
    if (!title) return;

    const key = title.toLowerCase();
    if (seen[key]) return;

    seen[key] = true;
    output.push({ title });
  });

  return output;
}
