 * ========================================================= */

function performanceAssignmentOSStatus_(
  current
) {
  const startedAt =
    Date.now();

  let error = "";

  if (!current) {
    try {
      current =
        performanceAssignmentOSCurrent_();

    } catch (err) {
      error =
        String(
          err && err.message
            ? err.message
            : err
        );
    }
  }

  return {
    system:
      "PerformanceAssignmentOS",

    version:
      "0.3.0",

    available:
      Boolean(current),

    healthy:
      Boolean(
        current &&
        current.date &&
        current.performance &&
        current.counts
          .onstageCast === 9 &&
        current.counts
          .unresolvedCoverage === 0
      ),

    error:
      error,

    date:
      current
        ? current.prettyDate
        : "",

    performance:
      current
        ? current.performance
        : "",

    performancePart:
      current
        ? current.performancePart
        : "",

    outs:
      current
        ? current.counts.outs
        : 0,

    coverage:
      current
        ? current.counts.coverage
        : 0,

    unresolvedCoverage:
      current
        ? current.counts
            .unresolvedCoverage
        : 0,

    resolvedCompany:
      current
        ? current.counts
            .resolvedCompany
        : 0,

    resolvedCast:
      current
        ? current.counts
            .resolvedCast
        : 0,

    onstageCast:
      current
        ? current.counts
            .onstageCast
        : 0,

    resolvedCastSource:
      current &&
      current.resolvedCast
        ? current.resolvedCast.source
        : "",

    staffingTracks:
      current
        ? current.counts
            .staffingTracks
        : 0,

    durationMs:
      current
        ? current.durationMs
        : Date.now() - startedAt
  };
}


/* =========================================================
 * HELPERS
 * ========================================================= */

function performanceAssignmentOSPerformancePart_(
  performanceText,
  performance
) {
  const explicitPart =
    String(
      performance &&
      (
        performance.part ||
        performance.showType
      ) ||
      ""
    ).trim();

  if (
    /^mat/i.test(
      explicitPart
    )
  ) {
    return "Mat";
  }

  if (
    /^eve/i.test(
      explicitPart
    )
  ) {
    return "Eve";
  }

  const text =
    String(
      performanceText || ""
    );

  if (
    /\bMAT(?:INEE)?\b/i.test(
      text
    )
  ) {
    return "Mat";
  }

  if (
    /\bEVE(?:NING)?\b/i.test(
      text
    )
  ) {
    return "Eve";
  }

  const match =
    text.match(
      /(\d{1,2}):(\d{2})\s*(AM|PM)/i
    );

  if (!match) {
    return "Unknown";
  }

  let hour =
    Number(match[1]);

  const ampm =
    match[3].toUpperCase();

  if (
    ampm === "PM" &&
    hour !== 12
  ) {
    hour += 12;
  }

  if (
    ampm === "AM" &&
    hour === 12
  ) {
    hour = 0;
  }

  return hour < 17
    ? "Mat"
    : "Eve";
}


function performanceAssignmentOSPartMatches_(
  recordPart,
  performancePart
) {
  const record =
    String(
      recordPart || "Unknown"
    );

  const target =
    String(
      performancePart || "Unknown"
    );

  return (
    record === target ||
    record === "Unknown" ||
    target === "Unknown"
  );
}


function performanceAssignmentOSDateKey_(
  value
) {
  let date =
    value;

  if (
    value &&
    typeof value === "string" &&
    /^\d{4}-\d{2}-\d{2}$/.test(
      value
    )
  ) {
    return value;
  }

  if (!(date instanceof Date)) {
    if (
      typeof prepOSParseDate_ ===
      "function"
    ) {
      date =
        prepOSParseDate_(
          value
        );
    } else {
      date =
        new Date(
          String(value || "")
        );
    }
  }

  if (
    !(date instanceof Date) ||
    isNaN(
      date.getTime()
    )
  ) {
    return "";
  }

  return Utilities.formatDate(
    date,
    Session.getScriptTimeZone(),
    "yyyy-MM-dd"
  );
}


function performanceAssignmentOSPerformanceMatches_(
  performance,
  requested
) {
  return (
    performanceAssignmentOSNameKey_(
      performance
    ) ===
    performanceAssignmentOSNameKey_(
      requested
    )
  );
}


function performanceAssignmentOSNameKey_(
  value
) {
  return String(
    value || ""
  )
    .toLowerCase()
    .normalize("NFD")
    .replace(
      /[\u0300-\u036f]/g,
      ""
    )
    .replace(/\./g, "")
    .replace(/\s+/g, " ")
    .trim();
}


function performanceAssignmentOSUniqueRecords_(
  records,
  keyBuilder
) {
  const seen = {};

  return records.filter(
    function (record) {
      const key =
        keyBuilder(record);

      if (seen[key]) {
        return false;
      }

      seen[key] = true;
      return true;
    }
  );
}


function performanceAssignmentOSClone_(
  value
) {
  return JSON.parse(
    JSON.stringify(
      value || []
    )
  );
}


