      {
        key: "guestPacket",
        icon: "⭐",
        title:
          "Create Guest Packet",
        runner:
          "homeButtonGuestSpellerPacket"
      }
    );
  }

  return tasks;
}

function getStageOSTasks_(
  dateText,
  guest
) {
  return getStageOSCurrentTasks_(
    dateText,
    guest
  );
}


