/* =========================================================
 * RISK REPORT
 * ========================================================= */

function dependencyOSWriteRiskReport_(ss, config, scan) {
  const sheet = dependencyOSGetOrCreateReportSheet_(
    ss,
    config.reportSheets.risks
  );

  sheet.clear();

  const headers = [
    "Severity",
    "Risk Type",
    "Location",
    "Usage Count",
    "Affected Sheets",
    "Explanation",
    "Recommended Action"
  ];

  const risks = [];

  Object.keys(scan.usageByTarget).forEach(function (targetKey) {
    const target = scan.usageByTarget[targetKey];
    const usageCount = target.usages.length;
    const affectedSheets =
      Object.keys(target.sourceSheets).sort();

    if (usageCount >= config.highUsageThreshold) {
      risks.push([
        "HIGH",
        "High-impact dependency",
        target.targetQualified,
        usageCount,
        affectedSheets.join(", "),
        "This cell or range is referenced by many formula relationships.",
        "Treat this location as critical. Inspect all dependents before moving, deleting, or changing its meaning."
      ]);
    } else if (usageCount >= config.mediumUsageThreshold) {
      risks.push([
        "MEDIUM",
        "Shared dependency",
        target.targetQualified,
        usageCount,
        affectedSheets.join(", "),
        "Several formula locations depend on this cell or range.",
        "Review dependents before restructuring this area."
      ]);
    }
  });

  scan.brokenFormulas.forEach(function (record) {
    risks.push([
      "HIGH",
      "Broken formula",
      dependencyOSQualifiedAddress_(
        record.sheet,
        record.cell
      ),
      1,
      record.sheet,
      record.formula + " currently displays " +
        record.displayValue,
      "Repair or intentionally retire this formula."
    ]);
  });

  scan.externalLinks.forEach(function (record) {
    risks.push([
      "MEDIUM",
      "External spreadsheet dependency",
      dependencyOSQualifiedAddress_(
        record.sourceSheet,
        record.sourceCell
      ),
      1,
      record.sourceSheet,
      "This formula imports data from another spreadsheet.",
      "Document the external workbook as an approved source of truth and confirm access permissions."
    ]);
  });

  Object.keys(scan.sheetStats).forEach(function (sheetName) {
    const stats = scan.sheetStats[sheetName];

    if (
      stats.incomingReferenceCount > 0 &&
      stats.outgoingReferenceCount > 0
    ) {
      risks.push([
        "MEDIUM",
        "Mixed source/output architecture",
        sheetName,
        stats.incomingReferenceCount +
          stats.outgoingReferenceCount,
        sheetName,
        "This sheet both reads from other sheets and supplies data to other sheets.",
        "Review whether manual inputs, engine calculations, and generated outputs can be separated."
      ]);
    }

    if (
      stats.formulaCells === 0 &&
      stats.incomingReferenceCount === 0 &&
      stats.outgoingReferenceCount === 0 &&
      stats.staticCells > 0
    ) {
      risks.push([
        "LOW",
        "No formula relationships detected",
        sheetName,
        0,
        sheetName,
        "DependencyOS found no formula connections for this populated sheet.",
        "Check whether this sheet is used only by Apps Script, is manually maintained, or may be retired."
      ]);
    }
  });

  risks.sort(function (a, b) {
    return (
      dependencyOSSeverityRank_(a[0]) -
      dependencyOSSeverityRank_(b[0])
    );
  });

  dependencyOSWriteTable_(
    sheet,
    headers,
    risks,
    config
  );

  sheet.setColumnWidth(1, 100);
  sheet.setColumnWidth(2, 240);
  sheet.setColumnWidth(3, 280);
  sheet.setColumnWidth(4, 110);
  sheet.setColumnWidth(5, 320);
  sheet.setColumnWidth(6, 560);
  sheet.setColumnWidth(7, 560);

  dependencyOSApplyRiskColors_(sheet, risks, config);
}


/* =========================================================
 * ACTIVE CELL INSPECTOR
 * ========================================================= */

function dependencyOSInspectActiveCell_() {
  const sourceSS = SpreadsheetApp.getActiveSpreadsheet();
  const engineSS = dependencyOSGetEngineWorkbook_();
  const config = dependencyOSConfig_();

  const activeSheet = sourceSS.getActiveSheet();
  const activeRange = sourceSS.getActiveRange();

  if (!activeSheet || !activeRange) {
    throw new Error("Select a cell or range before running the inspector.");
  }

  if (
    config.excludedSheets.indexOf(activeSheet.getName()) !== -1
  ) {
    throw new Error(
      "Select a cell on a StageOS working tab, not a DependencyOS report tab."
    );
  }

  const inspectedSheetName = activeSheet.getName();
  const inspectedRangeA1 = activeRange.getA1Notation();

  const scan = dependencyOSScanWorkbook_(sourceSS, config);

  const dependents = scan.references.filter(function (reference) {
    if (reference.targetSheet !== inspectedSheetName) {
      return false;
    }

    return dependencyOSRangesOverlap_(
      activeSheet,
      inspectedRangeA1,
      reference.targetRange
    );
  });

  const validations = scan.validations.filter(function (record) {
    if (record.sourceSheet !== inspectedSheetName) {
      return false;
    }

    return dependencyOSRangesOverlap_(
      activeSheet,
      inspectedRangeA1,
      record.sourceRange
    );
  });

  const namedRanges = scan.namedRanges.filter(function (record) {
    if (record.sheet !== inspectedSheetName) {
      return false;
    }

    return dependencyOSRangesOverlap_(
      activeSheet,
      inspectedRangeA1,
      record.range
    );
  });

  const inspectorSheet = dependencyOSGetOrCreateReportSheet_(
    engineSS,
    config.reportSheets.inspector
  );

  inspectorSheet.clear();

  const inspectedQualified =
    dependencyOSQualifiedAddress_(
      inspectedSheetName,
      inspectedRangeA1
    );

  const summary = [
    ["DependencyOS Cell Inspector", ""],
    ["Inspected Location", inspectedQualified],
    ["Current Display Value", activeRange.getDisplayValue()],
    ["Formula", activeRange.getFormula()],
    ["Formula Dependents", dependents.length],
    ["Validation Dependents", validations.length],
    ["Named Ranges Containing Selection", namedRanges.length],
    ["", ""],
    [
      "Safety Assessment",
      dependencyOSBuildCellSafetyAssessment_(
        dependents,
        validations,
        namedRanges
      )
    ]
  ];

  inspectorSheet
    .getRange(1, 1, summary.length, 2)
    .setValues(
      dependencyOSMakeReportRowsSafe_(summary)
    );

  inspectorSheet.getRange("A1:B1").merge();
  inspectorSheet
    .getRange("A1")
    .setValue("DependencyOS Cell Inspector");

  dependencyOSStyleTitle_(
    inspectorSheet.getRange("A1:B1"),
    config
  );

  let nextRow = summary.length + 2;

  nextRow = dependencyOSWriteInspectorSection_(
    inspectorSheet,
    nextRow,
    "Formula Cells Reading This Selection",
    [
      "Source Sheet",
      "Source Cell",
      "Source",
      "Target Reference",
      "Relationship",
      "Formula"
    ],
    dependents.map(function (reference) {
      return [
        reference.sourceSheet,
        reference.sourceCell,
        reference.sourceQualified,
        reference.targetQualified,
        reference.relationshipType,
        reference.formula
      ];
    }),
    config
  );

  nextRow++;

  nextRow = dependencyOSWriteInspectorSection_(
    inspectorSheet,
    nextRow,
    "Dropdowns / Validations Reading This Selection",
    [
      "Destination",
      "Validation Type",
      "Source",
      "Details"
    ],
    validations.map(function (record) {
      return [
        record.destinationQualified,
        record.criteriaType,
        record.sourceQualified,
        record.details
      ];
    }),
    config
  );

  nextRow++;

  dependencyOSWriteInspectorSection_(
    inspectorSheet,
    nextRow,
    "Named Ranges Containing This Selection",
    [
      "Named Range",
      "Qualified Range",
      "Formula Usage Count",
      "Used By"
    ],
    namedRanges.map(function (record) {
      return [
        record.name,
        record.qualifiedRange,
        record.formulaUsages.length,
        record.formulaUsages
          .map(function (usage) {
            return usage.sourceQualified;
          })
          .join(", ")
      ];
    }),
    config
  );

  inspectorSheet.setColumnWidth(1, 240);
  inspectorSheet.setColumnWidth(2, 260);
  inspectorSheet.setColumnWidth(3, 280);
  inspectorSheet.setColumnWidth(4, 300);
  inspectorSheet.setColumnWidth(5, 220);
  inspectorSheet.setColumnWidth(6, 560);

  inspectorSheet.getDataRange()
    .setVerticalAlignment("top")
    .setWrap(true);

  engineSS.setActiveSheet(inspectorSheet);
  inspectorSheet.setActiveSelection("A1");

  sourceSS.toast(
    "Inspection for " +
      inspectedQualified +
      " was written to the Engine workbook.",
    "DependencyOS",
    6
  );

  return {
    location: inspectedQualified,
    dependents: dependents,
    validations: validations,
    namedRanges: namedRanges
  };
}


function dependencyOSBuildCellSafetyAssessment_(
  dependents,
  validations,
  namedRanges
) {
  const total =
    dependents.length +
    validations.length +
    namedRanges.length;

  if (total === 0) {
    return (
      "No formula, validation, or named-range dependencies were detected. " +
      "Apps Script usage is not included yet, so do not treat this as confirmation that the location is completely unused."
    );
  }

  if (dependents.length >= 10 || total >= 15) {
    return (
      "HIGH IMPACT — Do not move or change this location until all listed dependencies have been reviewed."
    );
  }

  if (dependents.length >= 4 || total >= 6) {
    return (
      "MEDIUM IMPACT — Several workbook features depend on this location. Review the listed references before changing it."
    );
  }

  return (
    "LOW TO MODERATE IMPACT — A small number of workbook dependencies were detected. Review them before changing the location."
  );
}


