/*************************************************
 * 97 STAGEOS BUILDER
 * Version: 0.2.0
 *
 * Creates and manages the StageOS Builder workbook.
 *************************************************/

const STAGEOS_PROJECT_TRACKER = {
  propertyKey: "STAGEOS_PROJECT_TRACKER_ID",
  workbookName: "StageOS Builder",
  homeSheet: "Home",
  roadmapSheet: "Roadmap",
  parkingLotSheet: "Parking Lot",
  logSheet: "Build Journal",
  dependencySheet: "Dependencies",
  releaseSheet: "Release Plan",
  philosophySheet: "Philosophy",
  statsSheet: "Stats"
};

/*************************************************
 * CREATE / OPEN
 *************************************************/

function createStageOSProjectTracker() {
  const props = PropertiesService.getDocumentProperties();
  let trackerId = props.getProperty(STAGEOS_PROJECT_TRACKER.propertyKey);

  let tracker;

  if (trackerId) {
    tracker = SpreadsheetApp.openById(trackerId);
  } else {
    tracker = SpreadsheetApp.create(STAGEOS_PROJECT_TRACKER.workbookName);
    props.setProperty(STAGEOS_PROJECT_TRACKER.propertyKey, tracker.getId());
  }

  buildStageOSBuilder_(tracker);

  SpreadsheetApp.getUi().alert(
    "StageOS Builder ready.\n\n" +
    tracker.getUrl()
  );

  return tracker.getUrl();
}

function openStageOSProjectTracker() {
  const tracker = getStageOSProjectTracker_();
  SpreadsheetApp.getUi().alert("StageOS Builder:\n\n" + tracker.getUrl());
}

function getStageOSProjectTracker_() {
  const props = PropertiesService.getDocumentProperties();
  const trackerId = props.getProperty(STAGEOS_PROJECT_TRACKER.propertyKey);

  if (!trackerId) {
    throw new Error("No StageOS Builder found. Run createStageOSProjectTracker() first.");
  }

  return SpreadsheetApp.openById(trackerId);
}

/*************************************************
 * BUILD ALL SHEETS
 *************************************************/

function buildStageOSBuilder_(tracker) {
  buildBuilderRoadmap_(tracker);
  buildBuilderParkingLot_(tracker);
  buildBuilderJournal_(tracker);
  buildBuilderDependencies_(tracker);
  buildBuilderReleasePlan_(tracker);
  buildBuilderPhilosophy_(tracker);
  buildBuilderStats_(tracker);
  buildBuilderHome_(tracker);

  tracker.setActiveSheet(tracker.getSheetByName(STAGEOS_PROJECT_TRACKER.homeSheet));
}

/*************************************************
 * HOME
 *************************************************/

function buildBuilderHome_(tracker) {
  const sh = getOrCreateTrackerSheet_(tracker, STAGEOS_PROJECT_TRACKER.homeSheet);
  sh.clear();

  const roadmap = tracker.getSheetByName(STAGEOS_PROJECT_TRACKER.roadmapSheet);
  const data = roadmap.getDataRange().getDisplayValues();

  const rows = data.slice(1).filter(row => row[0]);
  const complete = rows.filter(row => row[4] === "Complete").length;
  const total = rows.length;
  const remaining = total - complete;
  const progress = total ? complete / total : 0;

  const next = rows.find(row =>
    row[4] !== "Complete" &&
    row[4] !== "Paused" &&
    row[5] === "High"
  ) || rows.find(row => row[4] !== "Complete") || [];

  sh.getRange("A1:H1").merge()
    .setValue("StageOS Builder")
    .setFontSize(28)
    .setFontWeight("bold")
    .setHorizontalAlignment("center")
    .setBackground("#2457c5")
    .setFontColor("#ffd84d");

  sh.getRange("A3").setValue("Development Dashboard").setFontSize(18).setFontWeight("bold");

  sh.getRange("A5").setValue("Overall Progress").setFontWeight("bold");
  sh.getRange("B5").setValue(Math.round(progress * 100) + "%");

  sh.getRange("A6").setValue("Completed Tasks").setFontWeight("bold");
  sh.getRange("B6").setValue(complete);

  sh.getRange("A7").setValue("Remaining Tasks").setFontWeight("bold");
  sh.getRange("B7").setValue(remaining);

  sh.getRange("A9").setValue("Recommended Next").setFontWeight("bold");
  sh.getRange("B9").setValue(next[3] || "No task found");

  sh.getRange("A10").setValue("Subsystem").setFontWeight("bold");
  sh.getRange("B10").setValue(next[2] || "");

  sh.getRange("A11").setValue("Estimate").setFontWeight("bold");
  sh.getRange("B11").setValue(next[6] || "");

  sh.getRange("A13").setValue("Current Sprint").setFontWeight("bold");
  const sprint = rows.filter(row => row[4] === "In Progress").slice(0, 8);
  if (sprint.length) {
    sh.getRange(14, 1, sprint.length, 3)
      .setValues(sprint.map(row => [row[0], row[2], row[3]]));
  } else {
    sh.getRange("A14").setValue("No tasks currently in progress.");
  }

  sh.getRange("E5").setValue("Quick Actions").setFontWeight("bold");
  sh.getRange("E6").setValue("Use menu in the main StageOS workbook:");
  sh.getRange("E7").setValue("Bee Tools → StageOS Project");
  sh.getRange("E9").setValue("Sheets").setFontWeight("bold");
  sh.getRange("E10:E16").setValues([
    ["Roadmap"],
    ["Parking Lot"],
    ["Build Journal"],
    ["Dependencies"],
    ["Release Plan"],
    ["Stats"],
    ["Philosophy"]
  ]);

  sh.setColumnWidths(1, 8, 170);
  sh.setRowHeights(1, 1, 48);
}

/*************************************************
 * ROADMAP
 *************************************************/

function buildBuilderRoadmap_(tracker) {
  const sh = getOrCreateTrackerSheet_(tracker, STAGEOS_PROJECT_TRACKER.roadmapSheet);

  const existing = sh.getDataRange().getDisplayValues();
  const hasExistingTasks = existing.length > 1 && existing[1][0];

  sh.clear();

  const headers = [
    "Task ID",
    "Phase",
    "Subsystem",
    "Task",
    "Status",
    "Priority",
    "Estimate",
    "Completed At",
    "Notes",
    "Pipeline",
    "Dependencies",
    "Version"
  ];

  sh.getRange(1, 1, 1, headers.length)
    .setValues([headers])
    .setFontWeight("bold")
    .setBackground("#cfe2f3");

  const rows = hasExistingTasks
    ? normalizeRoadmapRows_(existing.slice(1), headers.length)
    : getStageOSRoadmapSeedRows_();

  if (rows.length) {
    sh.getRange(2, 1, rows.length, headers.length).setValues(rows);
  }

  sh.setFrozenRows(1);
  sh.autoResizeColumns(1, headers.length);

  const statusRule = SpreadsheetApp.newDataValidation()
    .requireValueInList(["Backlog", "In Progress", "Testing", "Complete", "Paused"], true)
    .build();

  const priorityRule = SpreadsheetApp.newDataValidation()
    .requireValueInList(["Critical", "High", "Medium", "Low", "Dream"], true)
    .build();

  const pipelineRule = SpreadsheetApp.newDataValidation()
    .requireValueInList(["Dream", "Design", "Architecture", "Building", "Testing", "Released"], true)
    .build();

  sh.getRange(2, 5, 500, 1).setDataValidation(statusRule);
  sh.getRange(2, 6, 500, 1).setDataValidation(priorityRule);
  sh.getRange(2, 10, 500, 1).setDataValidation(pipelineRule);

  applyRoadmapFormatting_(sh);
  sortStageOSRoadmap_(sh);
}

function normalizeRoadmapRows_(rows, width) {
  return rows
    .filter(row => row[0])
    .map(row => {
      const next = row.slice(0, width);
      while (next.length < width) next.push("");

      if (!next[9]) next[9] = next[4] === "Complete" ? "Released" : "Dream";
      if (!next[11]) next[11] = "";

      return next;
    });
}

function applyRoadmapFormatting_(sh) {
  const lastRow = Math.max(sh.getLastRow(), 2);
  const range = sh.getRange(2, 1, lastRow - 1, 12);

  const rules = [
    SpreadsheetApp.newConditionalFormatRule()
      .whenTextEqualTo("Complete")
      .setBackground("#d9ead3")
      .setRanges([sh.getRange(2, 5, lastRow - 1, 1)])
      .build(),

    SpreadsheetApp.newConditionalFormatRule()
      .whenTextEqualTo("In Progress")
      .setBackground("#fff2cc")
      .setRanges([sh.getRange(2, 5, lastRow - 1, 1)])
      .build(),

    SpreadsheetApp.newConditionalFormatRule()
      .whenTextEqualTo("Critical")
      .setBackground("#f4cccc")
      .setRanges([sh.getRange(2, 6, lastRow - 1, 1)])
      .build(),

    SpreadsheetApp.newConditionalFormatRule()
      .whenTextEqualTo("High")
      .setBackground("#fce5cd")
      .setRanges([sh.getRange(2, 6, lastRow - 1, 1)])
      .build()
  ];

  sh.setConditionalFormatRules(rules);
}

/*************************************************
 * PARKING LOT
 *************************************************/

function buildBuilderParkingLot_(tracker) {
  const sh = getOrCreateTrackerSheet_(tracker, STAGEOS_PROJECT_TRACKER.parkingLotSheet);

  if (sh.getLastRow() > 0) return;

  sh.getRange(1, 1, 1, 6)
    .setValues([["Idea ID", "Idea", "Category", "Added At", "Promoted?", "Notes"]])
    .setFontWeight("bold")
    .setBackground("#eadcf8");

  sh.setFrozenRows(1);
  sh.autoResizeColumns(1, 6);
}

function addStageOSParkingLotIdeaPrompt() {
  const ui = SpreadsheetApp.getUi();

  const response = ui.prompt(
    "Add Parking Lot Idea",
    "What's the idea?",
    ui.ButtonSet.OK_CANCEL
  );

  if (response.getSelectedButton() !== ui.Button.OK) return;

  const idea = response.getResponseText().trim();
  if (!idea) return;

  addStageOSParkingLotIdea_(idea, "");

  ui.alert("Idea added to Parking Lot.");
}

function addStageOSParkingLotIdea_(idea, notes) {
  const tracker = getStageOSProjectTracker_();
  const sh = tracker.getSheetByName(STAGEOS_PROJECT_TRACKER.parkingLotSheet);
  const nextId = "IDEA-" + String(Math.max(1, sh.getLastRow())).padStart(3, "0");

  sh.appendRow([
    nextId,
    idea,
    classifyParkingLotIdea_(idea),
    new Date(),
    "No",
    notes || ""
  ]);
}

function classifyParkingLotIdea_(idea) {
  const text = String(idea || "").toLowerCase();

  if (text.includes("snapshot") || text.includes("decision")) return "Core";
  if (text.includes("payroll")) return "Payroll";
  if (text.includes("calendar")) return "Calendar";
  if (text.includes("report")) return "Report";
  if (text.includes("home") || text.includes("dashboard")) return "Dashboard";
  if (text.includes("call") || text.includes("notification")) return "Quality of Life";

  return "Idea";
}

