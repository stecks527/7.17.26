function testDecisionOSPlatformAPI() {
  const startedAt =
    Date.now();

  const decision =
    DecisionOS();

  const requiredMethods = [
    "current",
    "get",
    "refresh",
    "status",
    "test",
    "summary",
    "today",
    "review",
    "reviewLatestPerformance"
  ];

  const missingMethods =
    requiredMethods.filter(
      function (methodName) {
        return (
          typeof decision[methodName] !==
          "function"
        );
      }
    );

  const current =
    decision.current();

  const summary =
    decision.summary();

  const today =
    decision.today();

  const status =
    decision.status();

  const result = {
    healthy:
      status.healthy &&
      missingMethods.length === 0,

    methodsChecked:
      requiredMethods.length,

    missingMethods:
      missingMethods,

    available:
      Boolean(current),

    date:
      status.date,

    performance:
      status.performance,

    conductor:
      status.conductor,

    assignments:
      status.assignments,

    resolvedCast:
      status.resolvedCast,

    principalOuts:
      status.principalOuts,

    insertLines:
      status.insertLines,

    summaryAvailable:
      Boolean(
        summary.available
      ),

    todayAvailable:
      Boolean(
        today.available
      ),

    durationMs:
      Date.now() - startedAt
  };

  Logger.log(
    "DECISIONOS PLATFORM API TEST"
  );

  Logger.log(
    JSON.stringify(
      result,
      null,
      2
    )
  );

  SpreadsheetApp
    .getUi()
    .alert(
      "DecisionOS platform API test " +
      (
        result.healthy
          ? "passed."
          : "found issues."
      ) +
      "\n\n" +
      "Methods checked: " +
      result.methodsChecked +
      "\n" +
      "Missing methods: " +
      result.missingMethods.length +
      "\n" +
      "Available: " +
      result.available +
      "\n" +
      "Performance: " +
      result.performance +
      "\n" +
      "Date: " +
      result.date +
      "\n" +
      "Conductor: " +
      result.conductor +
      "\n" +
      "Assignments: " +
      result.assignments +
      "\n" +
      "Resolved Cast: " +
      result.resolvedCast +
      "\n" +
      "Principal Outs: " +
      result.principalOuts +
      "\n" +
      "Insert Lines: " +
      result.insertLines +
      "\n\n" +
      "Duration: " +
      result.durationMs +
      " ms"
    );

  return result;
}
