/*************************************************
 * SHOW STATE BUILDER
 *************************************************/

function buildShowState() {
  const performanceTimer =
    typeof TimerOS === "function"
      ? TimerOS("ShowState Build")
      : null;

  const totalStartedAt =
    Date.now();

  let stepStartedAt =
    totalStartedAt;


  function timer(label) {
    const now =
      Date.now();

    Logger.log(
      label +
      ": " +
      (now - stepStartedAt) +
      "ms"
    );

    stepStartedAt =
      now;
  }


  function markPerformanceTimer_(
    label,
    metadata
  ) {
    if (!performanceTimer) {
      return;
    }

    performanceTimer.mark(
      label,
      metadata || {}
    );
  }


  function finishPerformanceTimer_(
    state,
    source
  ) {
    if (!performanceTimer) {
      return;
    }

    state =
      state || {};

    const intelligence =
      state.intelligence || {};

    performanceTimer.finish({
      source:
        source || "rebuilt",

      date:
        state.prettyDate ||
        state.date ||
        "",

      performances:
        Array.isArray(
          state.performances
        )
          ? state.performances.length
          : 0,

      plannedOuts:
        Array.isArray(
          intelligence.plannedOuts
        )
          ? intelligence.plannedOuts.length
          : 0,

      assignmentTracks:
        state.assignments &&
        Array.isArray(
          state.assignments.tracks
        )
          ? state.assignments.tracks.length
          : 0
    });
  }


  const ss =
    SpreadsheetApp
      .getActiveSpreadsheet();

  const ui =
    SpreadsheetApp
      .getUi();

  const inOut =
    ss.getSheetByName(
      "IN/OUT"
    );

  timer(
    "Setup"
  );

  markPerformanceTimer_(
    "Setup"
  );


  if (!inOut) {
    finishPerformanceTimer_(
      null,
      "failed"
    );

    throw new Error(
      'Could not find "IN/OUT" tab.'
    );
  }


  const identityRanges =
    inOut
      .getRangeList([
        "A3",
        "A4",
        "A24"
      ])
      .getRanges();


  const dateText =
    prepOSClean_(
      identityRanges[0]
        .getDisplayValue()
    );


  const currentPerformanceText =
    prepOSClean_(
      identityRanges[1]
        .getDisplayValue()
    );


  const currentConductor =
    prepOSClean_(
      identityRanges[2]
        .getDisplayValue()
    );


  const targetDate =
    prepOSParseDate_(
      dateText
    );


  timer(
    "Read settings/date"
  );

  markPerformanceTimer_(
    "Read settings/date",
    {
      dateText:
        dateText,

      currentPerformance:
        currentPerformanceText,

      currentConductor:
        currentConductor
    }
  );


  if (!targetDate) {
    finishPerformanceTimer_(
      {
        date:
          dateText
      },
      "invalid-date"
    );

    ui.alert(
      "Could not read the date in IN/OUT!A3."
    );

    return null;
  }


  const cacheKey =
    showStateBuildCacheKey_(
      dateText,
      currentPerformanceText,
      currentConductor
    );


  const cachedState =
    showStateGetCachedState_(
      cacheKey
    );


  markPerformanceTimer_(
    "Check ShowState cache",
    {
      cacheHit:
        Boolean(
          cachedState
        )
    }
  );


  if (cachedState) {
    Logger.log(
      "Show State source: short-lived cache"
    );

    Logger.log(
      "TOTAL Show State: " +
      (
        Date.now() -
        totalStartedAt
      ) +
      "ms"
    );

    finishPerformanceTimer_(
      cachedState,
      "short-lived-cache"
    );

    return cachedState;
  }


  const settings =
    typeof getPrepSettings_ ===
      "function"
      ? getPrepSettings_()
      : {};


  const timezone =
    Session
      .getScriptTimeZone();


  const targetDay =
    Utilities
      .formatDate(
        targetDate,
        timezone,
        "EEEE"
      )
      .toUpperCase();


  const targetMonth =
    Utilities
      .formatDate(
        targetDate,
        timezone,
        "MMMM"
      )
      .toUpperCase();


  const targetDayNum =
    String(
      Number(
        Utilities.formatDate(
          targetDate,
          timezone,
          "d"
        )
      )
    );


  const prettyDate =
    titleCase_(
      targetDay
    ) +
    ", " +
    titleCase_(
      targetMonth
    ) +
    " " +
    targetDayNum;


  timer(
    "Build target date labels"
  );

  markPerformanceTimer_(
    "Build target date labels",
    {
      targetDay:
        targetDay,

      targetMonth:
        targetMonth,

      targetDayNum:
        targetDayNum
    }
  );


  if (
    typeof WeeklyCacheOS !==
      "function"
  ) {
    finishPerformanceTimer_(
      {
        date:
          prettyDate
      },
      "failed"
    );

    throw new Error(
      "WeeklyCacheOS() is unavailable."
    );
  }


  const weeklyDay =
    WeeklyCacheOS()
      .getPrepDay(
        targetDate,
        targetDay,
        targetMonth,
        targetDayNum
      );


  timer(
    "Find weekly prep cache"
  );

  markPerformanceTimer_(
    "Find weekly prep source",
    {
      found:
        Boolean(
          weeklyDay
        ),

      source:
        weeklyDay &&
        weeklyDay.source
          ? weeklyDay.source
          : ""
    }
  );


  Logger.log(
    "Weekly prep source: " +
    (
      weeklyDay &&
      weeklyDay.source
        ? weeklyDay.source
        : "unknown"
    )
  );


  if (!weeklyDay) {
    finishPerformanceTimer_(
      {
        date:
          prettyDate
      },
      "weekly-day-not-found"
    );

    ui.alert(
      "Could not find the weekly day header.\n\n" +
      "Looking for: " +
      targetDay +
      " / " +
      targetMonth +
      " " +
      targetDayNum
    );

    return null;
  }


  let performances =
    showStateClone_(
      weeklyDay.performances ||
      []
    );


  if (!performances.length) {
    finishPerformanceTimer_(
      {
        date:
          prettyDate,

        weeklyName:
          weeklyDay.sheetName ||
          ""
      },
      "no-performances"
    );

    ui.alert(
      "No performance was found for this date.\n\n" +
      "Weekly tab used: " +
      (
        weeklyDay.sheetName ||
        "(unknown)"
      )
    );

    return null;
  }


  /*
   * Preserve the current Expanded Calendar conductor
   * override, with Weekly as fallback.
   */
  if (
    typeof applyExpandedCalendarConductors_ ===
      "function"
  ) {
    performances =
      applyExpandedCalendarConductors_(
        performances,
        targetDate
      );
  }


  timer(
    "Get performances + conductors"
  );

  markPerformanceTimer_(
    "Performances and conductors",
    {
      performances:
        performances.length
    }
  );


  let notesAndHoliday =
    weeklyDay.notes ||
    "";


  const dollarFridayNote =
    typeof getDollarFridayNote_ ===
      "function"
      ? getDollarFridayNote_(
          targetDate,
          settings
        )
      : "";


  if (dollarFridayNote) {
    notesAndHoliday =
      notesAndHoliday
        ? (
            notesAndHoliday +
            "\n" +
            dollarFridayNote
          )
        : dollarFridayNote;
  }


  timer(
    "Get notes/holiday"
  );

  markPerformanceTimer_(
    "Notes and holiday",
    {
      hasNotes:
        Boolean(
          notesAndHoliday
        ),

      hasDollarFriday:
        Boolean(
          dollarFridayNote
        )
    }
  );


  /*
   * Preserve the existing Guest Speller cache behavior.
   */
  const guestCache =
    typeof getGuestSpellerCache_ ===
      "function"
      ? getGuestSpellerCache_()
      : {};


  performances.forEach(
    function (performance) {
      const matchesCachedPerformance =
        guestCache &&
        guestCache.performance ===
          performance.inOutText;


      performance.guestSpeller =
        matchesCachedPerformance
          ? (
              guestCache
                .guestSpellerName ||
              ""
            )
          : "";


      performance.guestDateTimeText =
        matchesCachedPerformance
          ? (
              guestCache
                .guestDateTimeText ||
              ""
            )
          : "";


      performance.guestNote =
        matchesCachedPerformance
          ? (
              guestCache
                .guestSpellerNote ||
              ""
            )
          : "";
    }
  );


  timer(
    "Guest spellers"
  );

  markPerformanceTimer_(
    "Guest Speller hydration",
    {
      cachedGuest:
        Boolean(
          guestCache &&
          guestCache.guestSpellerName
        )
    }
  );


  const selectedIndex =
    performances.length === 1
      ? 0
      : null;


  const defaultPerformance =
    performances[
      selectedIndex === null
        ? 0
        : selectedIndex
    ] ||
    {};


  const castOuts =
    showStateClone_(
      weeklyDay.castOuts ||
      []
    );


  const dropdowns =
    showStateGetCachedInOutDropdowns_();


  timer(
    "Get cast outs + dropdowns"
  );

  markPerformanceTimer_(
    "Cast outs and dropdowns",
    {
      castOuts:
        castOuts.length
    }
  );


  const assignments =
    showStateGetCachedAssignments_(
      defaultPerformance,
      currentConductor
    );


  timer(
    "Get cached assignment state"
  );

  markPerformanceTimer_(
    "Assignment state",
    {
      tracks:
        assignments &&
        Array.isArray(
          assignments.tracks
        )
          ? assignments.tracks.length
          : 0
    }
  );


  const staffing = {
    callingSM:
      assignments.values &&
      assignments.values.calling
        ? assignments.values.calling
        : "",

    deckSM:
      assignments.values &&
      assignments.values.deck
        ? assignments.values.deck
        : "",

    conductor:
      assignments.values &&
      assignments.values.conductor
        ? assignments.values.conductor
        : (
            defaultPerformance
              .conductor ||
            currentConductor ||
            ""
          ),

    a1:
      assignments.values &&
      assignments.values.audio
        ? assignments.values.audio
        : ""
  };


  let state = {
    system:
      "ShowStateOS",

    version:
      "4.1.0",

    date:
      dateText,

    prettyDate:
      prettyDate,

    weeklyName:
      weeklyDay.sheetName ||
      "",

    target: {
      date:
        targetDate,

      day:
        targetDay,

      month:
        targetMonth,

      dayNum:
        targetDayNum,

      timezone:
        timezone
    },

    performances:
      performances,

    selectedIndex:
      selectedIndex,

    selectedPerformance:
      defaultPerformance,

    notes:
      notesAndHoliday,

    currentCastOuts:
      castOuts,

    castOuts:
      castOuts,

    dropdowns:
      dropdowns,

    assignments:
      assignments,

    staffing:
      staffing,

    guestSpeller: {
      exists:
        Boolean(
          defaultPerformance
            .guestSpeller
        ),

      name:
        defaultPerformance
          .guestSpeller ||
        "",

      number:
        defaultPerformance
          .guestSpellerNumber ||
        "",

      note:
        defaultPerformance
          .guestNote ||
        "",

      dateTimeText:
        defaultPerformance
          .guestDateTimeText ||
        ""
    },

    report: {
      date:
        dateText,

      prettyDate:
        prettyDate,

      performance:
        defaultPerformance
          .inOutText ||
        "",

      performancesToday:
        performances
          .map(
            function (
              performance
            ) {
              return (
                performance
                  .inOutText ||
                ""
              );
            }
          )
          .filter(
            Boolean
          ),

      staffing:
        staffing,

      castOuts:
        castOuts,

      notes:
        notesAndHoliday,

      guest: {
        exists:
          Boolean(
            defaultPerformance
              .guestSpeller
          ),

        name:
          defaultPerformance
            .guestSpeller ||
          "",

        number:
          defaultPerformance
            .guestSpellerNumber ||
          "",

        note:
          defaultPerformance
            .guestNote ||
          "",

        dateTimeText:
          defaultPerformance
            .guestDateTimeText ||
          ""
      }
    }
  };


  markPerformanceTimer_(
    "Base ShowState model",
    {
      performances:
        performances.length,

      weeklyCastOuts:
        castOuts.length
    }
  );


  /*
   * Add planned-outs and Prep intelligence.
   */
  if (
    typeof addPrepIntelligenceToShowState_ ===
      "function"
  ) {
    state =
      addPrepIntelligenceToShowState_(
        state
      ) ||
      state;
  }


  markPerformanceTimer_(
    "Prep intelligence",
    {
      plannedOuts:
        state.intelligence &&
        Array.isArray(
          state.intelligence
            .plannedOuts
        )
          ? state.intelligence
              .plannedOuts
              .length
          : 0,

      actorOptions:
        state.intelligence &&
        Array.isArray(
          state.intelligence
            .actorOptions
        )
          ? state.intelligence
              .actorOptions
              .length
          : 0
    }
  );


  /*
   * Restore saved performance-specific staffing
   * after Prep intelligence is assembled.
   */
  if (
    typeof PerformanceStaffingOS ===
      "function"
  ) {
    state =
      PerformanceStaffingOS()
        .applyToShowState(
          state
        ) ||
      state;
  }


  timer(
    "Build intelligence"
  );

  markPerformanceTimer_(
    "Restore performance staffing",
    {
      staffing:
        state.staffing ||
        {}
    }
  );


  showStateSetCachedState_(
    cacheKey,
    state
  );


  markPerformanceTimer_(
    "Write ShowState cache"
  );


  Logger.log(
    "TOTAL Show State: " +
    (
      Date.now() -
      totalStartedAt
    ) +
    "ms"
  );


  finishPerformanceTimer_(
    state,
    "rebuilt"
  );


  return state;
}

/*************************************************
 * 10 SHOW STATE FAST CACHE
 *************************************************/

const SHOW_STATE_CACHE_PROPERTY_ =
  "SHOW_STATE_OS_FAST_CACHE";

const SHOW_STATE_CACHE_MAX_AGE_MS_ =
  90 * 1000;


function showStateBuildCacheKey_(
  dateText,
  performanceText,
  conductor
) {
  return [
    prepOSClean_(dateText),
    prepOSClean_(performanceText),
    prepOSClean_(conductor)
  ].join("|");
}


function showStateGetCachedState_(
  expectedKey
) {
  const raw =
    PropertiesService
      .getDocumentProperties()
      .getProperty(
        SHOW_STATE_CACHE_PROPERTY_
      );

  if (!raw) return null;

  try {
    const cached =
      JSON.parse(raw);

    const age =
      Date.now() -
      Number(
        cached.savedAt || 0
      );

    if (
      age >
      SHOW_STATE_CACHE_MAX_AGE_MS_
    ) {
      showStateClearFastCache_();
      return null;
    }

    if (
      cached.key !==
      expectedKey
    ) {
      return null;
    }

    const state = cached.state || null;

    if (
      state &&
      state.target &&
      state.target.date &&
      !(state.target.date instanceof Date)
    ) {
      const parsedDate = new Date(state.target.date);

      if (!isNaN(parsedDate.getTime())) {
        state.target.date = parsedDate;
      }
    }

    return state;

  } catch (err) {
    showStateClearFastCache_();
    return null;
  }
}


function showStateSetCachedState_(
  key,
  state
) {
  try {
    PropertiesService
      .getDocumentProperties()
      .setProperty(
        SHOW_STATE_CACHE_PROPERTY_,
        JSON.stringify({
          savedAt:
            Date.now(),

          key:
            key,

          state:
            state
        })
      );

    return true;

  } catch (err) {
    Logger.log(
      "Show State cache write skipped: " +
      String(err)
    );

    return false;
  }
}


function showStateClearFastCache_() {
  PropertiesService
    .getDocumentProperties()
    .deleteProperty(
      SHOW_STATE_CACHE_PROPERTY_
    );
}


/*************************************************
 * CACHED ASSIGNMENTS
 *************************************************/

function showStateGetCachedAssignments_(
  defaultPerformance,
  currentConductor
) {
  let cached = {};

  if (
    typeof AssignmentCacheOS ===
    "function"
  ) {
    cached =
      AssignmentCacheOS().get() ||
      {};
  }

  const tracks =
    showStateClone_(
      cached.tracks ||
      (
        typeof AssignmentOS ===
          "function"
          ? AssignmentOS()
              .getTracks()
          : []
      )
    );

  const groups =
    showStateClone_(
      cached.groups ||
      (
        typeof AssignmentOS ===
          "function"
          ? AssignmentOS()
              .getGroups()
          : []
      )
    );

  const peopleByTrack =
    showStateClone_(
      cached.peopleByTrack ||
      {}
    );

  const values = {};

  tracks.forEach(
    function (track) {
      values[track.id] = "";
    }
  );

  values.conductor =
    (
      defaultPerformance &&
      defaultPerformance.conductor
    ) ||
    currentConductor ||
    "";

  return {
    groups:
      groups,

    tracks:
      tracks,

    values:
      values,

    dropdowns: {
      peopleByTrack:
        peopleByTrack,

      people:
        cached.people ||
        uniqueSorted_(
          Object.keys(
            peopleByTrack
          )
            .flatMap(
              function (trackId) {
                return (
                  peopleByTrack[
                    trackId
                  ] ||
                  []
                );
              }
            )
            .map(
              function (person) {
                return (
                  person.name ||
                  person
                );
              }
            )
        ),

      tracks:
        tracks
    },

    officeShow:
      false,

    training: {
      stageManagement: {
        enabled:
          false,

        trackId:
          "",

        trainer:
          "",

        trainee:
          "",

        note:
          "",

        mode:
          "Training"
      },

      audio: {
        enabled:
          false,

        trackId:
          "",

        trainer:
          "",

        trainee:
          "",

        note:
          "",

        mode:
          "Training"
      }
    }
  };
}


/*************************************************
 * CACHED CAST DROPDOWNS
 *************************************************/

function showStateGetCachedInOutDropdowns_() {
  if (
    typeof CastListCacheOS !==
    "function"
  ) {
    return {
      out: [],
      in: [],
      role: [],
      reason:
        showStateReasonOptions_()
    };
  }

  const cache =
    CastListCacheOS().get() ||
    {};

  return {
    out:
      cache.actors || [],

    in:
      cache.actors || [],

    role:
      cache.roles || [],

    reason:
      showStateReasonOptions_()
  };
}


function showStateReasonOptions_() {
  return [
    "Approved PD",
    "Unapp PD",
    "Illness",
    "Injury",
    "MLOA",
    "LOA",
    "Vacation",
    "Conditional",
    "Other"
  ];
}


/*************************************************
 * SAFE CLONE
 *************************************************/

function showStateClone_(
  value
) {
  return JSON.parse(
    JSON.stringify(
      value || (
        Array.isArray(value)
          ? []
          : {}
      )
    )
  );
}


