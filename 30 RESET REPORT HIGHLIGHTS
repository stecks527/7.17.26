/*************************************************
 * 30 RESET REPORT HIGHLIGHTS
 *
 * Active responsibilities:
 * - Clear Performance Highlights
 * - Reset Performance Report shell
 * - Route today's IN/OUT notes safely
 *
 * Key safety rule:
 * - Never preserve stale report notes during reset
 * - Never write IN/OUT notes onto section title rows
 *************************************************/

function clearPerformanceHighlights() {
  const ss = SpreadsheetApp.getActive();
  const sheet = ss.getSheetByName("Performance Highlights");
  const ui = SpreadsheetApp.getUi();

  if (!sheet) {
    ui.alert('Could not find the "Performance Highlights" tab.');
    return;
  }

  sheet.getRange("A3:A181").uncheck();

  const rangesToClear = [
    "B13","G13",
    "B33","G33",
    "G35",
    "B37","G37",
    "B39","G39",
    "G41",
    "B43","G43",
    "B47","G47",
    "B49","G49",
    "G54","G57",
    "B59","G59",
    "B64","G64",
    "B66","G66",
    "G71",
    "B90","G90",
    "G92",
    "B94","G94",
    "B96","G96",
    "G98",
    "B100","G100",
    "B106","G106",
    "G108",
    "B110","G110",
    "B121","G121",
    "G123",
    "B125","G125"
  ];

  rangesToClear.forEach(rangeA1 => {
    sheet.getRange(rangeA1).clearContent();
  });
}

/*************************************************
 * FULL RESET BUTTONS
 *************************************************/

function fullReportResetMat() {
  updateReportBuilder();

  if (typeof copyReportBuilderScheduleToPerformanceReport_ === "function") {
    copyReportBuilderScheduleToPerformanceReport_();
  }

  clearPerformanceHighlights();
  clearPerformanceReport_("today");

  if (typeof routeInOutNotesToPerformanceReport_SAFE === "function") {
    routeInOutNotesToPerformanceReport_SAFE(false);
  }

  SpreadsheetApp.getUi().alert("Report reset complete for matinee.");
}

function fullReportResetEve() {
  setUpcomingDateForEveReset_();
  forcePerformanceReportEveHeader_();
  updateReportBuilder();

  if (typeof copyReportBuilderScheduleToPerformanceReport_ === "function") {
    copyReportBuilderScheduleToPerformanceReport_();
  }

  clearPerformanceHighlights();
  clearPerformanceReport_("tonight");

  // Route ONLY safe notes after the shell is clean.
  if (typeof routeInOutNotesToPerformanceReport_SAFE === "function") {
    routeInOutNotesToPerformanceReport_SAFE(false);
  }

  SpreadsheetApp.getUi().alert("Report reset complete for evening.");
}

function reportResetMatinee() {
  fullReportResetMat();
}

function reportResetEvening() {
  fullReportResetEve();
}

