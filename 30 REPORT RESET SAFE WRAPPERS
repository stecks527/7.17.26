function fullReportResetMat_SAFE() {
  updateReportBuilder_SAFE("MAT");

  clearPerformanceHighlights();
  clearPerformanceReport_("today");

  // Run these AFTER clearPerformanceReport_ so they do not get erased.
  syncInOutToPerformanceReport_();
  syncInOutGridToPerformanceReport_SAFE();
  routeInOutNotesToPerformanceReport_SAFE(false);
  addGuestSpellerToPerformanceReport_SAFE();

  SpreadsheetApp.getUi().alert("Full report reset complete for matinee.");
}

