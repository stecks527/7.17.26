function dependencyOSWriteArchitectureAudit_(ss, config, scan) {
  const sheet = dependencyOSGetOrCreateReportSheet_(
    ss,
    config.reportSheets.architecture
  );

  sheet.clear();

  const headers = [
    "Sheet",
    "Likely Architecture Role",
    "Confidence",
    "Populated Cells",
    "Static Cells",
    "Formula Cells",
    "Incoming References",
    "Outgoing References",
    "Unique Cells Reading This Sheet",
    "Unique Targets This Sheet Reads",
    "External Formulas",
    "Named Ranges",
    "Validations",
    "Architecture Notes"
  ];

  const rows = Object.keys(scan.sheetStats)
    .sort()
    .map(function (sheetName) {
      const stats = scan.sheetStats[sheetName];

      const classification =
        dependencyOSClassifySheetRole_(stats);

      return [
        sheetName,
        classification.role,
        classification.confidence,
        stats.populatedCells,
        stats.staticCells,
        stats.formulaCells,
        stats.incomingReferenceCount,
        stats.outgoingReferenceCount,
        Object.keys(stats.incomingSourceCells).length,
        Object.keys(stats.outgoingTargetCells).length,
        stats.externalFormulaCount,
        stats.namedRangeCount,
        stats.validationCount,
        classification.notes
      ];
    });

  dependencyOSWriteTable_(
    sheet,
    headers,
    rows,
    config
  );

  sheet.setColumnWidth(1, 220);
  sheet.setColumnWidth(2, 180);
  sheet.setColumnWidth(3, 100);
  sheet.setColumnWidth(14, 520);

  dependencyOSApplyArchitectureColors_(sheet, rows, config);
}


function dependencyOSClassifySheetRole_(stats) {
  const incoming = stats.incomingReferenceCount;
  const outgoing = stats.outgoingReferenceCount;
  const formulas = stats.formulaCells;
  const staticCells = stats.staticCells;
  const populated = Math.max(stats.populatedCells, 1);

  const formulaRatio = formulas / populated;
  const staticRatio = staticCells / populated;

  if (
    incoming > 0 &&
    outgoing === 0 &&
    staticRatio >= 0.5
  ) {
    return {
      role: "Likely Source",
      confidence: "HIGH",
      notes:
        "Other tabs read this sheet, while this sheet has little or no formula dependency on other tabs."
    };
  }

  if (
    incoming === 0 &&
    outgoing > 0 &&
    formulaRatio >= 0.25
  ) {
    return {
      role: "Likely Output",
      confidence: "HIGH",
      notes:
        "This sheet reads from elsewhere but is not currently referenced by other formula cells."
    };
  }

  if (
    incoming > 0 &&
    outgoing > 0 &&
    formulaRatio >= 0.2
  ) {
    return {
      role: "Processor / Mixed",
      confidence: "MEDIUM",
      notes:
        "This sheet both consumes and supplies information. Review whether it should be a source, engine layer, or generated output."
    };
  }

  if (
    incoming > 0 &&
    outgoing > 0
  ) {
    return {
      role: "Mixed Use",
      confidence: "MEDIUM",
      notes:
        "This sheet participates in both directions. It may contain manually entered source data alongside generated data."
    };
  }

  if (
    incoming === 0 &&
    outgoing === 0 &&
    staticCells > 0
  ) {
    return {
      role: "Standalone / Manual",
      confidence: "LOW",
      notes:
        "No direct formula relationships were detected. It may be used only by Apps Script, by manual workflows, or not at all."
    };
  }

  if (
    incoming > 0 &&
    outgoing === 0
  ) {
    return {
      role: "Likely Source",
      confidence: "MEDIUM",
      notes:
        "Other formula cells depend on this sheet."
    };
  }

  if (
    incoming === 0 &&
    outgoing > 0
  ) {
    return {
      role: "Likely Output",
      confidence: "MEDIUM",
      notes:
        "This sheet consumes formula data but does not appear to feed other formula cells."
    };
  }

  return {
    role: "Unclassified",
    confidence: "LOW",
    notes:
      "No strong formula-based architecture pattern was detected."
  };
}


