/* =========================================================
 * BROWSER STATE ENDPOINT
 *
 * The existing buildShowState() remains the live state
 * builder during this migration step.
 * ========================================================= */

function prepOS_getState() {
  const startTime = Date.now();

  try {
    const cached =
      typeof prepOSGetCachedState_ === "function"
        ? prepOSGetCachedState_()
        : null;

    if (cached) {
      cached.ok = true;
      cached.fromCache = true;

      Logger.log(
        "PrepOS state cache hit: " +
        (Date.now() - startTime) +
        "ms"
      );

      return prepOSMakeClientSafe_(cached);
    }

    Logger.log("PrepOS state cache miss.");

    const state = PrepOS().state();

    Logger.log(
      "PrepOS state built: " +
      (Date.now() - startTime) +
      "ms"
    );

    if (!state) {
      return prepOSMakeClientSafe_({
        ok: false,
        error:
          "No PrepState returned from buildShowState()."
      });
    }

    state.ok = true;
    state.fromCache = false;

    if (
      typeof prepOSSetCachedState_ ===
      "function"
    ) {
      prepOSSetCachedState_(state);
    }

    return prepOSMakeClientSafe_(state);

  } catch (err) {
    return prepOSMakeClientSafe_({
      ok: false,

      error:
        String(
          err && err.message
            ? err.message
            : err
        ),

      stack:
        String(
          err && err.stack
            ? err.stack
            : ""
        )
    });
  }
}

/*************************************************
 * PREPOS STATUS
 *************************************************/

function prepOSStatus_() {
  const startedAt =
    Date.now();

  let state = null;
  let error = "";

  try {
    state =
      prepOSGetState_();
  } catch (err) {
    error =
      String(
        err && err.message
          ? err.message
          : err
      );
  }

  const performances =
    state &&
    Array.isArray(
      state.performances
    )
      ? state.performances
      : [];

  const assignments =
    state &&
    state.assignments
      ? state.assignments
      : {};

  const intelligence =
    state &&
    state.intelligence
      ? state.intelligence
      : {};

  const tracks =
    Array.isArray(
      assignments.tracks
    )
      ? assignments.tracks
      : [];

  const plannedOuts =
    Array.isArray(
      intelligence.plannedOuts
    )
      ? intelligence.plannedOuts
      : [];

  const actorOptions =
    Array.isArray(
      intelligence.actorOptions
    )
      ? intelligence.actorOptions
      : [];

  return {
    system:
      "PrepOS",

    version:
      "4.0.0",

    available:
      Boolean(state),

    healthy:
      Boolean(
        state &&
        state.date &&
        performances.length &&
        tracks.length
      ),

    error:
      error,

    date:
      state
        ? (
            state.prettyDate ||
            state.date ||
            ""
          )
        : "",

    performances:
      performances.length,

    selectedIndex:
      state &&
      state.selectedIndex !== undefined
        ? state.selectedIndex
        : null,

    assignmentTracks:
      tracks.length,

    plannedOuts:
      plannedOuts.length,

    actorOptions:
      actorOptions.length,

    buildDurationMs:
      Date.now() -
      startedAt,

    dialogAvailable:
      typeof prepOSOpenDialog_ ===
      "function",

    applyAvailable:
      typeof prepOSApplyPayload_ ===
      "function",

    cacheAvailable:
      typeof prepOSGetCachedState_ ===
      "function",

    showStateAvailable:
      typeof ShowStateOS ===
        "function" ||
      typeof buildShowState ===
        "function"
  };
}


/*************************************************
 * PREPOS PLATFORM API TEST
 *************************************************/

function testPrepOSPlatformAPI() {
  const os =
    PrepOS();

  const requiredMethods = [
    "open",
    "current",
    "get",
    "refresh",
    "apply",
    "clearCache",
    "clearAllCaches",
    "status",
    "test"
  ];

  const missingMethods =
    requiredMethods.filter(
      function (methodName) {
        return (
          typeof os[methodName] !==
          "function"
        );
      }
    );

  /*
   * Read current state without opening the dialog
   * or applying anything.
   */
  const state =
    os.current();

  const status =
    os.status();

  const result = {
    healthy:
      status.healthy &&
      missingMethods.length === 0,

    methodsChecked:
      requiredMethods.length,

    missingMethods:
      missingMethods,

    date:
      status.date,

    performances:
      status.performances,

    assignmentTracks:
      status.assignmentTracks,

    plannedOuts:
      status.plannedOuts,

    actorOptions:
      status.actorOptions,

    selectedIndex:
      status.selectedIndex,

    buildDurationMs:
      status.buildDurationMs,

    stateAvailable:
      Boolean(state),

    dialogAvailable:
      status.dialogAvailable,

    applyAvailable:
      status.applyAvailable,

    cacheAvailable:
      status.cacheAvailable,

    showStateAvailable:
      status.showStateAvailable
  };

  Logger.log(
    "PREPOS PLATFORM API TEST"
  );

  Logger.log(
    JSON.stringify(
      result,
      null,
      2
    )
  );

  SpreadsheetApp
    .getUi()
    .alert(
      "PrepOS platform API test " +
      (
        result.healthy
          ? "passed."
          : "found issues."
      ) +
      "\n\n" +
      "Methods checked: " +
      result.methodsChecked +
      "\n" +
      "Missing methods: " +
      result.missingMethods.length +
      "\n" +
      "Date: " +
      result.date +
      "\n" +
      "Performances: " +
      result.performances +
      "\n" +
      "Assignment tracks: " +
      result.assignmentTracks +
      "\n" +
      "Planned outs: " +
      result.plannedOuts +
      "\n" +
      "Actor options: " +
      result.actorOptions +
      "\n\n" +
      "Build duration: " +
      result.buildDurationMs +
      " ms"
    );

  return result;
}

