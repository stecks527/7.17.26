function dependencyOSApplyRiskColors_(
  sheet,
  rows,
  config
) {
  rows.forEach(function (row, index) {
    const severity = row[0];
    const spreadsheetRow = index + 2;

    let background = config.lowRiskBackground;

    if (severity === "HIGH") {
      background = config.highRiskBackground;
    } else if (severity === "MEDIUM") {
      background = config.mediumRiskBackground;
    }

    sheet.getRange(spreadsheetRow, 1)
      .setBackground(background)
      .setFontWeight("bold");
  });
}


function dependencyOSApplyArchitectureColors_(
  sheet,
  rows,
  config
) {
  rows.forEach(function (row, index) {
    const role = row[1];
    const spreadsheetRow = index + 2;

    let background = "";

    if (role === "Likely Source") {
      background = config.lowRiskBackground;
    } else if (role === "Likely Output") {
      background = config.sectionBackground;
    } else if (
      role === "Processor / Mixed" ||
      role === "Mixed Use"
    ) {
      background = config.warningBackground;
    }

    if (background) {
      sheet.getRange(spreadsheetRow, 2)
        .setBackground(background)
        .setFontWeight("bold");
    }
  });
}


/* =========================================================
 * REPORT SHEET HELPERS
 * ========================================================= */

function dependencyOSGetOrCreateReportSheet_(
  ss,
  sheetName
) {
  let sheet = ss.getSheetByName(sheetName);

  if (!sheet) {
    sheet = ss.insertSheet(sheetName);
  }

  sheet.showSheet();

  return sheet;
}


/* =========================================================
 * FORMULA / ADDRESS HELPERS
 * ========================================================= */

function dependencyOSIsExternalFormula_(formula) {
  return /(?:IMPORTRANGE|IMPORTHTML|IMPORTXML|IMPORTDATA|IMPORTFEED)\s*\(/i
    .test(formula || "");
}


function dependencyOSIsBrokenFormula_(
  formula,
  displayValue
) {
  if (!formula) {
    return false;
  }

  return /#REF!|#NAME\?|#VALUE!|#N\/A|#ERROR!|#DIV\/0!/i
    .test(String(displayValue || ""));
}


function dependencyOSExtractImportRangeId_(formula) {
  const match = String(formula || "").match(
    /IMPORTRANGE\s*\(\s*"([^"]+)"/i
  );

  return match ? match[1] : "";
}


function dependencyOSExtractImportRangeRange_(formula) {
  const match = String(formula || "").match(
    /IMPORTRANGE\s*\(\s*"[^"]+"\s*,\s*"([^"]+)"/i
  );

  return match ? match[1] : "";
}


function dependencyOSQualifiedAddress_(
  sheetName,
  rangeA1
) {
  return "'" +
    String(sheetName).replace(/'/g, "''") +
    "'!" +
    rangeA1;
}


function dependencyOSColumnToLetter_(column) {
  let result = "";
  let current = column;

  while (current > 0) {
    const remainder = (current - 1) % 26;

    result =
      String.fromCharCode(65 + remainder) +
      result;

    current = Math.floor((current - 1) / 26);
  }

  return result;
}


function dependencyOSEscapeRegex_(value) {
  return String(value).replace(
    /[.*+?^${}()|[\]\\]/g,
    "\\$&"
  );
}


/* =========================================================
 * RANGE OVERLAP
 * ========================================================= */

function dependencyOSRangesOverlap_(
  sheet,
  firstA1,
  secondA1
) {
  if (!firstA1 || !secondA1) {
    return false;
  }

  try {
    const first = sheet.getRange(firstA1);
    const second = sheet.getRange(secondA1);

    const firstStartRow = first.getRow();
    const firstEndRow =
      firstStartRow + first.getNumRows() - 1;

    const firstStartColumn = first.getColumn();
    const firstEndColumn =
      firstStartColumn + first.getNumColumns() - 1;

    const secondStartRow = second.getRow();
    const secondEndRow =
      secondStartRow + second.getNumRows() - 1;

    const secondStartColumn = second.getColumn();
    const secondEndColumn =
      secondStartColumn + second.getNumColumns() - 1;

    const rowsOverlap =
      firstStartRow <= secondEndRow &&
      firstEndRow >= secondStartRow;

    const columnsOverlap =
      firstStartColumn <= secondEndColumn &&
      firstEndColumn >= secondStartColumn;

    return rowsOverlap && columnsOverlap;
  } catch (error) {
    return firstA1 === secondA1;
  }
}


/* =========================================================
 * MISC HELPERS
 * ========================================================= */

function dependencyOSSeverityRank_(severity) {
  if (severity === "HIGH") {
    return 1;
  }

  if (severity === "MEDIUM") {
    return 2;
  }

  return 3;
}


function dependencyOSShowError_(title, error) {
  const message =
    error && error.message
      ? error.message
      : String(error);

  SpreadsheetApp.getUi().alert(
    title,
    message,
    SpreadsheetApp.getUi().ButtonSet.OK
  );
}

/* =========================================================
 * SAFE REPORT VALUES
 *
 * Prevent formulas from executing when they are written
 * into the Engine workbook as audit text.
 * ========================================================= */

function dependencyOSMakeReportValueSafe_(value) {
  if (typeof value !== "string") {
    return value;
  }

  /*
   * A leading apostrophe tells Google Sheets to preserve
   * formula-like content as plain text. The apostrophe
   * will not appear visibly in the cell.
   */
  if (/^[=+@]/.test(value)) {
    return "'" + value;
  }

  return value;
}


function dependencyOSMakeReportRowsSafe_(rows) {
  return rows.map(function (row) {
    return row.map(function (value) {
      return dependencyOSMakeReportValueSafe_(value);
    });
  });
}
