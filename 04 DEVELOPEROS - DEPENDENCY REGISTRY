/*************************************************
 * STATUS
 *************************************************/

function developerOSDependencyRegistryStatus() {
  const sheet =
    developerOSGetOrCreateDependencyIndexSheet_();

  const result = {
    system:
      "DeveloperOS",

    version:
      "3.0.0",

    dependencyEntries:
      Math.max(
        0,
        sheet.getLastRow() - 1
      ),

    automaticSourceScanning:
      false,

    healthy:
      true
  };

  Logger.log(
    "DEVELOPEROS DEPENDENCY REGISTRY STATUS"
  );

  Logger.log(
    JSON.stringify(
      result,
      null,
      2
    )
  );

  SpreadsheetApp
    .getUi()
    .alert(
      "DeveloperOS Dependency Registry\n\n" +
      "Registered relationships: " +
      result.dependencyEntries +
      "\n" +
      "Automatic source scanning: No\n" +
      "Registry-backed usage lookup: Ready"
    );

  return result;
}


/*************************************************
 * HELPERS
 *************************************************/

function developerOSDependencyKey_(
  functionName,
  relationship,
  relatedFunction
) {
  return [
    developerOSNormalizeSearch_(
      functionName
    ),

    developerOSNormalizeSearch_(
      relationship
    ),

    developerOSNormalizeSearch_(
      relatedFunction
    )
  ].join("::");
}
