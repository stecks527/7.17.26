/* =========================================================
 * SHARED ACTION HELPERS
 * ========================================================= */

function stageOSActionMarkDone_(taskId) {
  if (
    !taskId ||
    typeof WorkflowStatusOS !==
      "function"
  ) {
    return false;
  }

  WorkflowStatusOS().markDone(
    taskId
  );

  if (
    typeof HOME_WORKFLOW_STATUS_CACHE_ !==
       "undefined"
  ) {
    HOME_WORKFLOW_STATUS_CACHE_ =
      null;
  }

  return true;
}


/**
 * Compatibility name used by existing HomeOS code.
 */
function homeOSMarkWorkflowDone_(taskId) {
  return stageOSActionMarkDone_(
    taskId
  );
}


function stageOSActionRefreshHome_() {
  try {
    if (
      typeof HomeOS ===
      "function"
    ) {
      return HomeOS().refresh();
    }

    if (
      typeof refreshHome ===
      "function"
    ) {
      return refreshHome();
    }

  } catch (err) {
    Logger.log(
      "Home refresh skipped after workflow: " +
      String(
        err &&
        err.message
          ? err.message
          : err
      )
    );
  }

  return null;
}


/**
 * Compatibility name used throughout existing workflows.
 */
function refreshHomeAfterWorkflow_() {
  return stageOSActionRefreshHome_();
}


function stageOSActionMissing_(
  label,
  functionNames
) {
  const expected =
    Array.isArray(functionNames)
      ? functionNames
      : [functionNames];

  SpreadsheetApp
    .getUi()
    .alert(
      label +
      " is not connected yet.\n\n" +
      "Expected function:\n" +
      expected.join("\n")
    );

  return false;
}


/**
 * Compatibility alias used by older HomeOS code.
 */
function homeOSActionMissing_(
  label,
  functionName
) {
  return stageOSActionMissing_(
    label,
    functionName
  );
}


