 * REFRESH
 *************************************************/

function refreshStageOSBuilder() {
  const tracker = getStageOSProjectTracker_();
  buildBuilderStats_(tracker);
  refreshBuilderStats_(tracker);
  buildBuilderHome_(tracker);

  SpreadsheetApp.getUi().alert("StageOS Builder refreshed.");
}

function refreshBuilderStats_(tracker) {
  const stats = tracker.getSheetByName(STAGEOS_PROJECT_TRACKER.statsSheet);
  const roadmap = tracker.getSheetByName(STAGEOS_PROJECT_TRACKER.roadmapSheet);
  const journal = tracker.getSheetByName(STAGEOS_PROJECT_TRACKER.logSheet);

  const rows = roadmap.getDataRange().getDisplayValues().slice(1).filter(row => row[0]);
  const completed = rows.filter(row => row[4] === "Complete");
  const inProgress = rows.filter(row => row[4] === "In Progress");

  const bySubsystem = {};
  rows.forEach(row => {
    bySubsystem[row[2]] = (bySubsystem[row[2]] || 0) + 1;
  });

  const topSubsystem = Object.keys(bySubsystem).sort((a, b) => bySubsystem[b] - bySubsystem[a])[0] || "";

  const output = [
    ["Metric", "Value"],
    ["Total Tasks", rows.length],
    ["Completed", completed.length],
    ["In Progress", inProgress.length],
    ["Remaining", rows.length - completed.length],
    ["Largest Subsystem", topSubsystem],
    ["Build Journal Entries", Math.max(0, journal.getLastRow() - 1)]
  ];

  stats.getRange(3, 1, output.length, 2).setValues(output);
  stats.getRange(3, 1, 1, 2).setFontWeight("bold").setBackground("#cfe2f3");
  stats.autoResizeColumns(1, 2);
}

/*************************************************
 * ADD TASKS
 *************************************************/

function addStageOSTaskPrompt() {
  const ui = SpreadsheetApp.getUi();

  const taskResponse = ui.prompt(
    "Add StageOS Task",
    "What do we need to build/fix?",
    ui.ButtonSet.OK_CANCEL
  );

  if (taskResponse.getSelectedButton() !== ui.Button.OK) return;

  const taskName = taskResponse.getResponseText().trim();
  if (!taskName) return;

  const classified = classifyStageOSTask_(taskName);

  const notesResponse = ui.prompt(
    "Task Details",
    "Optional notes/context:",
    ui.ButtonSet.OK_CANCEL
  );

  const notes =
    notesResponse.getSelectedButton() === ui.Button.OK
      ? notesResponse.getResponseText().trim()
      : "";

  const result = addStageOSTask_({
    phase: classified.phase,
    subsystem: classified.subsystem,
    task: taskName,
    status: "Backlog",
    priority: classified.priority,
    estimate: classified.estimate,
    notes: notes,
    pipeline: "Dream",
    dependencies: classified.dependencies || "",
    version: classified.version || ""
  });

  refreshStageOSBuilderSilent_();

  ui.alert(
    "Task added.\n\n" +
    "Task ID: " + result.taskId + "\n" +
    "Subsystem: " + classified.subsystem + "\n" +
    "Estimate: " + classified.estimate
  );
}

function addStageOSTask_(task) {
  const tracker = getStageOSProjectTracker_();
  const roadmap = tracker.getSheetByName(STAGEOS_PROJECT_TRACKER.roadmapSheet);

  const taskId = buildNextStageOSTaskId_(roadmap, task.subsystem);

  roadmap.appendRow([
    taskId,
    task.phase || "Backlog",
    task.subsystem || "General",
    task.task || "",
    task.status || "Backlog",
    task.priority || "Medium",
    task.estimate || "2 hrs",
    "",
    task.notes || "",
    task.pipeline || "Dream",
    task.dependencies || "",
    task.version || ""
  ]);

  sortStageOSRoadmap_(roadmap);
  roadmap.autoResizeColumns(1, 12);

  return { taskId };
}

/*************************************************
 * COMPLETE TASKS
 *************************************************/

function completeStageOSTaskPrompt() {
  const ui = SpreadsheetApp.getUi();

  const task = ui.prompt(
    "Complete StageOS Task",
    "Enter Task ID:",
    ui.ButtonSet.OK_CANCEL
  );

  if (task.getSelectedButton() !== ui.Button.OK) return;

  const notes = ui.prompt(
    "Completion Notes",
    "Optional notes:",
    ui.ButtonSet.OK_CANCEL
  );

  completeStageOSTask(
    task.getResponseText(),
    notes.getSelectedButton() === ui.Button.OK ? notes.getResponseText() : ""
  );

  ui.alert("Task marked complete.");
}

function completeStageOSTask(taskId, notes) {
  const tracker = getStageOSProjectTracker_();
  const roadmap = tracker.getSheetByName(STAGEOS_PROJECT_TRACKER.roadmapSheet);
  const log = tracker.getSheetByName(STAGEOS_PROJECT_TRACKER.logSheet);

  const values = roadmap.getDataRange().getValues();
  const now = new Date();

  for (let r = 1; r < values.length; r++) {
    if (String(values[r][0]).trim() === String(taskId).trim()) {
      roadmap.getRange(r + 1, 5).setValue("Complete");
      roadmap.getRange(r + 1, 8).setValue(now);
      roadmap.getRange(r + 1, 10).setValue("Released");

      if (notes) {
        roadmap.getRange(r + 1, 9).setValue(notes);
      }

      log.appendRow([
        now,
        values[r][0],
        values[r][2],
        values[r][3],
        Session.getActiveUser().getEmail() || "StageOS",
        values[r][11] || "",
        "",
        notes || ""
      ]);

      refreshStageOSBuilderSilent_();
      return true;
    }
  }

  throw new Error("Could not find task ID: " + taskId);
}

/*************************************************
 * CLASSIFIER
 *************************************************/

function classifyStageOSTask_(taskName) {
  const text = String(taskName || "").toLowerCase();

  if (text.includes("snapshot") || text.includes("history")) {
    return taskClass_("Phase 1", "SnapshotOS", "Critical", "6 hrs", "AssignmentOS", "v0.8");
  }

  if (text.includes("decision") || text.includes("smart") || text.includes("compare")) {
    return taskClass_("Phase 1", "DecisionOS", "Critical", "6 hrs", "SnapshotOS", "v0.9");
  }

  if (
    text.includes("assignment") ||
    text.includes("calling") ||
    text.includes("deck") ||
    text.includes("a1") ||
    text.includes("office show") ||
    text.includes("training")
  ) {
    return taskClass_("AssignmentOS", "AssignmentOS", "High", "3 hrs", "", "v0.7");
  }

  if (
    text.includes("report") ||
    text.includes("pdf") ||
    text.includes("notes") ||
    text.includes("guest speller")
  ) {
    return taskClass_("Performance Report", "ReportOS", "High", "3 hrs", "SnapshotOS / DecisionOS", "v0.9");
  }

  if (text.includes("calendar") || text.includes("expanded") || text.includes("cancellation")) {
    return taskClass_("CalendarOS", "CalendarOS", "Medium", "4 hrs", "", "v1.2");
  }

  if (text.includes("out request") || text.includes("pd tracker") || text.includes("vacation")) {
    return taskClass_("Wizards", "Out Request Wizard", "High", "6 hrs", "CalendarOS", "v1.2");
  }

  if (text.includes("new hire") || text.includes("company wizard")) {
    return taskClass_("Wizards", "New Hire Wizard", "High", "6 hrs", "", "v1.0");
  }

  if (text.includes("weekly")) {
    return taskClass_("Weekly", "Weekly Builder", "Medium", "3 hrs", "CalendarOS", "v1.1");
  }

  if (text.includes("email") || text.includes("gmail") || text.includes("draft")) {
    return taskClass_("EmailOS", "EmailOS", "Medium", "3 hrs", "", "v1.1");
  }

  if (text.includes("payroll")) {
    return taskClass_("PayrollOS", "PayrollOS", "High", "4 hrs", "SnapshotOS / AssignmentOS", "v1.1");
  }

  if (text.includes("home") || text.includes("dashboard")) {
    return taskClass_("Home", "Home", "Medium", "3 hrs", "SnapshotOS", "v1.0");
  }

  if (text.includes("call") || text.includes("notification") || text.includes("places")) {
    return taskClass_("CallOS", "CallOS", "High", "6 hrs", "ShowState", "v1.3");
  }

  if (text.includes("dependency") || text.includes("scanner") || text.includes("developer")) {
    return taskClass_("DeveloperOS", "DeveloperOS", "Medium", "4 hrs", "", "v1.3");
  }

  if (text.includes("money")) {
    return taskClass_("MoneyOS", "MoneyOS", "Medium", "4 hrs", "", "");
  }

  return taskClass_("Backlog", "General", "Medium", "2 hrs", "", "");
}

function taskClass_(phase, subsystem, priority, estimate, dependencies, version) {
  return {
    phase,
    subsystem,
    priority,
    estimate,
    dependencies: dependencies || "",
    version: version || ""
  };
}

/*************************************************
 * TASK IDS + SORTING
 *************************************************/

function buildNextStageOSTaskId_(roadmap, subsystem) {
  const prefix = getStageOSTaskPrefix_(subsystem);
  const values = roadmap.getDataRange().getDisplayValues();

  let max = 0;

  values.forEach(row => {
    const id = String(row[0] || "");
    const match = id.match(new RegExp("^" + prefix + "-(\\d+)$"));

    if (match) {
      max = Math.max(max, Number(match[1]));
    }
  });

  return prefix + "-" + String(max + 1).padStart(3, "0");
}

function getStageOSTaskPrefix_(subsystem) {
  const key = String(subsystem || "").toLowerCase();

  if (key.includes("snapshot")) return "SNAP";
  if (key.includes("decision")) return "DECIDE";
  if (key.includes("assignment")) return "ASSIGN";
  if (key.includes("report")) return "REPORT";
  if (key.includes("cast")) return "CAST";
  if (key.includes("calendar")) return "CAL";
  if (key.includes("out request")) return "OUT";
  if (key.includes("new hire")) return "HIRE";
  if (key.includes("weekly")) return "WEEKLY";
  if (key.includes("email")) return "EMAIL";
  if (key.includes("payroll")) return "PAYROLL";
  if (key.includes("home")) return "HOME";
  if (key.includes("intelligence")) return "INTEL";
  if (key.includes("call")) return "CALL";
  if (key.includes("developer")) return "DEV";
  if (key.includes("money")) return "MONEY";

  return "TASK";
}

function sortStageOSRoadmap_(sheet) {
  const lastRow = sheet.getLastRow();
  if (lastRow <= 2) return;

  sheet.getRange(2, 1, lastRow - 1, 12).sort([
    { column: 2, ascending: true },
    { column: 3, ascending: true },
    { column: 6, ascending: true },
    { column: 1, ascending: true }
  ]);
}

/*************************************************
 * SEED ROADMAP
 *************************************************/

