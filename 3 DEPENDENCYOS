/* =========================================================
 * FORMULA MAP REPORT
 * ========================================================= */

function dependencyOSWriteFormulaMap_(ss, config, scan) {
  const sheet = dependencyOSGetOrCreateReportSheet_(
    ss,
    config.reportSheets.formulas
  );

  sheet.clear();

  const headers = [
    "Source Sheet",
    "Source Cell",
    "Source",
    "Target Sheet",
    "Target Range",
    "Target",
    "Relationship",
    "Formula",
    "Current Display Value",
    "External?",
    "Broken?"
  ];

  const rows = [];

  scan.formulas.forEach(function (formulaRecord) {
    if (!formulaRecord.references.length) {
      rows.push([
        formulaRecord.sourceSheet,
        formulaRecord.sourceCell,
        formulaRecord.sourceQualified,
        "",
        "",
        "",
        "Formula with no static A1 reference found",
        formulaRecord.formula,
        formulaRecord.displayValue,
        formulaRecord.isExternal ? "YES" : "",
        formulaRecord.isBroken ? "YES" : ""
      ]);

      return;
    }

    formulaRecord.references.forEach(function (relationship) {
      rows.push([
        formulaRecord.sourceSheet,
        formulaRecord.sourceCell,
        formulaRecord.sourceQualified,
        relationship.targetSheet,
        relationship.targetRange,
        relationship.targetQualified,
        relationship.relationshipType,
        formulaRecord.formula,
        formulaRecord.displayValue,
        formulaRecord.isExternal ? "YES" : "",
        formulaRecord.isBroken ? "YES" : ""
