/*************************************************
 * WEEKLY + PERFORMANCE HELPERS
 *************************************************/

function findPerformancesForWeeklyDay_(values, dayStart, dayEnd) {
  const performances = [];
  const seen = {};

  const headerText = values[dayStart].slice(1, 5).join(" ");
  const headerMatches = [...headerText.matchAll(/PERFORMANCE\s*#?\s*(\d+)\s*-\s*([^+\-]+)/gi)];

  for (const match of headerMatches) {
    const number = match[1];
    const timeText = cleanPerformanceTime_(match[2]);

    if (!seen[number]) {
      performances.push({ number, time: timeText, row: null });
      seen[number] = true;
    }
  }

  for (let r = dayStart; r < dayEnd; r++) {
    const rowText = values[r].slice(0, 5).join(" ");
    const match = rowText.match(/PERFORMANCE\s*#?\s*(\d+)/i);

    if (!match) continue;

    const number = match[1];

    if (seen[number]) {
      const existing = performances.find(p => p.number === number);
      if (existing) existing.row = r;
      continue;
    }

    performances.push({
      number,
      time: findTimeNearPerformanceRow_(values, r),
      row: r
    });

    seen[number] = true;
  }

  const count = performances.length;

  performances.forEach(perf => {
    perf.inOutText = buildInOutPerformanceText_(perf.number, perf.time, count);
  });

  return performances;
}

function buildInOutPerformanceText_(number, timeText, performanceCount) {
  const normalizedTime = cleanPerformanceTime_(timeText);
  const upper = normalizedTime.toUpperCase();

  let suffix = "";

  if (performanceCount > 1) {
    if (upper.includes("MAT")) suffix = " MAT";
    else if (upper.includes("EVE")) suffix = " EVE";
    else if (upper.includes("2:") || upper.includes("1:")) suffix = " MAT";
    else if (upper.includes("7:") || upper.includes("8:")) suffix = " EVE";
  }

  const timeOnly = normalizedTime
    .replace(/\bMAT\b/gi, "")
    .replace(/\bEVE\b/gi, "")
    .trim();

  return "PERFORMANCE #" + number + (timeOnly ? " - " + timeOnly : "") + suffix;
}

function findConductorForPerformanceFromWeekly_(values, dayStart, dayEnd, performanceNumber) {
  for (let r = dayStart; r < dayEnd; r++) {
    const rowText = values[r].slice(0, 5).join(" ");
    const rowPerf = getPerformanceNumber_(rowText);

    if (rowPerf && rowPerf === performanceNumber) {
      for (let i = r + 1; i < Math.min(r + 8, dayEnd); i++) {
        const line = String(values[i].slice(0, 5).join(" ")).trim();
        const match = line.match(/Conductor\s*=\s*(.+)/i);
        if (match) return match[1].trim();
      }
    }
  }

  return "";
}

function getNotesAndHolidayFromWeeklyDay_(values, dayStart, dayEnd) {
  const output = [];

  const holidayText = extractHolidayFromHeader_(
    values[dayStart].slice(1, 5).join(" ").trim()
  );

  if (holidayText) output.push("- " + holidayText);

  for (let r = dayStart; r < dayEnd; r++) {
    const rowText = normalizeWeeklyText_(values[r].slice(0, 5).join(" "));

    if (rowText.includes("NOTES")) {
      const notesText = values[r]
        .slice(0, 5)
        .filter(cell => !normalizeWeeklyText_(cell).includes("NOTES"))
        .join(" ")
        .trim();

      if (notesText) output.push(notesText);
      break;
    }
  }

  return output.join("\n");
}

/*************************************************
 * EXPANDED CALENDAR CONDUCTOR LOOKUP
 *
 * Expanded Calendar:
 * A = Date
 * B = Performance
 * F = Conductor
 *
 * Uses the same matching logic as Guest Speller.
 *************************************************/

function applyExpandedCalendarConductors_(
  performances,
  targetDate
) {
  const list = Array.isArray(performances)
    ? performances
    : [];

  if (!list.length || !targetDate) {
    return list;
  }

  const conductorMap =
    getExpandedCalendarConductorMap_(
      targetDate
    );

  list.forEach(function (perf) {
    perf = perf || {};

    const performanceNumber =
      stageOSGuestPerformanceNumber_(
        perf.inOutText ||
        perf.performanceText ||
        perf.label ||
        perf.number ||
        ""
      );

    const conductor =
      conductorMap[performanceNumber] || "";

    if (conductor) {
      perf.conductor = conductor;
      perf.conductorSource =
        "Expanded Calendar";
    } else {
      /*
       * Preserve the existing Weekly value only
       * when Expanded Calendar has no match.
       */
      perf.conductor =
        String(perf.conductor || "").trim();

      perf.conductorSource =
        perf.conductor
          ? "Weekly Schedule"
          : "";
    }
  });

  return list;
}


/* =========================================================
 * EXPANDED CALENDAR CONDUCTOR CACHE
 * Version: 1.1.0
 *
 * Improvements:
 * - Uses CacheService instead of Document Properties
 * - Reads A:F in one Spreadsheet call
 * - Caches each date for six hours
 * ========================================================= */

const EXPANDED_CALENDAR_CONDUCTOR_CACHE_PREFIX_ =
  "EXPANDED_CALENDAR_CONDUCTORS_V2|";

const EXPANDED_CALENDAR_CONDUCTOR_CACHE_SECONDS_ =
  21600; // 6 hours


function getExpandedCalendarConductorMap_(
  targetDate,
  forceRefresh
) {
  if (
    !(targetDate instanceof Date) ||
    isNaN(targetDate.getTime())
  ) {
    return {};
  }

  const timezone =
    Session.getScriptTimeZone();

  const dateKey =
    Utilities.formatDate(
      targetDate,
      timezone,
      "yyyy-MM-dd"
    );

  const cacheKey =
    EXPANDED_CALENDAR_CONDUCTOR_CACHE_PREFIX_ +
    dateKey;

  if (!forceRefresh) {
    const cached =
      expandedCalendarReadConductorCache_(
        cacheKey
      );

    if (cached) {
      Logger.log(
        "Expanded Calendar conductor source: cache"
      );

      return cached;
    }
  }

  const startedAt =
    Date.now();

  const calendar =
    SpreadsheetApp
      .getActiveSpreadsheet()
      .getSheetByName(
        "Expanded Calendar"
      );

  if (!calendar) {
    return {};
  }

  const lastRow =
    calendar.getLastRow();

  if (lastRow < 2) {
    return {};
  }

  /*
   * Read columns A:F once:
   *
   * A = Date
   * B = Performance
   * F = Conductor
   */
  const values =
    calendar
      .getRange(
        2,
        1,
        lastRow - 1,
        6
      )
      .getDisplayValues();

  const wantedDateKey =
    stageOSGuestDateKey_(
      targetDate
    );

  const conductorMap = {};

  let currentDateKey =
    "";

  for (
    let index = 0;
    index < values.length;
    index++
  ) {
    const row =
      values[index];

    const displayedDate =
      String(
        row[0] || ""
      ).trim();

    if (displayedDate) {
      currentDateKey =
        stageOSGuestDateKey_(
          displayedDate
        );
    }

    if (
      currentDateKey !==
      wantedDateKey
    ) {
      continue;
    }

    const performanceNumber =
      stageOSGuestPerformanceNumber_(
        row[1]
      );

    const conductor =
      String(
        row[5] || ""
      ).trim();

    if (
      performanceNumber &&
      conductor
    ) {
      conductorMap[
        performanceNumber
      ] =
        conductor;
    }
  }

  expandedCalendarWriteConductorCache_(
    cacheKey,
    conductorMap
  );

  Logger.log(
    "Expanded Calendar conductor source: rebuilt"
  );

  Logger.log(
    "Expanded Calendar conductor lookup: " +
    (
      Date.now() -
      startedAt
    ) +
    "ms"
  );

  return conductorMap;
}


function expandedCalendarReadConductorCache_(
  cacheKey
) {
  try {
    const raw =
      CacheService
        .getDocumentCache()
        .get(
          cacheKey
        );

    if (!raw) {
      return null;
    }

    const parsed =
      JSON.parse(
        raw
      );

    if (
      !parsed ||
      typeof parsed.map !==
        "object"
    ) {
      return null;
    }

    return parsed.map;

  } catch (err) {
    Logger.log(
      "Expanded Calendar conductor cache read skipped: " +
      String(err)
    );

    return null;
  }
}


function expandedCalendarWriteConductorCache_(
  cacheKey,
  conductorMap
) {
  try {
    CacheService
      .getDocumentCache()
      .put(
        cacheKey,
        JSON.stringify({
          cachedAt:
            new Date()
              .toISOString(),

          map:
            conductorMap || {}
        }),
        EXPANDED_CALENDAR_CONDUCTOR_CACHE_SECONDS_
      );

    return true;

  } catch (err) {
    Logger.log(
      "Expanded Calendar conductor cache write skipped: " +
      String(err)
    );

    return false;
  }
}


function clearExpandedCalendarConductorCache_(
  targetDate
) {
  /*
   * CacheService cannot enumerate every matching key,
   * so a date is required for targeted clearing.
   *
   * The current production date is used when no date
   * is explicitly supplied.
   */
  let date =
    targetDate;

  if (
    !(date instanceof Date) ||
    isNaN(date.getTime())
  ) {
    const inOut =
      SpreadsheetApp
        .getActiveSpreadsheet()
        .getSheetByName(
          "IN/OUT"
        );

    const dateText =
      inOut
        ? inOut
            .getRange("A3")
            .getDisplayValue()
        : "";

    date =
      typeof prepOSParseDate_ ===
        "function"
        ? prepOSParseDate_(
            dateText
          )
        : new Date(
            dateText
          );
  }

  if (
    !(date instanceof Date) ||
    isNaN(date.getTime())
  ) {
    return false;
  }

  const dateKey =
    Utilities.formatDate(
      date,
      Session.getScriptTimeZone(),
      "yyyy-MM-dd"
    );

  CacheService
    .getDocumentCache()
    .remove(
      EXPANDED_CALENDAR_CONDUCTOR_CACHE_PREFIX_ +
      dateKey
    );

  Logger.log(
    "Expanded Calendar conductor cache cleared for " +
    dateKey
  );

  return true;
}


function refreshExpandedCalendarConductorCache() {
  const inOut =
    SpreadsheetApp
      .getActiveSpreadsheet()
      .getSheetByName(
        "IN/OUT"
      );

  if (!inOut) {
    throw new Error(
      'Could not find "IN/OUT" tab.'
    );
  }

  const targetDate =
    prepOSParseDate_(
      inOut
        .getRange("A3")
        .getDisplayValue()
    );

  if (!targetDate) {
    throw new Error(
      "Could not read the current IN/OUT date."
    );
  }

  clearExpandedCalendarConductorCache_(
    targetDate
  );

  const map =
    getExpandedCalendarConductorMap_(
      targetDate,
      true
    );

  SpreadsheetApp
    .getUi()
    .alert(
      "Expanded Calendar conductor cache refreshed.\n\n" +
      "Conductors found: " +
      Object.keys(
        map
      ).length
    );

  return map;
}


