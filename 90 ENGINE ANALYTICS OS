    category: "Resolver",
    notes: ""
  });

  metrics.push({
    metric: "Default Decisions",
    value: objects.filter(o => String(o.Status || "") === "DEFAULT").length,
    category: "Resolver",
    notes: ""
  });

  metrics.push({
    metric: "Uncovered Decisions",
    value: objects.filter(o => String(o.Status || "") === "OUT_UNCOVERED").length,
    category: "Resolver",
    notes: ""
  });

  const uniqueRoles = [...new Set(
