/* =========================================================
 * SETTINGS SERVICE CONSTANTS
 * ========================================================= */

const STAGEOS_SETTINGS_CACHE_KEY =
  "SETTINGS_CACHE_OS_DATA";

let STAGEOS_SETTINGS_MEMORY_CACHE_ = null;


/* =========================================================
 * PUBLIC SETTINGS SERVICE
 * ========================================================= */

function StageOSSettings() {
  return {
    all: function () {
      return stageOSSettingsLoad_();
    },

    get: function (labelOrKey, fallback) {
      return stageOSSettingsGet_(
        labelOrKey,
        fallback
      );
    },

    boolean: function (labelOrKey, fallback) {
      return stageOSSettingsBoolean_(
        labelOrKey,
        fallback
      );
    },

    sheetName: function (sheetKey) {
      return stageOSResolveSheetName_(sheetKey);
    },

    sheet: function (sheetKey) {
      return stageOSGetSheet_(sheetKey);
    },

    driveId: function (labelOrKey) {
      return stageOSSettingsDriveId_(
        labelOrKey
      );
    },

    refresh: function () {
      return stageOSSettingsRefresh_();
    },

    clear: function () {
      return stageOSSettingsClear_();
    },

    status: function () {
      return stageOSSettingsStatus_();
    }
  };
}


/* =========================================================
 * SETTINGS LOAD / CACHE
 * ========================================================= */

function stageOSSettingsLoad_() {
  if (STAGEOS_SETTINGS_MEMORY_CACHE_) {
    return STAGEOS_SETTINGS_MEMORY_CACHE_;
  }

  const props =
    PropertiesService.getDocumentProperties();

  const raw =
    props.getProperty(
      STAGEOS_SETTINGS_CACHE_KEY
    );

  if (raw) {
    try {
      const cached = JSON.parse(raw);

      if (
        cached &&
        cached.stageKeys
      ) {
        STAGEOS_SETTINGS_MEMORY_CACHE_ =
          stageOSSettingsBuildPublicObject_(cached);

        return STAGEOS_SETTINGS_MEMORY_CACHE_;
      }
    } catch (err) {
      Logger.log(
        "StageOS settings cache could not be parsed. Rebuilding."
      );
    }
  }

  return stageOSSettingsRefresh_();
}

function stageOSSettingsRefresh_() {
  const ss =
    SpreadsheetApp.getActiveSpreadsheet();

  const sheet =
    ss.getSheetByName(
      STAGEOS.SETTINGS_SHEET
    );

  if (!sheet) {
    throw new Error(
      'Could not find "' +
      STAGEOS.SETTINGS_SHEET +
      '" tab.'
    );
  }

  const lastRow = sheet.getLastRow();

  const values = lastRow
    ? sheet
        .getRange(1, 1, lastRow, 2)
        .getDisplayValues()
    : [];

  const rawValues = {};
  const stageKeys = {};

  values.forEach(function (row) {
    const label =
      String(row[0] || "").trim();

    const rawValue =
      String(row[1] || "").trim();

    if (!label) return;
    if (stageOSSettingsIsHeader_(label)) return;

    const normalizedLabel =
      label.toLowerCase();

    const stageKey =
      toStageOSKey_(label);

    const parsedValue =
      parseStageOSValue_(rawValue);

    rawValues[normalizedLabel] =
      parsedValue;

    if (stageKey) {
      stageKeys[stageKey] =
        parsedValue;
    }
  });

  const cache = {
    cachedAt: new Date().toISOString(),
    values: rawValues,
    stageKeys: stageKeys
  };

  PropertiesService
    .getDocumentProperties()
    .setProperty(
      STAGEOS_SETTINGS_CACHE_KEY,
      JSON.stringify(cache)
    );

  STAGEOS_SETTINGS_MEMORY_CACHE_ =
    stageOSSettingsBuildPublicObject_(cache);

  return STAGEOS_SETTINGS_MEMORY_CACHE_;
}

function stageOSSettingsClear_() {
  STAGEOS_SETTINGS_MEMORY_CACHE_ = null;

  PropertiesService
    .getDocumentProperties()
    .deleteProperty(
      STAGEOS_SETTINGS_CACHE_KEY
    );

  return true;
}

function stageOSSettingsBuildPublicObject_(cache) {
  const settings = Object.assign(
    {},
    cache && cache.stageKeys
      ? cache.stageKeys
      : {}
  );

  settings.sheets = Object.assign(
    {},
    STAGEOS.SHEETS
  );

  settings.cachedAt =
    cache && cache.cachedAt
      ? cache.cachedAt
      : "";

  return settings;
}

function stageOSSettingsStatus_() {
  const props =
    PropertiesService.getDocumentProperties();

  const raw =
    props.getProperty(
      STAGEOS_SETTINGS_CACHE_KEY
    ) || "";

  let parsed = {};

  if (raw) {
    try {
      parsed = JSON.parse(raw);
    } catch (err) {
      parsed = {};
    }
  }

  return {
    exists: Boolean(raw),
    cachedAt: parsed.cachedAt || "",
    settingsCount: Object.keys(
      parsed.stageKeys || {}
    ).length,
    rawLabelCount: Object.keys(
      parsed.values || {}
    ).length,
    size: raw.length,
    memoryLoaded:
      Boolean(
        STAGEOS_SETTINGS_MEMORY_CACHE_
      )
  };
}


/* =========================================================
 * SETTING ACCESS
 * ========================================================= */

function stageOSSettingsGet_(
  labelOrKey,
  fallback
) {
  const key =
    toStageOSKey_(labelOrKey);

  const settings =
    stageOSSettingsLoad_();

  if (
    key &&
    settings[key] !== undefined &&
    settings[key] !== ""
  ) {
    return settings[key];
  }

  /*
   * Also check the original lower-case label map.
   * This supports SettingsCacheOS().get("Engine Enabled")
   * and similar legacy calls.
   */
  const props =
    PropertiesService.getDocumentProperties();

  const raw =
    props.getProperty(
      STAGEOS_SETTINGS_CACHE_KEY
    );

  if (raw) {
    try {
      const cache = JSON.parse(raw);

      const rawKey =
        String(labelOrKey || "")
          .trim()
          .toLowerCase();

      const value =
        cache.values &&
        cache.values[rawKey];

      if (
        value !== undefined &&
        value !== ""
      ) {
        return value;
      }
    } catch (err) {}
  }

  return fallback;
}

function stageOSSettingsBoolean_(
  labelOrKey,
  fallback
) {
  const value =
    stageOSSettingsGet_(
      labelOrKey,
      fallback
    );

  return stageOSParseBoolean_(
    value,
    fallback
  );
}

function stageOSSettingsDriveId_(
  labelOrKey
) {
  const value =
    stageOSSettingsGet_(
      labelOrKey,
      ""
    );

  if (!value) {
    throw new Error(
      'Could not find "' +
      labelOrKey +
      '" in Production Settings.'
    );
  }

  return extractStageOSDriveId_(value);
}


/* =========================================================
 * SHEET ACCESS
 * ========================================================= */

function stageOSResolveSheetName_(sheetKey) {
  const key =
    String(sheetKey || "").trim();

  if (!key) return "";

  const settings =
    stageOSSettingsLoad_();

  const configuredSheets =
    settings.sheets || {};

  return (
    configuredSheets[key] ||
    STAGEOS.SHEETS[key] ||
    key
  );
}

function stageOSGetSheet_(sheetKey) {
  const ss =
    SpreadsheetApp.getActiveSpreadsheet();

  const sheetName =
    stageOSResolveSheetName_(sheetKey);

  const sheet =
    ss.getSheetByName(sheetName);

  if (!sheet) {
    throw new Error(
      'Could not find "' +
      sheetName +
      '" tab.'
    );
  }

  return sheet;
}


/* =========================================================
 * SHARED PARSERS
 * ========================================================= */

function toStageOSKey_(label) {
  return String(label || "")
    .trim()
    .replace(/[^\w\s]/g, "")
    .replace(
      /\s+(.)/g,
      function (_, chr) {
        return chr.toUpperCase();
      }
    )
    .replace(
      /^\w/,
      function (chr) {
        return chr.toLowerCase();
      }
    );
}

function parseStageOSValue_(value) {
  const text =
    String(value || "").trim();

  const upper =
    text.toUpperCase();

  if (
    upper === "TRUE" ||
    upper === "YES"
  ) {
    return true;
  }

  if (
    upper === "FALSE" ||
    upper === "NO"
  ) {
    return false;
  }

  return text;
}

function stageOSParseBoolean_(
  value,
  fallback
) {
  if (
    value === true ||
    value === false
  ) {
    return value;
  }

  const text =
    String(value || "")
      .trim()
      .toUpperCase();

  if (
    [
      "TRUE",
      "YES",
      "Y",
      "1",
      "CHECKED"
    ].includes(text)
  ) {
    return true;
  }

  if (
    [
      "FALSE",
      "NO",
      "N",
      "0",
      "UNCHECKED"
    ].includes(text)
  ) {
    return false;
  }

  return Boolean(fallback);
}

function extractStageOSDriveId_(input) {
  const text =
    String(input || "").trim();

  if (!text) return "";

  const fileMatch =
    text.match(
      /\/d\/([a-zA-Z0-9_-]+)/
    );

  if (fileMatch) {
    return fileMatch[1];
  }

  const folderMatch =
    text.match(
      /\/folders\/([a-zA-Z0-9_-]+)/
    );

  if (folderMatch) {
    return folderMatch[1];
  }

  const queryMatch =
    text.match(
      /[?&]id=([a-zA-Z0-9_-]+)/
    );

  if (queryMatch) {
    return queryMatch[1];
  }

  const genericMatch =
    text.match(
      /[a-zA-Z0-9_-]{20,}/
    );

  return genericMatch
    ? genericMatch[0]
    : text;
}

function stageOSSettingsIsHeader_(label) {
  const text =
    String(label || "")
      .trim()
      .toLowerCase();

  return [
    "production settings",
    "value",
    "production",
    "branding",
    "assets",
    "default email signature",
    "stageos"
  ].includes(text);
}


