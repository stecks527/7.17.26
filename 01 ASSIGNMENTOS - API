/*************************************************
 * UNCACHED STATE FALLBACK
 *************************************************/

function assignmentOSBuildUncachedState_() {
  const tracks =
    AssignmentOS().getTracks();

  const groups =
    AssignmentOS().getGroups();

  const peopleByTrack =
    AssignmentOS().getPeopleByTrack();

  const people =
    uniqueSorted_(
      Object.keys(
        peopleByTrack
      )
        .flatMap(function (trackId) {
          return (
            peopleByTrack[trackId] ||
            []
          );
        })
        .map(function (person) {
          return (
            person.name ||
            person
          );
        })
    );

  return {
    cachedAt: "",
    source: "uncached",
    groups: groups,
    tracks: tracks,
    peopleByTrack: peopleByTrack,
    people: people
  };
}


/*************************************************
 * STATUS
 *************************************************/

function assignmentOSStatus_() {
  const cached =
    AssignmentOS().getCached() ||
    {};

  const tracks =
    cached.tracks ||
    AssignmentOS().getTracks();

  const groups =
    cached.groups ||
    AssignmentOS().getGroups();

  const peopleByTrack =
    cached.peopleByTrack ||
    {};

  const missingTracks =
    tracks
      .filter(function (track) {
        return !Array.isArray(
          peopleByTrack[track.id]
        );
      })
      .map(function (track) {
        return track.id;
      });

  return {
    system: "AssignmentOS",
    version: "4.0.0",
    available: true,

    cacheAvailable:
      typeof AssignmentCacheOS ===
      "function",

    cachedAt:
      cached.cachedAt || "",

    groups:
      groups.length,

    tracks:
      tracks.length,

    people:
      Array.isArray(
        cached.people
      )
        ? cached.people.length
        : 0,

    peopleByTrack: {
      calling:
        (
          peopleByTrack.calling ||
          []
        ).length,

      deck:
        (
          peopleByTrack.deck ||
          []
        ).length,

      conductor:
        (
          peopleByTrack.conductor ||
          []
        ).length,

      audio:
        (
          peopleByTrack.audio ||
          []
        ).length
    },

    missingTracks:
      missingTracks,

    healthy:
      tracks.length === 4 &&
      missingTracks.length === 0
  };
}


/*************************************************
 * PLATFORM API TEST
 *************************************************/

function testAssignmentOSPlatformAPI() {
  const os =
    AssignmentOS();

  const refreshed =
    os.refresh();

  const status =
    os.status();

  const requiredMethods = [
    "getTracks",
    "getGroups",
    "getPeopleByTrack",
    "getAllDepartments",
    "getCached",
    "refresh",
    "clearCache",
    "status",
    "test"
  ];

  const missingMethods =
    requiredMethods.filter(
      function (methodName) {
        return (
          typeof os[methodName] !==
          "function"
        );
      }
    );

  const result = {
    healthy:
      status.healthy &&
      missingMethods.length === 0,

    methodsChecked:
      requiredMethods.length,

    missingMethods:
      missingMethods,

    tracks:
      status.tracks,

    groups:
      status.groups,

    people:
      status.people,

    calling:
      status.peopleByTrack.calling,

    deck:
      status.peopleByTrack.deck,

    conductor:
      status.peopleByTrack.conductor,

    audio:
      status.peopleByTrack.audio,

