/* =========================================================
 * INTERNAL BRIDGES
 *
 * These deliberately call the existing working systems.
 * We will migrate each implementation one file at a time.
 * ========================================================= */

function prepOSGetState_() {
  if (
    typeof buildShowState !==
    "function"
  ) {
    throw new Error(
      "PrepOS could not find buildShowState()."
    );
  }

  return buildShowState();
}

function prepOSApplyPayload_(payload) {
  if (
    typeof applyInOutPrepFromDialog !==
    "function"
  ) {
    throw new Error(
      "PrepOS could not find applyInOutPrepFromDialog()."
    );
  }

  return applyInOutPrepFromDialog(
    payload || {}
  );
}


/* =========================================================
 * CLIENT-SAFE SERIALIZATION
 *
 * This uses a new private name so it does not conflict with
 * the existing prepOSClientSafe_() in the helper file.
 * ========================================================= */

function prepOSMakeClientSafe_(value) {
  return JSON.parse(
    JSON.stringify(
      value,
      function (key, item) {
        if (
          Object.prototype.toString.call(item) ===
          "[object Date]"
        ) {
          return Utilities.formatDate(
            item,
            Session.getScriptTimeZone(),
            "yyyy-MM-dd'T'HH:mm:ss"
          );
        }

        if (
          item === undefined ||
          typeof item === "function"
        ) {
          return null;
        }

        return item;
      }
    )
  );
}


