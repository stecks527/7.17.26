/* =========================================================
 * ENGINE WORKBOOK
 * ========================================================= */

function dependencyOSGetEngineWorkbook_() {
  const config = dependencyOSConfig_();
  const engineSpreadsheetId =
    String(config.engineSpreadsheetId || "").trim();

  if (!engineSpreadsheetId) {
    throw new Error(
      "DependencyOS engineSpreadsheetId has not been configured."
    );
  }

  try {
    return SpreadsheetApp.openById(engineSpreadsheetId);
  } catch (error) {
    throw new Error(
      "DependencyOS could not open the Engine workbook. " +
      "Confirm the spreadsheet ID and that you have access. " +
      "Original error: " +
      error.message
    );
  }
}


/* =========================================================
 * MAIN AUDIT
 * ========================================================= */

function dependencyOSAuditWorkbook_() {
  const activeSS = SpreadsheetApp.getActiveSpreadsheet();
  if (!activeSS) throw new Error("DependencyOS must be started from the StageOS workbook.");

  const existingState = dependencyOSLoadAuditState_();
  if (existingState && existingState.sourceSpreadsheetId && existingState.sourceSpreadsheetId !== activeSS.getId()) {
    throw new Error("A DependencyOS audit is already saved for another workbook. Run Reset Audit Progress first.");
  }

  if (!existingState || existingState.status === "COMPLETE") {
    dependencyOSInitializeAudit_(activeSS);
  }

  return dependencyOSRunResumableAudit_(false);
}


/* =========================================================
 * WORKBOOK SCANNER
 * ========================================================= */

function dependencyOSScanWorkbook_(ss, config) {
  const sheets = dependencyOSGetIncludedSheets_(ss, config);
  const scan = dependencyOSCreateEmptyScan_(ss);
  sheets.forEach(function (sheet) { dependencyOSScanSheet_(sheet, scan); });
  dependencyOSScanNamedRanges_(ss, scan);
  dependencyOSFinalizeSheetRelationships_(scan);
  return scan;
}

function dependencyOSScanSheet_(sheet, scan) {
  const lastRow = sheet.getLastRow();
  dependencyOSEnsureSheetStats_(sheet, scan);
  if (lastRow < 1) return;
  dependencyOSScanSheetChunk_(sheet, scan, 1, lastRow);
}

