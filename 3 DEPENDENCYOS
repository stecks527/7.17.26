}


function dependencyOSResetStageSheets_(
  engineSS,
  config
) {
  const definitions =
    dependencyOSStageDefinitions_(
      config
    );

  Object.keys(definitions)
    .forEach(function (key) {
      const definition =
        definitions[key];

      let sheet =
        engineSS.getSheetByName(
          definition.name
        );

      if (!sheet) {
        sheet =
          engineSS.insertSheet(
            definition.name
          );
      }

      sheet.clear();

      sheet
        .getRange(
          1,
          1,
          1,
          definition.headers.length
        )
        .setValues([
          definition.headers
        ]);

      sheet.hideSheet();
    });
}


function dependencyOSGetStageSheet_(
  engineSS,
  sheetName
) {
  const sheet =
    engineSS.getSheetByName(
      sheetName
    );

  if (!sheet) {
    throw new Error(
      "DependencyOS staging sheet is missing: " +
      sheetName +
      ". Reset Audit Progress and start again."
    );
  }

  return sheet;
}


function dependencyOSAppendStageRows_(
  sheet,
  rows
) {
  if (!rows || !rows.length) {
    return;
  }

  sheet
    .getRange(
      sheet.getLastRow() + 1,
      1,
      rows.length,
      rows[0].length
    )
    .setValues(
      dependencyOSMakeReportRowsSafe_(
        rows
      )
    );
}


function dependencyOSEnsureStageSheetStats_(
  engineSS,
  config,
  sourceSheet
) {
  const stageSheet =
    dependencyOSGetStageSheet_(
      engineSS,
      config.stagingSheets
        .sheetStats
    );

  const sheetName =
    sourceSheet.getName();

  const lastRow =
    stageSheet.getLastRow();

  if (lastRow > 1) {
    const names =
      stageSheet
        .getRange(
          2,
          1,
          lastRow - 1,
          1
        )
        .getDisplayValues()
        .map(function (row) {
          return row[0];
        });

    if (
      names.indexOf(
        sheetName
      ) !== -1
    ) {
      return;
    }
  }

  dependencyOSAppendStageRows_(
    stageSheet,
    [[
      sheetName,
      sourceSheet.getSheetId(),
      sourceSheet.getLastRow(),
      sourceSheet.getLastColumn(),
      0,
      0,
      0,
      0,
      0
    ]]
  );
}


function dependencyOSUpdateStageSheetStats_(
  engineSS,
  config,
  sheetName,
  delta
) {
  const stageSheet =
    dependencyOSGetStageSheet_(
      engineSS,
      config.stagingSheets
        .sheetStats
    );

  const lastRow =
    stageSheet.getLastRow();

  if (lastRow < 2) {
    throw new Error(
      "DependencyOS could not find staging stats for " +
      sheetName +
      "."
    );
  }

  const rows =
    stageSheet
      .getRange(
        2,
        1,
        lastRow - 1,
        9
      )
      .getValues();

  const index =
    rows.findIndex(function (row) {
      return row[0] === sheetName;
    });

  if (index === -1) {
    throw new Error(
      "DependencyOS could not find staging stats for " +
      sheetName +
      "."
    );
  }

  const row =
    rows[index];

  row[4] =
    Number(row[4] || 0) +
    Number(delta.populatedCells || 0);

  row[5] =
    Number(row[5] || 0) +
    Number(delta.formulaCells || 0);

  row[6] =
    Number(row[6] || 0) +
    Number(delta.staticCells || 0);

  row[7] =
    Number(row[7] || 0) +
    Number(delta.externalFormulaCount || 0);

  row[8] =
    Number(row[8] || 0) +
    Number(delta.brokenFormulaCount || 0);

  stageSheet
    .getRange(
      index + 2,
      1,
      1,
      9
    )
    .setValues([
      row
    ]);
}


function dependencyOSScanSheetChunkToStage_(
  sheet,
  engineSS,
  config,
  startRow,
  rowCount
) {
  const sheetName =
    sheet.getName();

  const lastColumn =
    sheet.getLastColumn();

  if (
    rowCount < 1 ||
    lastColumn < 1
  ) {
    return;
  }

  const range =
    sheet.getRange(
      startRow,
      1,
      rowCount,
      lastColumn
    );

  const formulas =
    range.getFormulas();

  const displayValues =
    range.getDisplayValues();

  const formulaRows = [];
  const referenceRows = [];
  const externalRows = [];
  const brokenRows = [];

  const delta = {
    populatedCells: 0,
    formulaCells: 0,
    staticCells: 0,
    externalFormulaCount: 0,
    brokenFormulaCount: 0
  };

  for (
    let rowOffset = 0;
    rowOffset < rowCount;
    rowOffset++
  ) {
    for (
      let columnIndex = 0;
      columnIndex < lastColumn;
      columnIndex++
    ) {
      const formula =
        formulas[rowOffset][
          columnIndex
        ];

      const displayValue =
        displayValues[rowOffset][
          columnIndex
        ];

      if (
        formula ||
        displayValue !== ""
      ) {
        delta.populatedCells++;
      }

      if (!formula) {
        if (displayValue !== "") {
          delta.staticCells++;
        }

        continue;
      }

      delta.formulaCells++;

      const actualRow =
        startRow + rowOffset;

      const sourceA1 =
        dependencyOSColumnToLetter_(
          columnIndex + 1
        ) +
        String(actualRow);

      const sourceQualified =
        dependencyOSQualifiedAddress_(
          sheetName,
          sourceA1
        );

      const isExternal =
        dependencyOSIsExternalFormula_(
          formula
        );

      const isBroken =
        dependencyOSIsBrokenFormula_(
          formula,
          displayValue
        );

      formulaRows.push([
        sheetName,
        sourceA1,
        sourceQualified,
        formula,
        displayValue,
        isExternal ? "YES" : "",
        isBroken ? "YES" : ""
      ]);

      if (isExternal) {
        delta.externalFormulaCount++;

        externalRows.push([
          sheetName,
          sourceA1,
          formula,
          dependencyOSExtractImportRangeId_(
            formula
          ),
          dependencyOSExtractImportRangeRange_(
            formula
          )
        ]);
      }

      if (isBroken) {
        delta.brokenFormulaCount++;

        brokenRows.push([
          sheetName,
          sourceA1,
          formula,
          displayValue
        ]);
      }

      dependencyOSExtractFormulaReferences_(
        formula,
        sheetName
      ).forEach(function (reference) {
        referenceRows.push([
          sheetName,
          sourceA1,
          sourceQualified,
          reference.sheet,
          reference.range,
          dependencyOSQualifiedAddress_(
            reference.sheet,
            reference.range
          ),
          reference.relationshipType,
          formula
        ]);
      });
    }
  }

  dependencyOSAppendStageRows_(
    dependencyOSGetStageSheet_(
      engineSS,
      config.stagingSheets
        .formulas
    ),
    formulaRows
  );

  dependencyOSAppendStageRows_(
    dependencyOSGetStageSheet_(
      engineSS,
      config.stagingSheets
        .references
    ),
    referenceRows
  );

  dependencyOSAppendStageRows_(
    dependencyOSGetStageSheet_(
      engineSS,
      config.stagingSheets
        .external
    ),
    externalRows
  );

  dependencyOSAppendStageRows_(
    dependencyOSGetStageSheet_(
      engineSS,
      config.stagingSheets
        .broken
    ),
    brokenRows
  );

  dependencyOSUpdateStageSheetStats_(
    engineSS,
    config,
    sheetName,
    delta
  );
}


function dependencyOSBuildScanFromStage_(
  sourceSS,
  engineSS,
  config,
  state
) {
  const scan =
    dependencyOSCreateEmptyScan_(
      sourceSS
    );

  scan.scannedAt =
    new Date(
      state.startedAt
    );

  const statsSheet =
    dependencyOSGetStageSheet_(
      engineSS,
      config.stagingSheets
        .sheetStats
    );

  if (statsSheet.getLastRow() > 1) {
    statsSheet
      .getRange(
        2,
        1,
        statsSheet.getLastRow() - 1,
        9
      )
      .getValues()
      .forEach(function (row) {
        const sheetName =
          String(row[0] || "");

        if (!sheetName) {
          return;
        }

        scan.sheetStats[
          sheetName
        ] = {
          sheetName: sheetName,
          sheetId:
            Number(row[1] || 0),
          lastRow:
            Number(row[2] || 0),
          lastColumn:
            Number(row[3] || 0),
          populatedCells:
            Number(row[4] || 0),
          formulaCells:
            Number(row[5] || 0),
          staticCells:
            Number(row[6] || 0),
          incomingReferenceCount: 0,
          outgoingReferenceCount: 0,
          incomingSourceCells: {},
          outgoingTargetCells: {},
          externalFormulaCount:
            Number(row[7] || 0),
          brokenFormulaCount:
            Number(row[8] || 0),
          namedRangeCount: 0,
          validationCount: 0,
          formattingRuleCount: 0
        };
      });
  }

  const formulaBySource = {};

  const formulasSheet =
    dependencyOSGetStageSheet_(
      engineSS,
      config.stagingSheets
        .formulas
    );

  if (formulasSheet.getLastRow() > 1) {
    formulasSheet
      .getRange(
        2,
        1,
        formulasSheet.getLastRow() - 1,
        7
      )
      .getValues()
      .forEach(function (row) {
        const record = {
          sourceSheet:
            String(row[0] || ""),
          sourceCell:
            String(row[1] || ""),
          sourceQualified:
            String(row[2] || ""),
          formula:
            dependencyOSRestoreStagedText_(
              row[3]
            ),
          displayValue:
            row[4],
          isExternal:
            String(row[5] || "") === "YES",
          isBroken:
            String(row[6] || "") === "YES",
          references: []
        };

        scan.formulas.push(
          record
        );

        formulaBySource[
          record.sourceQualified
        ] = record;
      });
  }

  const referencesSheet =
    dependencyOSGetStageSheet_(
      engineSS,
      config.stagingSheets
        .references
    );

  if (
    referencesSheet.getLastRow() >
    1
  ) {
    referencesSheet
      .getRange(
        2,
        1,
        referencesSheet.getLastRow() - 1,
        8
      )
      .getValues()
      .forEach(function (row) {
        const relationship = {
          sourceSheet:
            String(row[0] || ""),
          sourceCell:
            String(row[1] || ""),
          sourceQualified:
            String(row[2] || ""),
          targetSheet:
            String(row[3] || ""),
          targetRange:
            String(row[4] || ""),
          targetQualified:
            String(row[5] || ""),
          relationshipType:
            String(row[6] || ""),
          formula:
            dependencyOSRestoreStagedText_(
              row[7]
            )
        };

        scan.references.push(
          relationship
        );

        dependencyOSRegisterReferenceUsage_(
          scan,
          relationship
        );

        if (
          formulaBySource[
            relationship
              .sourceQualified
          ]
        ) {
          formulaBySource[
            relationship
              .sourceQualified
          ].references.push(
            relationship
          );
        }
      });
  }

  const externalSheet =
    dependencyOSGetStageSheet_(
      engineSS,
      config.stagingSheets
        .external
    );

  if (externalSheet.getLastRow() > 1) {
    scan.externalLinks =
      externalSheet
        .getRange(
          2,
          1,
          externalSheet.getLastRow() - 1,
          5
        )
        .getValues()
        .map(function (row) {
          return {
            sourceSheet:
              String(row[0] || ""),
            sourceCell:
              String(row[1] || ""),
            formula:
              dependencyOSRestoreStagedText_(
                row[2]
              ),
            externalId:
              String(row[3] || ""),
            externalRange:
              String(row[4] || "")
          };
        });
  }

  const brokenSheet =
    dependencyOSGetStageSheet_(
      engineSS,
      config.stagingSheets
        .broken
    );

  if (brokenSheet.getLastRow() > 1) {
    scan.brokenFormulas =
      brokenSheet
        .getRange(
          2,
          1,
          brokenSheet.getLastRow() - 1,
          4
        )
        .getValues()
        .map(function (row) {
          return {
            sheet:
              String(row[0] || ""),
            cell:
              String(row[1] || ""),
            formula:
              dependencyOSRestoreStagedText_(
                row[2]
              ),
            displayValue:
              row[3]
          };
        });
  }

  return scan;
}


function dependencyOSRestoreStagedText_(
  value
) {
  const text =
    String(value || "");

  return text.charAt(0) === "'" &&
    /^[=+@]/.test(
      text.substring(1)
    )
      ? text.substring(1)
      : text;
}


function dependencyOSForceClearAllSavedProperties() {
  const properties =
    PropertiesService
      .getDocumentProperties();

  const all =
    properties.getProperties();

  Object.keys(all)
    .filter(function (key) {
      return (
        key.indexOf(
          "DEPENDENCYOS_"
        ) === 0
      );
    })
    .forEach(function (key) {
      properties.deleteProperty(
        key
      );
    });

  dependencyOSDeleteResumeTriggers_();

  SpreadsheetApp
    .getActiveSpreadsheet()
    .toast(
      "DependencyOS saved properties and resume triggers were cleared.",
      "DependencyOS",
      8
    );
}


/* =========================================================
 * FORMULA REFERENCE PARSING
 * ========================================================= */

function dependencyOSExtractFormulaReferences_(formula, currentSheetName) {
  const references = [];
  const seen = {};

  if (!formula) {
    return references;
  }

  /*
   * Matches:
   * 'IN/OUT'!A3
   * 'Performance Report'!A11:G23
   * Weekly!B3
   * $A$3
   * A3:G20
   */
  const qualifiedPattern =
    /(?:'((?:[^']|'')+)'|([A-Za-z0-9_]+))!\$?([A-Z]{1,3})\$?(\d+)(?::\$?([A-Z]{1,3})\$?(\d+))?/gi;

  let qualifiedMatch;

  while ((qualifiedMatch = qualifiedPattern.exec(formula)) !== null) {
    const rawSheetName = qualifiedMatch[1] || qualifiedMatch[2];
    const sheetName = String(rawSheetName).replace(/''/g, "'");

    const startCell =
      qualifiedMatch[3].toUpperCase() + qualifiedMatch[4];

    const endCell = qualifiedMatch[5] && qualifiedMatch[6]
      ? qualifiedMatch[5].toUpperCase() + qualifiedMatch[6]
      : "";

    const targetRange = endCell
      ? startCell + ":" + endCell
      : startCell;

    const key = sheetName + "!" + targetRange;

    if (!seen[key]) {
      seen[key] = true;

      references.push({
        sheet: sheetName,
        range: targetRange,
        relationshipType:
          sheetName === currentSheetName
            ? "Same-sheet formula"
            : "Cross-sheet formula"
      });
    }
  }

  /*
   * Remove qualified references before looking for
   * unqualified same-sheet references.
   */
  const formulaWithoutQualifiedReferences = formula.replace(
    qualifiedPattern,
    " "
  );

  const unqualifiedPattern =
    /(^|[^A-Z0-9_.'"])\$?([A-Z]{1,3})\$?(\d+)(?::\$?([A-Z]{1,3})\$?(\d+))?(?![A-Z0-9_])/gi;

  let unqualifiedMatch;

  while (
    (unqualifiedMatch =
      unqualifiedPattern.exec(formulaWithoutQualifiedReferences)) !== null
  ) {
    const startCell =
      unqualifiedMatch[2].toUpperCase() + unqualifiedMatch[3];

    const endCell = unqualifiedMatch[4] && unqualifiedMatch[5]
      ? unqualifiedMatch[4].toUpperCase() + unqualifiedMatch[5]
      : "";

    const targetRange = endCell
      ? startCell + ":" + endCell
      : startCell;

    const key = currentSheetName + "!" + targetRange;

    if (!seen[key]) {
      seen[key] = true;

      references.push({
        sheet: currentSheetName,
        range: targetRange,
        relationshipType: "Same-sheet formula"
      });
    }
  }

  return references;
}


function dependencyOSRegisterReferenceUsage_(scan, relationship) {
  const targetKey = relationship.targetQualified;

  if (!scan.usageByTarget[targetKey]) {
    scan.usageByTarget[targetKey] = {
      targetSheet: relationship.targetSheet,
      targetRange: relationship.targetRange,
      targetQualified: targetKey,
      usages: [],
      sourceSheets: {}
    };
  }

  scan.usageByTarget[targetKey].usages.push({
    sourceSheet: relationship.sourceSheet,
    sourceCell: relationship.sourceCell,
    sourceQualified: relationship.sourceQualified,
    formula: relationship.formula,
    relationshipType: relationship.relationshipType
  });

  scan.usageByTarget[targetKey].sourceSheets[
    relationship.sourceSheet
  ] = true;

  if (!scan.incomingBySheet[relationship.targetSheet]) {
    scan.incomingBySheet[relationship.targetSheet] = [];
  }

  scan.incomingBySheet[relationship.targetSheet].push(relationship);

  if (!scan.outgoingBySheet[relationship.sourceSheet]) {
    scan.outgoingBySheet[relationship.sourceSheet] = [];
  }

  scan.outgoingBySheet[relationship.sourceSheet].push(relationship);
}


/* =========================================================
 * NAMED RANGES
 * ========================================================= */

function dependencyOSScanNamedRanges_(ss, scan) {
  const namedRanges = ss.getNamedRanges();

  namedRanges.forEach(function (namedRange) {
    const range = namedRange.getRange();
    const sheet = range.getSheet();

    const record = {
      name: namedRange.getName(),
      sheet: sheet.getName(),
      range: range.getA1Notation(),
      qualifiedRange: dependencyOSQualifiedAddress_(
        sheet.getName(),
        range.getA1Notation()
      ),
      formulaUsages: []
    };

    scan.formulas.forEach(function (formulaRecord) {
      if (
        dependencyOSFormulaContainsNamedRange_(
          formulaRecord.formula,
          record.name
        )
      ) {
        record.formulaUsages.push({
          sourceSheet: formulaRecord.sourceSheet,
          sourceCell: formulaRecord.sourceCell,
          sourceQualified: formulaRecord.sourceQualified,
          formula: formulaRecord.formula
        });
      }
    });

    scan.namedRanges.push(record);

    if (scan.sheetStats[record.sheet]) {
      scan.sheetStats[record.sheet].namedRangeCount++;
    }
  });
}


function dependencyOSFormulaContainsNamedRange_(formula, rangeName) {
  if (!formula || !rangeName) {
    return false;
  }

  const escapedName = dependencyOSEscapeRegex_(rangeName);
  const pattern = new RegExp(
    "(^|[^A-Za-z0-9_])" + escapedName + "([^A-Za-z0-9_]|$)",
    "i"
  );

  return pattern.test(formula);
}


/* =========================================================
 * DATA VALIDATION
 * ========================================================= */

function dependencyOSScanValidations_(sheets, scan) {
  sheets.forEach(function (sheet) {
    const lastRow = sheet.getLastRow();
    const lastColumn = sheet.getLastColumn();

    if (lastRow < 1 || lastColumn < 1) {
      return;
    }

    const range = sheet.getRange(1, 1, lastRow, lastColumn);
    const validations = range.getDataValidations();

    for (let rowIndex = 0; rowIndex < lastRow; rowIndex++) {
      for (
        let columnIndex = 0;
        columnIndex < lastColumn;
        columnIndex++
      ) {
        const validation = validations[rowIndex][columnIndex];

        if (!validation) {
          continue;
        }

        const criteriaType = String(validation.getCriteriaType());
        const criteriaValues = validation.getCriteriaValues();

        const destinationCell =
          dependencyOSColumnToLetter_(columnIndex + 1) +
          String(rowIndex + 1);

        const record = {
          destinationSheet: sheet.getName(),
          destinationCell: destinationCell,
          destinationQualified: dependencyOSQualifiedAddress_(
            sheet.getName(),
            destinationCell
          ),
          criteriaType: criteriaType,
          sourceSheet: "",
          sourceRange: "",
          sourceQualified: "",
          details: ""
        };

        if (
          criteriaType.indexOf("VALUE_IN_RANGE") !== -1 &&
          criteriaValues &&
          criteriaValues[0] &&
          typeof criteriaValues[0].getA1Notation === "function"
        ) {
          const sourceRange = criteriaValues[0];

          record.sourceSheet = sourceRange.getSheet().getName();
          record.sourceRange = sourceRange.getA1Notation();
          record.sourceQualified = dependencyOSQualifiedAddress_(
            record.sourceSheet,
            record.sourceRange
          );

          record.details =
            "Dropdown values come from " + record.sourceQualified;
        } else {
          record.details = dependencyOSCriteriaValuesToText_(
            criteriaValues
          );
        }

        scan.validations.push(record);

        if (scan.sheetStats[sheet.getName()]) {
          scan.sheetStats[sheet.getName()].validationCount++;
        }
      }
    }
  });
}


function dependencyOSCriteriaValuesToText_(criteriaValues) {
  if (!criteriaValues || !criteriaValues.length) {
    return "";
  }

  return criteriaValues
    .map(function (value) {
      if (value === null || value === undefined) {
        return "";
      }

      if (
        value &&
        typeof value.getA1Notation === "function" &&
        typeof value.getSheet === "function"
      ) {
        return dependencyOSQualifiedAddress_(
          value.getSheet().getName(),
          value.getA1Notation()
        );
      }

      if (value instanceof Date) {
        return Utilities.formatDate(
          value,
          Session.getScriptTimeZone(),
          "yyyy-MM-dd HH:mm:ss"
        );
      }

      if (Array.isArray(value)) {
        return value.join(", ");
      }

      return String(value);
    })
    .join(" | ");
}


/* =========================================================
 * CONDITIONAL FORMATTING
 * ========================================================= */

function dependencyOSScanConditionalFormatting_(sheets, scan) {
  sheets.forEach(function (sheet) {
    const rules = sheet.getConditionalFormatRules();

    rules.forEach(function (rule, ruleIndex) {
      const ranges = rule.getRanges().map(function (range) {
        return range.getA1Notation();
      });

      const booleanCondition = rule.getBooleanCondition();
      const gradientCondition = rule.getGradientCondition();

      let criteriaType = "";
      let criteriaValues = "";
      let formulaReferences = [];

      if (booleanCondition) {
        criteriaType = String(booleanCondition.getCriteriaType());

        const rawValues = booleanCondition.getCriteriaValues();

        criteriaValues = dependencyOSCriteriaValuesToText_(rawValues);

        rawValues.forEach(function (value) {
          if (
            typeof value === "string" &&
            value.charAt(0) === "="
          ) {
            const references =
              dependencyOSExtractFormulaReferences_(
                value,
                sheet.getName()
              );

            formulaReferences =
              formulaReferences.concat(references);
          }
        });
      } else if (gradientCondition) {
        criteriaType = "GRADIENT";
        criteriaValues = "Color scale";
      }

      const record = {
        sheet: sheet.getName(),
        ruleNumber: ruleIndex + 1,
        appliesTo: ranges.join(", "),
        criteriaType: criteriaType,
        criteriaValues: criteriaValues,
        referenceTargets: formulaReferences
          .map(function (reference) {
            return dependencyOSQualifiedAddress_(
              reference.sheet,
              reference.range
            );
          })
          .join(", ")
      };

      scan.formattingRules.push(record);

      if (scan.sheetStats[sheet.getName()]) {
        scan.sheetStats[sheet.getName()].formattingRuleCount++;
      }
    });
  });
}


/* =========================================================
 * RELATIONSHIP FINALIZATION
 * ========================================================= */

function dependencyOSFinalizeSheetRelationships_(scan) {
  Object.keys(scan.sheetStats).forEach(function (sheetName) {
    const stats = scan.sheetStats[sheetName];

    const incoming = scan.incomingBySheet[sheetName] || [];
    const outgoing = scan.outgoingBySheet[sheetName] || [];

    stats.incomingReferenceCount = incoming.length;
    stats.outgoingReferenceCount = outgoing.length;

    incoming.forEach(function (relationship) {
      stats.incomingSourceCells[
        relationship.sourceQualified
      ] = true;
    });

    outgoing.forEach(function (relationship) {
      stats.outgoingTargetCells[
        relationship.targetQualified
      ] = true;
    });
  });
}


/* =========================================================
 * SUMMARY REPORT
 * ========================================================= */

function dependencyOSWriteSummary_(
  ss,
  config,
  scan,
  startedAt
) {
  const sheet = dependencyOSGetOrCreateReportSheet_(
    ss,
    config.reportSheets.summary
  );

  sheet.clear();

  const elapsedSeconds =
    ((Date.now() - startedAt) / 1000).toFixed(1);

  const usageTargets = Object.keys(scan.usageByTarget);

  const highImpactTargets = usageTargets.filter(function (targetKey) {
    return (
      scan.usageByTarget[targetKey].usages.length >=
      config.highUsageThreshold
    );
  });

  const crossSheetReferences = scan.references.filter(
    function (reference) {
      return reference.sourceSheet !== reference.targetSheet;
    }
  );

  const data = [
    ["DependencyOS Workbook Audit", ""],
    ["Workbook", scan.spreadsheetName],
    ["Version", config.version],
    ["Scanned At", scan.scannedAt],
    ["Run Time", elapsedSeconds + " seconds"],
    ["", ""],

    ["Workbook Totals", ""],
    ["Sheets Scanned", Object.keys(scan.sheetStats).length],
    ["Formula Cells", scan.formulas.length],
    ["Formula References", scan.references.length],
    ["Cross-Sheet References", crossSheetReferences.length],
    ["Unique Referenced Targets", usageTargets.length],
    ["Named Ranges", scan.namedRanges.length],
    ["Data Validations", scan.validations.length],
    ["Conditional Formatting Rules", scan.formattingRules.length],
    ["External Spreadsheet Formulas", scan.externalLinks.length],
    ["Broken Formulas", scan.brokenFormulas.length],
    ["High-Impact Targets", highImpactTargets.length],
    ["", ""],

    ["What These Reports Mean", ""],
    [
      "Dependency Formula Map",
      "Every formula and the sheet/cell or range it reads."
    ],
    [
      "Source of Truth Audit",
      "A formula-topology estimate of which tabs act as sources, processors, outputs, or mixed-use tabs."
    ],
    [
      "Dependency Risk Report",
      "High-impact ranges, broken formulas, external links, and duplicated architecture concerns."
    ],
    [
      "Dependency Cell Inspector",
      "Select a cell anywhere in the workbook and run Inspect Selected Cell."
    ],
    ["", ""],

    ["Important Limitation", ""],
    [
      "Apps Script Source",
      "Version 0.3 scans the workbook. It does not yet read the source code inside .gs or .html files."
    ],
    [
      "Dynamic References",
      "INDIRECT, OFFSET, dynamically constructed addresses, and script-generated ranges may require manual review."
    ]
  ];

  sheet.getRange(1, 1, data.length, 2).setValues(data);

  sheet.getRange("A1:B1").merge();
  sheet.getRange("A1").setValue("DependencyOS Workbook Audit");

