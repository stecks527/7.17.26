/*************************************************
 * 07 SHOWSTATEOS
 * Version: 4.1.0
 * Status: ACTIVE
 *
 * Canonical public API for current production state.
 *************************************************/

function ShowStateOS() {
  return {
    current: function () {
      return buildShowState();
    },

    get: function () {
      return buildShowState();
    },

    refresh: function () {
      clearShowStateOSCache();
      return buildShowState();
    },

    clearCache: function () {
      return clearShowStateOSCache();
    },

    clearAllCaches: function () {
      if (
        typeof clearShowStateAndConductorCaches ===
        "function"
      ) {
        return clearShowStateAndConductorCaches();
      }

      return clearShowStateOSCache();
    },

    status: function () {
      return showStateOSStatus_();
    },

    test: function () {
      return testShowStateOSPlatformAPI();
    }
  };
}


/*************************************************
 * STATUS
 *************************************************/

function showStateOSStatus_() {
  const startedAt = Date.now();

  let state = null;
  let error = "";

  try {
    state = buildShowState();
  } catch (err) {
    error = String(
      err && err.message
        ? err.message
        : err
    );
  }

  const performances =
    state &&
    Array.isArray(state.performances)
      ? state.performances
      : [];

  const assignments =
    state && state.assignments
      ? state.assignments
      : {};

  const intelligence =
    state && state.intelligence
      ? state.intelligence
      : {};

  const assignmentTracks =
    Array.isArray(assignments.tracks)
      ? assignments.tracks
      : [];

  const plannedOuts =
    Array.isArray(intelligence.plannedOuts)
      ? intelligence.plannedOuts
      : [];

  return {
    system: "ShowStateOS",
    version: "4.1.0",
    available: Boolean(state),

    healthy: Boolean(
      state &&
      state.date &&
      performances.length
    ),

    error: error,

    date: state
      ? (
          state.prettyDate ||
          state.date ||
          ""
        )
      : "",

    weeklyName: state
      ? state.weeklyName || ""
      : "",

    performances: performances.length,
    assignmentTracks: assignmentTracks.length,
    plannedOuts: plannedOuts.length,

    selectedIndex:
      state &&
      state.selectedIndex !== undefined
        ? state.selectedIndex
        : null,

    buildDurationMs:
      Date.now() - startedAt,

    cacheAvailable:
      typeof showStateGetCachedState_ ===
      "function",

    conductorCacheAvailable:
      typeof getExpandedCalendarConductorMap_ ===
      "function",

    intelligenceAvailable:
      typeof addPrepIntelligenceToShowState_ ===
      "function"
  };
}


/*************************************************
 * PLATFORM API TEST
 *************************************************/

function testShowStateOSPlatformAPI() {
  const os = ShowStateOS();

  const requiredMethods = [
    "current",
    "get",
    "refresh",
    "clearCache",
    "clearAllCaches",
    "status",
    "test"
  ];

  const missingMethods =
    requiredMethods.filter(
      function (methodName) {
        return (
          typeof os[methodName] !==
          "function"
        );
      }
    );

  const state = os.current();
  const status = os.status();

  const result = {
    healthy:
      status.healthy &&
      missingMethods.length === 0,

    methodsChecked:
      requiredMethods.length,

    missingMethods:
      missingMethods,

    date:
      status.date,

    weeklyName:
      status.weeklyName,

    performances:
      status.performances,

    assignmentTracks:
      status.assignmentTracks,

    plannedOuts:
      status.plannedOuts,

    selectedIndex:
      status.selectedIndex,

    buildDurationMs:
      status.buildDurationMs,

    stateAvailable:
      Boolean(state),

    cacheAvailable:
      status.cacheAvailable,

    conductorCacheAvailable:
      status.conductorCacheAvailable,

    intelligenceAvailable:
      status.intelligenceAvailable
  };

  Logger.log(
    "SHOWSTATEOS PLATFORM API TEST"
  );

  Logger.log(
    JSON.stringify(
      result,
      null,
      2
    )
  );

  SpreadsheetApp
    .getUi()
    .alert(
      "ShowStateOS platform API test " +
      (
        result.healthy
          ? "passed."
          : "found issues."
      ) +
      "\n\n" +
      "Methods checked: " +
      result.methodsChecked +
      "\n" +
      "Missing methods: " +
      result.missingMethods.length +
      "\n" +
      "Date: " +
      result.date +
      "\n" +
      "Performances: " +
      result.performances +
      "\n" +
      "Assignment tracks: " +
      result.assignmentTracks +
      "\n" +
      "Planned outs: " +
      result.plannedOuts +
      "\n\n" +
      "Build duration: " +
      result.buildDurationMs +
      " ms"
    );

  return result;
}


/*************************************************
