let PREP_SETTINGS_CACHE_ = null;

function getPrepSettings_() {
  if (PREP_SETTINGS_CACHE_) return PREP_SETTINGS_CACHE_;

  const dollarFridayValue =
    typeof SettingsCacheOS === "function"
      ? SettingsCacheOS().get("Dollar Friday")
      : "";

  PREP_SETTINGS_CACHE_ = {
    dollarFriday: String(dollarFridayValue || "TRUE").toUpperCase() !== "FALSE"
  };

  return PREP_SETTINGS_CACHE_;
}

function getDollarFridayNote_(targetDate, settings) {
  if (!settings || !settings.dollarFriday) return "";

  const day = Utilities.formatDate(targetDate, Session.getScriptTimeZone(), "EEEE");
  if (day !== "Friday") return "";

  return "- It’s Dollar Friday! You know what to do! Venmo or Cash to RZ. We will draw the winner after the show";
}

function getInOutFolderId_() {
  const value = getPrepSettingValue_("In/Out Folder") || getPrepSettingValue_("inOutFolder");
  if (!value) throw new Error('Could not find "In/Out Folder" in Production Settings.');
  return extractDriveIdLocal_(value);
}

function getPrepSettingValue_(label) {
  if (typeof SettingsCacheOS === "function") {
    return SettingsCacheOS().get(label);
  }

  const sh = SpreadsheetApp.getActiveSpreadsheet().getSheetByName("Production Settings");
  if (!sh) return "";

  const values = sh.getDataRange().getDisplayValues();
  const wanted = String(label || "").toLowerCase().trim();

  for (let i = 0; i < values.length; i++) {
    if (String(values[i][0] || "").toLowerCase().trim() === wanted) {
      return String(values[i][1] || "").trim();
    }
  }

  return "";
}

function matchRoleFromCastList_(roleText, rolesByKey) {
  const key = cleanKey_(roleText);
  if (rolesByKey[key]) return rolesByKey[key];

  const looseKey = Object.keys(rolesByKey).find(k => k.includes(key) || key.includes(k));
  return looseKey ? rolesByKey[looseKey] : roleText;
}

function matchActorNameFromCastList_(nameText, actors) {
  const cleaned = clean_(nameText);
  if (!cleaned) return "";

  const exact = actors.find(name => clean_(name).toLowerCase() === cleaned.toLowerCase());
  if (exact) return exact;

  const parts = cleaned.replace(/\./g, "").split(/\s+/);
  const first = parts[0] || "";
  const lastInitial = parts.length > 1 ? parts[parts.length - 1].charAt(0).toLowerCase() : "";

  if (first && lastInitial) {
    const matched = actors.find(fullName => {
      const fullParts = clean_(fullName).split(/\s+/);
      const fullFirst = fullParts[0] || "";
      const fullLast = fullParts[fullParts.length - 1] || "";

      return fullFirst.toLowerCase() === first.toLowerCase() &&
        fullLast.charAt(0).toLowerCase() === lastInitial;
    });

    if (matched) return matched;
  }

  return cleaned;
}

function dedupeCastOutRows_(rows) {
  const seen = {};

  return rows.filter(row => {
    const key = [row.out, row.in, row.role].join("|").toLowerCase();
    if (seen[key]) return false;

    seen[key] = true;
    return true;
  });
}


function findDayEnd_(values, dayStart) {
  const dayNames = ["MONDAY", "TUESDAY", "WEDNESDAY", "THURSDAY", "FRIDAY", "SATURDAY", "SUNDAY"];

  for (let r = dayStart + 1; r < values.length; r++) {
    const rowText = normalizeWeeklyText_(values[r].slice(0, 5).join(" "));
    if (dayNames.some(day => rowText.includes(day))) return r;
  }

  return values.length;
}

function parseInOutDate_(dateText) {
  if (!dateText) return null;

  const text = clean_(dateText);

  if (/\b20\d{2}\b/.test(text)) {
    const dateWithYear = new Date(text);
    return isNaN(dateWithYear.getTime()) ? null : dateWithYear;
  }

  const year = getPrepShowYear_();
  const dateWithYear = new Date(text + ", " + year);

  return isNaN(dateWithYear.getTime()) ? null : dateWithYear;
}

function getPrepYearForDateText_(dateText) {
  const start = new Date().getTime();

  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const normalizedDate = normalizeWeeklyText_(dateText);

  const sheets = ss.getSheets().filter(sheet =>
    sheet.getName().toLowerCase().includes("weekly schedule")
  );

  Logger.log("Weekly sheets found: " + sheets.length);

  for (const sheet of sheets) {
    const values = sheet.getDataRange().getDisplayValues();

    for (let r = 0; r < values.length; r++) {
      const rowText = values[r].slice(0, 5).join(" ");
      const normalizedRow = normalizeWeeklyText_(rowText);

      if (normalizedRow.includes(normalizedDate)) {
        Logger.log(
          "Year lookup: " +
          (new Date().getTime() - start) +
          "ms"
        );

        const yearFromRow = rowText.match(/\b(20\d{2})\b/);
        if (yearFromRow) return Number(yearFromRow[1]);

        const yearFromName = sheet.getName().match(/\b\d{1,2}\.\d{1,2}\.(\d{2})\b/);
        if (yearFromName) return 2000 + Number(yearFromName[1]);
      }
    }
  }

  Logger.log(
    "Year lookup (fallback): " +
    (new Date().getTime() - start) +
    "ms"
  );

  return getPrepShowYear_();
}

function getPerformanceNumber_(text) {
  const match = String(text || "").match(/PERFORMANCE\s*#?\s*(\d+)/i);
  return match ? match[1] : "";
}

function cleanPerformanceTime_(value) {
  return String(value || "")
    .replace(/\s+/g, " ")
    .replace(/(\d)(AM|PM)/gi, "$1 $2")
    .trim();
}

function findTimeNearPerformanceRow_(values, performanceRow) {
  for (let r = performanceRow; r >= Math.max(0, performanceRow - 3); r--) {
    const possibleTime = String(values[r][0] || "").trim();
    if (/\d{1,2}:\d{2}\s*(AM|PM)?/i.test(possibleTime)) return possibleTime;
  }

  return "";
}

function extractHolidayFromHeader_(headerText) {
  const text = String(headerText || "").trim();
  const parts = text.split(" - ");
  const possibleHoliday = clean_(parts[parts.length - 1]);

  if (!possibleHoliday) return "";
  if (possibleHoliday.toUpperCase().includes("PERFORMANCE")) return "";
  if (/^\d{1,2}:\d{2}/.test(possibleHoliday)) return "";

  return possibleHoliday;
}

function uniqueSorted_(values) {
  return [...new Set(values.filter(Boolean))].sort();
}

function extractDriveIdLocal_(input) {
  const text = String(input || "").trim();
  const match = text.match(/[-\w]{25,}/);
  return match ? match[0] : text;
}

function normalizeWeeklyText_(value) {
  return String(value || "")
    .toUpperCase()
    .replace(/,/g, "")
    .replace(/\s+/g, " ")
    .trim();
}

function titleCase_(value) {
  return String(value || "")
    .toLowerCase()
    .replace(/\b\w/g, c => c.toUpperCase());
}

function clean_(value) {
  return String(value || "")
    .replace(/\s+/g, " ")
    .trim();
}

function cleanKey_(value) {
  return clean_(value)
    .replace(/\.+/g, "")
    .toLowerCase()
    .trim();
}

function getPrepShowYear_() {
  const value =
    getPrepSettingValue_("Show Year") ||
    getPrepSettingValue_("Production Year") ||
    getPrepSettingValue_("Year");

  const year = Number(value);
  return year || new Date().getFullYear();
}
