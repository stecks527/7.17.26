/*************************************************
 * 30 REPORT DECISION OS
 * Version: 1.0.0
 * Status: ACTIVE / CANONICAL
 *
 * Rich Performance Report reset preview.
 *
 * Responsibilities:
 * - Build a report-shaped preview model
 * - Show every note section in report order
 * - Allow individual notes to be kept or reset
 * - Run the canonical ReportResetOS pipeline
 * - Restore only selected notes safely
 * - Merge restored notes with any fresh IN/OUT notes
 *************************************************/


/* =========================================================
 * PUBLIC API
 * ========================================================= */

function ReportDecisionOS() {
  return {
    openResetPreview:
      reportDecisionOpenResetPreview_,

    current:
      reportDecisionBuildResetDecision_,

    run:
      reportOSRunResetWithDecision
  };
}


/* =========================================================
 * PUBLIC ENTRY POINTS
 * ========================================================= */

function reportDecisionResetAuto_TEST() {
  return ReportDecisionOS()
    .openResetPreview(
      "AUTO"
    );
}


function reportDecisionOpenResetPreviewFromPrep() {
  ReportDecisionOS()
    .openResetPreview(
      "AUTO"
    );

  return {
    success:
      true,

    message:
      "Report Reset Preview opened."
  };
}


