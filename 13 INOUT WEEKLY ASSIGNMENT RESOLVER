function testResolveAssignedCoverFromWeeklyToday() {
  const ui = SpreadsheetApp.getUi();
  const ss = SpreadsheetApp.getActive();
  const inOut = ss.getSheetByName("IN/OUT");

  const targetDate = parseInOutDate_(inOut.getRange("A3").getDisplayValue());

  const res = ui.prompt("Character?", "Example: Barfée", ui.ButtonSet.OK_CANCEL);
  if (res.getSelectedButton() !== ui.Button.OK) return;

  const role = res.getResponseText().trim();
  const cover = resolveAssignedCoverFromWeekly_(targetDate, role);

  ui.alert(
    "Weekly assigned cover for " + role + ":\n\n" +
    (cover || "None found")
  );
}

function debugWeeklyCoverLinesToday() {
  const ss = SpreadsheetApp.getActive();
  const inOut = ss.getSheetByName("IN/OUT");
  const targetDate = parseInOutDate_(inOut.getRange("A3").getDisplayValue());

  const block = findWeeklyBlockForDate_(targetDate);

  if (!block) {
    SpreadsheetApp.getUi().alert("No weekly block found for IN/OUT!A3.");
    return;
  }

  const lines = [];

  for (let r = block.dayStart; r < block.dayEnd; r++) {
    const rowText = block.values[r].join(" | ").replace(/\s+/g, " ").trim();

    if (
      rowText.toUpperCase().includes(" OUT") ||
      rowText.includes("=")
    ) {
      lines.push((r + 1) + ": " + rowText);
    }
  }

  SpreadsheetApp.getUi().alert(
    "Weekly sheet: " + block.sheet.getName() + "\n\n" +
    (lines.length ? lines.join("\n") : "No possible cover lines found.")
  );
}
