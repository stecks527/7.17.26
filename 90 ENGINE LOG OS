  EngineLogOS().diagnostic(
    "EngineLogOS",
    "Test Metric",
    1,
    "EngineLogOS diagnostic test successful."
  );

  SpreadsheetApp.getUi().alert("EngineLogOS diagnostic test complete.");
}
