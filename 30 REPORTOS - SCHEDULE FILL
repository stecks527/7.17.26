function testReportScheduleRules() {
  const ss =
    SpreadsheetApp
      .getActiveSpreadsheet();

  const reportBuilder =
    ss.getSheetByName(
      "Report Builder"
    );

  const report =
    ss.getSheetByName(
      "Performance Report"
    );

  const context =
    reportScheduleGetTargetContext_(
      ss,
      reportBuilder,
      {}
    );

  const upcoming =
    getUpcomingSchedule_(
      ss,
      context.date,
      context.label
    );

  const rows =
    reportScheduleResolveUpcomingRows_(
      report
    );

  const result = {
    source:
      context.source,

    performanceType:
      context.type,

    targetLabel:
      context.label,

    upcomingHeaderDate:
      upcoming.headerDate,

    upcomingFinal:
      upcoming.final,

    upcomingRows:
      rows,

    separatorVisibleLines:
      buildReportScheduleBlock_(
        "FIRST SECTION",
        "SECOND SECTION"
      ).split("\n")
  };

  Logger.log(
    "REPORT SCHEDULE RULES TEST"
  );

  Logger.log(
    JSON.stringify(
      result,
      null,
      2
    )
  );

  SpreadsheetApp
    .getUi()
    .alert(
      "Report schedule rules checked.\n\n" +
      "Type: " +
      result.performanceType +
      "\nUpcoming date: " +
      result.upcomingHeaderDate +
      "\nUpcoming date row: " +
      result.upcomingRows.dateRow +
      "\nUpcoming schedule row: " +
      result.upcomingRows.scheduleRow
    );

  return result;
}
