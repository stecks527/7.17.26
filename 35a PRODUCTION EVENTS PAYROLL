/*************************************************
 * DIAGNOSTIC — UNDERSTUDY PAYROLL READING
 *************************************************/

function diagnoseUnderstudyPayrollRows() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const payroll = ss.getSheetByName("Payroll");
  const castList = ss.getSheetByName("Cast List");

  if (!payroll) {
    throw new Error('Could not find the "Payroll" sheet.');
  }

  if (!castList) {
    throw new Error('Could not find the "Cast List" sheet.');
  }

  const actorMap =
    productionEventsActorMapV1_(castList);

  const dateDisplays =
    payroll.getRange("B3:H3").getDisplayValues()[0];

  const people =
    productionEventsReadPayrollPeopleV1_(
      payroll,
      dateDisplays,
      actorMap
    );

  Logger.log("====================================");
  Logger.log("UNDERSTUDY / SWING PAYROLL DIAGNOSTIC");
  Logger.log("People read: " + people.length);
  Logger.log("====================================");

  people.forEach(function(person) {
    const role = String(person.role || "");
    const roleLower = role.toLowerCase();

    const isPossibleUnderstudy =
      roleLower.includes("swing") ||
      roleLower.includes("understudy") ||
      roleLower.includes("u/s") ||
      roleLower === "us";

    /*
     * Also include anyone with an OUT so we can catch
     * an understudy whose Cast List role is missing or unexpected.
     */
    const hasOutText =
      JSON.stringify(person.block || [])
        .toUpperCase()
        .includes("OUT");

    if (!isPossibleUnderstudy && !hasOutText) {
      return;
    }

    Logger.log("------------------------------------");
    Logger.log("NAME: " + person.name);
    Logger.log("ROLE: " + person.role);
    Logger.log("ROLE KEY: " + person.roleKey);
    Logger.log(
      "RAW BLOCK: " +
      JSON.stringify(person.block)
    );
    Logger.log(
      "PARSED OUT: " +
      JSON.stringify(person.out)
    );
    Logger.log(
      "PERSON EVENTS: " +
      JSON.stringify(person.events)
    );
  });

  const engineEvents =
    ProductionEventsEngineV1_().events();

  Logger.log("====================================");
  Logger.log("FINAL OUT EVENTS");
  Logger.log("====================================");

  engineEvents.forEach(function(event) {
    if (
      event.type === "ACTOR_OUT" ||
      event.type === "ACTOR_OUT_COVERAGE" ||
      event.type === "UNDERSTUDY_OUT"
    ) {
      Logger.log(JSON.stringify(event));
    }
  });
}
