/* =========================================================
 * SAFE ACCESSORS
 * ========================================================= */

function getStageOSSheetSafe_(
  sheetKey
) {
  try {
    return getStageOSSheet(
      sheetKey
    );
  } catch (err) {
    return null;
  }
}

function getStageOSPerformanceNumber_(
  text
) {
  if (
    typeof getPerformanceNumber_ ===
    "function"
  ) {
    return getPerformanceNumber_(text);
  }

  const match =
    String(text || "")
      .match(
        /PERFORMANCE\s*#?\s*(\d+)/i
      );

  return match
    ? match[1]
    : "";
}

function getStageOSIsDollarFriday_(
  dateText
) {
  if (
    !stageOSBoolean_(
      "dollarFriday",
      true
    )
  ) {
    return false;
  }

  let date = null;

  if (
    typeof parseInOutDate_ ===
    "function"
  ) {
    date =
      parseInOutDate_(dateText);
  } else {
    date =
      new Date(dateText);
  }

  if (
    !date ||
    isNaN(date.getTime())
  ) {
    return false;
  }

  return (
    Utilities.formatDate(
      date,
      Session.getScriptTimeZone(),
      "EEEE"
    ) === "Friday"
  );
}

function buildStageOSGuestDateTime_(
  dateText,
  performanceText
) {
  const date =
    typeof parseInOutDate_ ===
      "function"
      ? parseInOutDate_(dateText)
      : new Date(dateText);

  const monthDay =
    date &&
    !isNaN(date.getTime())
      ? Utilities.formatDate(
          date,
          Session.getScriptTimeZone(),
          "MMMM d"
        ).toUpperCase()
      : String(
          dateText || ""
        ).toUpperCase();

  const timeMatch =
    String(performanceText || "")
      .match(
        /(\d{1,2}:\d{2})\s*(AM|PM)?/i
      );

  const timeText =
    timeMatch
      ? (
          timeMatch[1] +
          (timeMatch[2] || "PM")
        )
          .replace(/\s+/g, "")
          .toUpperCase()
      : "";

  return timeText
    ? monthDay +
        ", " +
        timeText +
        ":"
    : monthDay + ":";
}


/* =========================================================
 * SYSTEM AVAILABILITY / STATUS
 * ========================================================= */

function stageOSSystemAvailable_(
  systemName
) {
  const map = {
    home:
      typeof HomeOS ===
      "function",

    showState:
      typeof buildShowState ===
      "function",

    decision:
      typeof DecisionOS ===
      "function",

    snapshot:
      typeof SnapshotOSv2 ===
      "function",

    resolver:
      typeof CastResolverOS ===
      "function",

    assignments:
      typeof AssignmentOS ===
      "function",

    engine:
      typeof EngineOS ===
      "function",

    engineQuery:
      typeof EngineQueryOS ===
      "function",

    cache:
      typeof StageCacheOS ===
      "function",

    workflow:
      typeof WorkflowStatusOS ===
      "function",

    operations:
      typeof OperationsOS ===
      "function",

    productionEvents:
      typeof ProductionEventsOS ===
      "function",

    weekly:
      typeof WeeklyOS ===
        "function" ||
      typeof WeeklyCacheOS ===
        "function"
  };

  const key =
    String(systemName || "")
      .trim();

  return Boolean(map[key]);
}

function stageOSBuildAPIStatus_(
  api
) {
  const systems = [
    "home",
    "showState",
    "decision",
    "snapshot",
    "resolver",
    "assignments",
    "engine",
    "engineQuery",
    "cache",
    "workflow",
    "operations",
    "productionEvents",
    "weekly"
  ];

  const available = {};

  systems.forEach(function (
    system
  ) {
    available[system] =
      api.available(system);
  });

  return {
    name: api.name(),
    version: api.version(),
    build: api.build(),
    workbook:
      api.workbook().getName(),
    systems: available
  };
}


/* =========================================================
 * KERNEL COMPATIBILITY
 *
 * StageOSKernel() now redirects into StageOS().
 * ========================================================= */

function StageOSKernel() {
  const stage = StageOS();

  return {
    version: function () {
      return stage.version();
    },

    build: function () {
      return stage.build();
    },

    workbook: function () {
      return stage.workbook();
    }
  };
}


/* =========================================================
 * TESTS
 * ========================================================= */

function testStageOSAPI() {
  const stage = StageOS();
  const status =
    stage.status();

  const results = {
    status: status,

    productionName:
      stage.setting(
        "productionName",
        ""
      ),

    payrollSheet:
      stage
        .sheet("payroll")
        .getName(),

    inOutSheet:
      stage
        .sheet("inOut")
        .getName(),

    current:
      stage.current(),

    engineConnected:
      stage.engine()
        ? stage.engine()
            .status()
            .connected
        : false,

    productionEventsAvailable:
      stage.available(
        "productionEvents"
      )
  };

  Logger.log(
    "STAGEOS API TEST"
  );

  Logger.log(
    JSON.stringify(
      results,
      null,
      2
    )
  );

  SpreadsheetApp.getUi().alert(
    "StageOS API test passed.\n\n" +
    "Version: " +
    status.version +
    "\n" +
    "Workbook: " +
    status.workbook +
    "\n" +
    "Payroll: " +
    results.payrollSheet +
    "\n" +
    "Engine connected: " +
    results.engineConnected
  );

  return results;
}

