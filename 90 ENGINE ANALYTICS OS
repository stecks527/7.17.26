    category: "Resolver",
    notes: ""
  });

  return metrics;
}

/*************************************************
 * CACHE METRICS
 *************************************************/

function engineAnalyticsOSBuildCacheMetrics_() {
  if (typeof StageCacheOS !== "function") {
    return [{
      metric: "StageCacheOS Available",
      value: "NO",
      category: "Cache",
      notes: ""
    }];
  }

  const status = StageCacheOS().status();

  const populated = status.filter(item => item.exists).length;
  const totalSize = status.reduce((sum, item) => sum + Number(item.size || 0), 0);

  return [
    {
      metric: "Caches Known",
      value: status.length,
      category: "Cache",
      notes: ""
    },
    {
      metric: "Caches Populated",
      value: populated,
      category: "Cache",
      notes: ""
    },
    {
      metric: "Cache Total Size",
      value: totalSize,
      category: "Cache",
      notes: "DocumentProperties characters"
    }
  ];
}

/*************************************************
 * HELPERS
 *************************************************/

function engineAnalyticsOSReadSheet_(keyOrName) {
  try {
    return EngineOS().sheet(keyOrName, { create: false }).values();
  } catch (err) {
    return [];
  }
}

function engineAnalyticsOSRowsToObjects_(rows) {
  if (!rows || rows.length < 2) return [];

  const headers = rows[0];

  return rows.slice(1).filter(row => row.some(Boolean)).map(row => {
    const obj = {};

    headers.forEach((header, i) => {
      obj[String(header || "").trim()] = row[i];
    });

    return obj;
  });
}

function engineAnalyticsOSUniqueFromRows_(rows, headerName) {
  if (!rows || rows.length < 2) return [];

  const headers = rows[0].map(h => String(h || "").trim());
  const index = headers.indexOf(headerName);

  if (index === -1) return [];

  return [...new Set(
    rows.slice(1)
      .map(row => String(row[index] || "").trim())
      .filter(Boolean)
  )];
}
