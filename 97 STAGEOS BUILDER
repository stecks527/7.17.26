 *************************************************/

function seedMissingStageOSTasks() {
  const tracker = getStageOSProjectTracker_();
  const roadmap = tracker.getSheetByName(STAGEOS_PROJECT_TRACKER.roadmapSheet);

  const existingIds = roadmap
    .getDataRange()
    .getDisplayValues()
    .slice(1)
    .map(row => String(row[0] || "").trim())
    .filter(Boolean);

  const existingSet = new Set(existingIds);
  const seedRows = getStageOSRoadmapSeedRows_();

  let added = 0;

  seedRows.forEach(row => {
    const taskId = String(row[0] || "").trim();
    if (!taskId || existingSet.has(taskId)) return;

    roadmap.appendRow(row);
    added++;
  });

  sortStageOSRoadmap_(roadmap);
  roadmap.autoResizeColumns(1, 12);
  refreshStageOSBuilderSilent_();

  SpreadsheetApp.getUi().alert(
    "Seed missing tasks complete.\n\nAdded: " + added
  );
}

function completeStageOSTaskBySearchPrompt() {
  const ui = SpreadsheetApp.getUi();

  const response = ui.prompt(
    "Complete StageOS Task",
    "Type part of the task name or task ID:",
    ui.ButtonSet.OK_CANCEL
  );

  if (response.getSelectedButton() !== ui.Button.OK) return;

  const search = response.getResponseText().trim();
  if (!search) return;

  const matches = findStageOSTaskMatches_(search);

  if (!matches.length) {
    ui.alert("No matching tasks found.");
    return;
  }

  if (matches.length > 10) {
    ui.alert(
      "Too many matches found.\n\nTry a more specific search."
    );
    return;
  }

  const message =
    "Matching tasks:\n\n" +
    matches.map((task, index) =>
      (index + 1) + ". " + task.taskId + " — " + task.task
    ).join("\n") +
    "\n\nEnter the number to complete:";

  const choice = ui.prompt(
    "Choose Task",
    message,
    ui.ButtonSet.OK_CANCEL
  );

  if (choice.getSelectedButton() !== ui.Button.OK) return;

  const index = Number(choice.getResponseText()) - 1;
  if (isNaN(index) || !matches[index]) {
    ui.alert("Invalid selection.");
    return;
  }

  const notes = ui.prompt(
    "Completion Notes",
    "Optional notes:",
    ui.ButtonSet.OK_CANCEL
  );

  completeStageOSTask(
    matches[index].taskId,
    notes.getSelectedButton() === ui.Button.OK ? notes.getResponseText() : ""
  );

  ui.alert("Task completed:\n\n" + matches[index].task);
}

function findStageOSTaskMatches_(searchText) {
  const tracker = getStageOSProjectTracker_();
  const roadmap = tracker.getSheetByName(STAGEOS_PROJECT_TRACKER.roadmapSheet);
  const values = roadmap.getDataRange().getDisplayValues();

  const search = String(searchText || "").toLowerCase().trim();

  return values.slice(1)
    .filter(row => row[0])
    .filter(row => String(row[4] || "") !== "Complete")
    .map(row => ({
      taskId: String(row[0] || "").trim(),
      phase: row[1],
      subsystem: row[2],
      task: row[3],
      status: row[4],
      priority: row[5]
    }))
    .filter(task => {
      const blob = [
        task.taskId,
        task.phase,
        task.subsystem,
        task.task,
        task.status,
        task.priority
      ].join(" ").toLowerCase();

      return blob.includes(search);
    });
}

function setStageOSTaskStatusPrompt() {
  const ui = SpreadsheetApp.getUi();

  const taskResponse = ui.prompt(
    "Update Task Status",
    "Enter task ID:",
    ui.ButtonSet.OK_CANCEL
  );

  if (taskResponse.getSelectedButton() !== ui.Button.OK) return;

  const taskId = taskResponse.getResponseText().trim();
  if (!taskId) return;

  const statusResponse = ui.prompt(
    "New Status",
    "Enter one: Backlog, In Progress, Testing, Complete, Paused",
    ui.ButtonSet.OK_CANCEL
  );

  if (statusResponse.getSelectedButton() !== ui.Button.OK) return;

  updateStageOSTaskStatus_(taskId, statusResponse.getResponseText().trim());

  ui.alert("Task updated.");
}

function updateStageOSTaskStatus_(taskId, status) {
  const allowed = ["Backlog", "In Progress", "Testing", "Complete", "Paused"];
  if (!allowed.includes(status)) {
    throw new Error("Invalid status: " + status);
  }

  const tracker = getStageOSProjectTracker_();
  const roadmap = tracker.getSheetByName(STAGEOS_PROJECT_TRACKER.roadmapSheet);
  const values = roadmap.getDataRange().getValues();

  for (let r = 1; r < values.length; r++) {
    if (String(values[r][0]).trim() === String(taskId).trim()) {
      roadmap.getRange(r + 1, 5).setValue(status);

      if (status === "Complete") {
        roadmap.getRange(r + 1, 8).setValue(new Date());
        roadmap.getRange(r + 1, 10).setValue("Released");
      }

      refreshStageOSBuilderSilent_();
      return true;
    }
  }

  throw new Error("Could not find task ID: " + taskId);
}

