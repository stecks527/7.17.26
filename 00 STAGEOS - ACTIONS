function writeReportNotesFromCurrentInOut_() {
  const ss =
    SpreadsheetApp.getActive();

  const inOut =
    ss.getSheetByName("IN/OUT");

  if (!inOut) return false;

  if (
    typeof writeReportNotesFromPayload_ !==
    "function"
  ) {
    return stageOSActionMissing_(
      "Input IN/OUT Notes",
      [
        "writeReportNotesFromPayload_"
      ]
    );
  }

  return writeReportNotesFromPayload_({
    notes:
      inOut
        .getRange("A28")
        .getDisplayValue()
  });
}


